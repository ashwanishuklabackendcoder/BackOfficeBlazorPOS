@implements IDisposable
@inherits LayoutComponentBase
@using MudBlazor
@using POS.UI.Pages
@using POS.UI.Services
@using BackOfficeBlazor.Shared.DTOs
@inject IAuthService AuthService
@inject ICompanyBrandingService CompanyBrandingService
@inject NavigationManager Nav

<div class="page">
    <div class="sidebar">
        <NavMenu />
    </div>

    <main>
        <div class="top-row auth px-4">
            <div class="topbar-spacer" aria-hidden="true"></div>
            <a class="topbar-brand" href="dashboard">
                @if (!string.IsNullOrWhiteSpace(_branding?.CompanyLogoUrl))
                {
                    <img src="@_branding.CompanyLogoUrl"
                         alt="Company logo"
                         class="topbar-brand-logo" />
                }
                <span class="topbar-brand-name">
                    @(string.IsNullOrWhiteSpace(_branding?.CompanyName) ? "POS.UI" : _branding!.CompanyName)
                </span>
            </a>
            @if (AuthService.IsAuthenticated)
            {
                <div class="topbar-actions">
                    <div class="topbar-user">
                        <span class="text-muted small">Logged in as</span>
                        <span class="fw-semibold ms-2">@AuthService.CurrentUser?.Username</span>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary ms-3" @onclick="Logout">Logout</button>
                </div>
            }
        </div>
        <article class="content px-4">
            @Body
        </article>
    </main>
    <AppSnackbar />
    <SelectorOverlayHost />

</div>

@code {
    private CompanyBrandingDto? _branding;

    protected override async Task OnInitializedAsync()
    {
        CompanyBrandingService.Changed += HandleBrandingChanged;
        _branding = CompanyBrandingService.Current;
        await LoadBrandingAsync();
    }

    private async Task LoadBrandingAsync()
    {
        _branding = await CompanyBrandingService.GetAsync();
    }

    private void HandleBrandingChanged()
    {
        _branding = CompanyBrandingService.Current;
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        _branding = null;
        Nav.NavigateTo("/login", true);
    }

    public void Dispose()
    {
        CompanyBrandingService.Changed -= HandleBrandingChanged;
    }
}
