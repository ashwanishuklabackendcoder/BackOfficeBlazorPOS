@using POS.UI.Services
@inject AppSnackbarService SnackbarService
<style>
    .snackbar-container {
        position: fixed;
        bottom: 20px;
        right: 20px;
        z-index: 99999;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .snackbar {
        min-width: 260px;
        padding: 14px 18px;
        border-radius: 6px;
        color: white;
        font-size: 14px;
        box-shadow: 0 6px 12px rgba(0,0,0,0.15);
        animation: slidein .25s ease;
    }

    .snackbar-info {
        background: #0d6efd;
    }

    .snackbar-success {
        background: #198754;
    }

    .snackbar-warning {
        background: #ffc107;
        color: black;
    }

    .snackbar-error {
        background: #dc3545;
    }

    @@keyframes slidein {
        from

    {
        transform: translateX(100%);
        opacity: 0;
    }

    to {
        transform: translateX(0);
        opacity: 1;
    }

    }
</style>
<div class="snackbar-container">
    @foreach (var msg in SnackbarService.Messages)
    {
        <div class="snackbar @GetClass(msg.Type)">
            @msg.Message
        </div>

        _ = Task.Run(async () =>
        {
            await Task.Delay(msg.Timeout);
            SnackbarService.Remove(msg.Id);
        });
    }

</div>

@code {

    protected override void OnInitialized()
    {
        SnackbarService.OnChange += StateHasChanged;
    }

    string GetClass(SnackbarType type) => type switch
    {
        SnackbarType.Success => "snackbar-success",
        SnackbarType.Warning => "snackbar-warning",
        SnackbarType.Error => "snackbar-error",
        _ => "snackbar-info"
    };
}
