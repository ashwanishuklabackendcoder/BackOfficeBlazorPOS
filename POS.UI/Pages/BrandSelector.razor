@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@inject IManufacturerService BrandService
@inject IJSRuntime JS
@inject SelectorOverlayService OverlayService


<div class="position-relative" @ref="root" tabindex="0">
    <!-- Selector -->
    <div class="form-control d-flex justify-content-between align-items-center"
         style="cursor:pointer; min-height: calc(1.5em + 0.75rem + 2px);"
         @onclick="ToggleDropdownAsync">
        <span class="text-truncate">@(string.IsNullOrWhiteSpace(Value) ? " " : Value)</span>
        <span class="d-inline-flex align-items-center gap-2 ms-2">
            @if (!string.IsNullOrWhiteSpace(Value))
            {
                <button type="button"
                        title="Clear"
                        aria-label="Clear selection"
                        style="width:18px; height:18px; border:none; border-radius:50%; background:gray; color:white; display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; line-height:1; padding:0;"
                        @onclick="ClearSelection"
                        @onclick:stopPropagation="true">
                    &times;
                </button>
            }
            <i class="bi bi-chevron-down"></i>
        </span>
    </div>
</div>

@if (showManage)
{
    <div class="modal fade show d-block"
         style="background:rgba(0,0,0,.5); position:fixed; inset:0; z-index:3000; overflow:auto;">

        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content" style="max-height:90vh;">

                <!-- Header (fixed) -->
                <div class="modal-header">
                    <h5 class="modal-title">Manage Brands</h5>
                    <button class="btn-close" @onclick="CloseManage"></button>
                </div>

                <!-- Body (scrollable) -->
                <div class="modal-body" style="overflow-y:auto;">

                    <button class="btn btn-primary mb-3"
                            @onclick="NewBrand">
                        + New Brand
                    </button>

                    @if (isEditing)
                    {
                        <div class="border p-3 mb-3 rounded">
                            <label class="form-label text-danger">Brand Code *</label>
                            <input class="form-control"
                                   @bind="editId"
                                   maxlength="@(MaxLengthHelper.For<ManufacturerDto>(nameof(ManufacturerDto.Code)))" />
                            <label class="form-label text-danger">Brand Name *</label>
                            <input class="form-control"
                                   @bind="editBrandName"
                                   maxlength="@(MaxLengthHelper.For<ManufacturerDto>(nameof(ManufacturerDto.Name)))" />

                            <div class="mt-2">
                                <button class="btn btn-success me-2"
                                        @onclick="SaveBrand">
                                    Save and Select
                                </button>
                                <button class="btn btn-secondary"
                                        @onclick="CancelEdit">
                                    Cancel
                                </button>
                            </div>
                        </div>
                    }

                    <table class="table table-sm mb-0">
                        <tbody>
                            @foreach (var b in brands)
                            {
                                <tr>
                                    <td>@b.Name</td>
                                    <td class="text-end">
                                        <button class="btn btn-sm btn-link"
                                                @onclick="() => EditBrand(b)">
                                            Edit
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>

                </div>

            </div>
        </div>
    </div>
}

@code {

    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    List<ManufacturerDto> brands = new();

    bool isOpen;
    bool showManage;
    bool isEditing;

    string search = "";
    string editId;
    string editBrandName = "";
    SelectorOverlayPlacement? overlayPlacement;
    const string OverlayKey = nameof(BrandSelector);
    ElementReference root;
    IJSObjectReference? selectorModule;

    protected override void OnInitialized()
    {
        Value ??= "";
    }

    protected override async Task OnInitializedAsync()
    {
        brands = await BrandService.GetAllAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            selectorModule = await JS.InvokeAsync<IJSObjectReference>("import", "./selectorOverlay.js");
    }

    IEnumerable<ManufacturerDto> FilteredBrands =>
        string.IsNullOrWhiteSpace(search)
            ? brands
            : brands.Where(x =>
                (x.Name ?? string.Empty).Contains(search, StringComparison.OrdinalIgnoreCase));

    async Task ToggleDropdownAsync()
    {
        if (isOpen)
        {
            await CloseDropdownAsync();
            return;
        }

        await OpenDropdownAsync();
    }

    [JSInvokable]
    public async Task OnF5()
    {
        await OpenDropdownAsync();
    }

    async Task SelectBrand(ManufacturerDto b)
    {
        Value = b.Name;
        await ValueChanged.InvokeAsync(Value);
        await CloseDropdownAsync();
        await InvokeAsync(StateHasChanged);
        await root.FocusAsync();
    }

    async Task ClearSelection()
    {
        Value = "";
        search = "";
        await ValueChanged.InvokeAsync(Value);
        await CloseDropdownAsync();
        await InvokeAsync(StateHasChanged);
        await root.FocusAsync();
    }

    async Task OpenManageModal()
    {
        await CloseDropdownAsync();
        showManage = true;
    }

    void CloseManage()
    {
        showManage = false;
        CancelEdit();
    }

    void NewBrand()
    {
        isEditing = true;
        editId = "";
        editBrandName = "";
    }

    void EditBrand(ManufacturerDto b)
    {
        isEditing = true;
        editId = b.Code;
        editBrandName = b.Name;
    }
    async Task SaveBrand()
    {
        if (string.IsNullOrWhiteSpace(editBrandName))
            return;

        var dto = new ManufacturerDto
        {
            Code = editId,          
            Name = editBrandName
        };

        var response = await BrandService.SaveManufacturer(dto);

        if (response?.Success != true)
        {
            // TODO: replace with toast / alert UI if you have
            Console.WriteLine(response?.Message ?? "Save failed");
            return;
        }

        // Refresh dropdown list
        brands = await BrandService.GetAllAsync();

        // Auto-select saved brand
        Value = response.Data?.Name ?? editBrandName;
        await ValueChanged.InvokeAsync(Value);

        CloseManage();
    }

    async Task OpenDropdownAsync()
    {
        isOpen = true;
        overlayPlacement = selectorModule != null
            ? await selectorModule.InvokeAsync<SelectorOverlayPlacement>("measureAnchor", root)
            : null;
        await OverlayService.ShowAsync(
            OverlayKey,
            typeof(SelectorDropdownPanel<ManufacturerDto>),
            BuildOverlayParameters(),
            overlayPlacement,
            HandleOverlayDismissedAsync);
        await InvokeAsync(StateHasChanged);
    }

    async Task CloseDropdownAsync()
    {
        if (!isOpen && OverlayService.Current is null)
            return;

        await OverlayService.RequestCloseAsync();
        isOpen = false;
        overlayPlacement = null;
        await InvokeAsync(StateHasChanged);
    }

    async Task HandleOverlayDismissedAsync()
    {
        isOpen = false;
        overlayPlacement = null;
        await InvokeAsync(StateHasChanged);
    }

    IDictionary<string, object> BuildOverlayParameters()
    {
        return new Dictionary<string, object>
        {
            ["Items"] = FilteredBrands.ToList(),
            ["ItemText"] = (Func<ManufacturerDto, string>)(b => b.Name ?? string.Empty),
            ["IsSelected"] = (Func<ManufacturerDto, bool>)(b => string.Equals(Value, b.Name, StringComparison.OrdinalIgnoreCase)),
            ["ItemSelected"] = EventCallback.Factory.Create<ManufacturerDto>(this, SelectBrand),
            ["SearchChanged"] = EventCallback.Factory.Create<string>(this, OnSearchChanged),
            ["OnManage"] = EventCallback.Factory.Create(this, OpenManageModal),
            ["InitialSearch"] = search,
            ["SearchPlaceholder"] = "Search...",
            ["ManageLabel"] = "Manage"
        };
    }

    async Task OnSearchChanged(string value)
    {
        search = value;
        if (isOpen)
            await RefreshOverlayAsync();
    }

    async Task RefreshOverlayAsync()
    {
        if (!isOpen || overlayPlacement is null)
            return;

        await OverlayService.ShowAsync(
            OverlayKey,
            typeof(SelectorDropdownPanel<ManufacturerDto>),
            BuildOverlayParameters(),
            overlayPlacement,
            HandleOverlayDismissedAsync);
    }
  
    void CancelEdit()
    {
        isEditing = false;
        editId = "";
        editBrandName = "";
    }
}

