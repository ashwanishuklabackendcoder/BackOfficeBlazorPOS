@page "/category"
@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@using POS.UI.Shared
@inject ICategoryService CategoryService
@inject AppSnackbarService AppSnackbar
@inject IJSRuntime JS

@inherits LayoutComponentBase
@implements IAsyncDisposable

<PageTitle>Category Maintenance</PageTitle>

<FormGlassLayout Title="Category Maintenance"
                 Subtitle="Create category codes and assignment flags"
                 Id="category-form"
                 ScopeId="category-form">
    <ChildContent>
        <div class="glass-panel border rounded-3 px-3 py-3">
        <div class="row mb-3 align-items-center">
            <label class="col-sm-2 form-label-custom">Category Code</label>
            <div class="col-sm-3">
                <input class="form-control"
                       @bind="model.Code"
                       @onkeydown="OnCodeKeyDown"
                       maxlength="5"
                       data-enter-skip="true"
                       disabled="@isCodeLocked"
                       @ref="codeInput" />
                <div class="form-text text-muted small mt-1">
                    Leave blank to auto-generate after saving.
                </div>
            </div>
            <div class="col-sm-2">
                <button class="btn btn-primary w-100 search-btn" @onclick="Search">Search</button>
            </div>
        </div>

        <div class="section-divider"></div>

        <div class="row mb-3">
            <label class="col-sm-2 form-label-custom required-label">Description</label>
            <div class="col-sm-4">
                <input class="form-control"
                       @bind="model.Name"
                       @ref="nameInput"
                       maxlength="@(MaxLengthHelper.For<CategoryDto>(nameof(CategoryDto.Name)))" />
            </div>
        </div>
        <div class="row mb-3">
            <label class="col-sm-2 form-label-custom">Included In</label>
            <div class="col-sm-6">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" @bind="model.A" id="catA" />
                    <label class="form-check-label" for="catA">Cat A</label>
                </div>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" @bind="model.B" id="catB" />
                    <label class="form-check-label" for="catB">Cat B</label>
                </div>
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" @bind="model.C" id="catC" />
                    <label class="form-check-label" for="catC">Cat C</label>
                </div>
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-2 form-label-custom">Major Item</label>
            <div class="col-sm-2">
                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch" @bind="model.Major" id="majorItem" />
                    <label class="form-check-label" for="majorItem">Major</label>
                </div>
            </div>
        </div>
      
        
    </div>
    </ChildContent>
    <FooterContent>
        <div>
            @if (recordExists)
            {
                <button type="button"
                        class="btn btn-danger"
                        @onclick="Delete">
                    Delete
                </button>
            }
        </div>
        <div class="d-flex justify-content-end gap-2 ms-auto">
            <button type="button" class="btn btn-primary px-4" @onclick="Save">OK</button>
            <button type="button" class="btn btn-outline-secondary px-4" @onclick="Reset">Cancel</button>
        </div>
    </FooterContent>
</FormGlassLayout>

<div class="card mt-4 shadow-sm border-0">
   
    <div class="card-body p-0">
        <GenericGrid @ref="savedCategoriesGrid"
                     Title="Saved Categories"
                     GridKey="saved-categories"
                     Columns="SavedCategoryColumns"
                     LoadData="LoadSavedCategoriesForGrid"
                     OnRowClick="@( (CategoryDto item) => FillFormFromRow(item) )"
                     RowCssClass="GetCategoryRowClass" />
    </div>
</div>

@code {

    private static readonly string[] CategoryLevels = { "A", "B", "C" };
    private string? selectedCategoryCode;
    private bool isRowSelecting;
    private GenericGrid<CategoryDto>? savedCategoriesGrid;
    private readonly List<GridColumn<CategoryDto>> SavedCategoryColumns = new()
    {
        new GridColumn<CategoryDto>
        {
            Title = "Code",
            Key = "Code",
            Value = c => c.Code,
            ColumnFilterType = GridFilterType.Text,
            IsHideable = false,
            IsVisible = true
        },
        new GridColumn<CategoryDto>
        {
            Title = "Description",
            Key = "Name",
            Value = c => c.Name,
            ColumnFilterType = GridFilterType.Text,
            IsVisible = true
        },
        new GridColumn<CategoryDto>
        {
            Title = "Cat A",
            Key = "A",
            Value = c => c.A ? "Yes" : "No",
            ColumnFilterType = GridFilterType.Dropdown,
            LookupValues = new[] { "Yes", "No" },
            IsVisible = true
        },
        new GridColumn<CategoryDto>
        {
            Title = "Cat B",
            Key = "B",
            Value = c => c.B ? "Yes" : "No",
            ColumnFilterType = GridFilterType.Dropdown,
            LookupValues = new[] { "Yes", "No" },
            IsVisible = true
        },
        new GridColumn<CategoryDto>
        {
            Title = "Cat C",
            Key = "C",
            Value = c => c.C ? "Yes" : "No",
            ColumnFilterType = GridFilterType.Dropdown,
            LookupValues = new[] { "Yes", "No" },
            IsVisible = true
        },
        new GridColumn<CategoryDto>
        {
            Title = "Major",
            Key = "Major",
            Value = c => c.Major ? "Yes" : "No",
            ColumnFilterType = GridFilterType.Dropdown,
            LookupValues = new[] { "Yes", "No" },
            IsHideable = false,
            IsVisible = true
        }
    };

    CategoryDto model = new();
    bool recordExists = false;
    bool isCodeLocked = false;

    ElementReference codeInput;
    ElementReference nameInput;

    DotNetObjectReference<Categories>? dotNetRef;
    string? shortcutRegistrationId;

    [JSInvokable]
    public async Task OnEsc()
    {
        await Reset();
        await AppSnackbar.Show("Enter Code to search Category", SnackbarType.Info);
    }

    // 🔥 ENTER ON CODE
    async Task OnCodeKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter")
            return;
        await Task.Yield();
        // 🔹 Blank → New Mode
        if (string.IsNullOrWhiteSpace(model.Code))
        {
            model = new CategoryDto();
            recordExists = false;
            isCodeLocked = true;

            await AppSnackbar.Show(
                "New category mode activated.",
                SnackbarType.Info);

            await Task.Delay(50);
            await nameInput.FocusAsync();
            return;
        }

        // 🔹 Otherwise search
        await Search();

        await Task.Delay(50);
        await nameInput.FocusAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        dotNetRef = DotNetObjectReference.Create(this);
        shortcutRegistrationId = await JS.InvokeAsync<string>(
            "blazorShortcuts.register",
            dotNetRef,
            new
            {
                scopeSelector = "#category-form",
                enableEsc = true,
                enableEnter = true
            });

        await codeInput.FocusAsync();
    }
    async Task Search()
    {
        if (string.IsNullOrWhiteSpace(model.Code))
        {
            await AppSnackbar.Show("Enter Category Code", SnackbarType.Warning);
            return;
        }

        var response = await CategoryService.GetCategory(model.Code);

        if (response?.Success == true && response.Data != null)
        {
            model = response.Data;
            recordExists = true;

            await AppSnackbar.Show("Category loaded", SnackbarType.Success);
        }
        else
        {
            recordExists = false;
            var code = model.Code;

            model = new CategoryDto { Code = code };

            await AppSnackbar.Show(
                "No record found. New category will be created.",
                SnackbarType.Info);
            model.Code = "";
            isCodeLocked = true;
        }
    }

    async Task Save()
    {
        if (string.IsNullOrWhiteSpace(model.Name))
        {
            await AppSnackbar.Show("Description required", SnackbarType.Error);
            return;
        }

        var isNewInsert = string.IsNullOrWhiteSpace(model.Code);
        var res = await CategoryService.SaveCategory(model);

        if (res?.Success == true)
        {
            if (isNewInsert)
            {
                await AppSnackbar.Show(res?.Message ?? "Saved", SnackbarType.Success);
                await Reset();
            }
            else
            {
                if (res.Data != null)
                {
                    model = res.Data;
                }

                await AppSnackbar.Show(res?.Message ?? "Saved", SnackbarType.Success);
                recordExists = true;
                selectedCategoryCode = model.Code;
                isCodeLocked = true;

                if (savedCategoriesGrid != null)
                    await savedCategoriesGrid.ReloadAsync();
            }
        }
        else
        {
            await AppSnackbar.Show(res?.Message ?? "Save failed", SnackbarType.Error);
        }
    }

    async Task Delete()
    {
        if (!recordExists) return;

        var res = await CategoryService.DeleteCategory(model.Code);

        if (res?.Success == true)
            await AppSnackbar.Show(res?.Message ?? "Deleted", SnackbarType.Success);
        else
            await AppSnackbar.Show(res?.Message ?? "Delete failed", SnackbarType.Error);

        await Reset();
        if (savedCategoriesGrid != null)
            await savedCategoriesGrid.ReloadAsync();
    }

    async Task Reset()
    {
        model = new CategoryDto();
        recordExists = false;
        isCodeLocked = false;   // 🔴 IMPORTANT
        selectedCategoryCode = null;

        await InvokeAsync(StateHasChanged);
        await codeInput.FocusAsync();
        if (savedCategoriesGrid != null)
            await savedCategoriesGrid.ReloadAsync();
    }

    private async Task<List<CategoryDto>> LoadSavedCategoriesForGrid()
    {
        var aggregate = new Dictionary<string, CategoryDto>(StringComparer.OrdinalIgnoreCase);

        foreach (var level in CategoryLevels)
        {
            var list = await CategoryService.GetAllCategory(level);
            foreach (var item in list)
            {
                if (string.IsNullOrWhiteSpace(item.Code))
                    continue;

                if (!aggregate.ContainsKey(item.Code))
                    aggregate[item.Code] = item;
            }
        }

        return aggregate.Values
            .OrderBy(x => x.Code)
            .ToList();
    }

    private async Task FillFormFromRow(CategoryDto category)
    {
        if (string.IsNullOrWhiteSpace(category.Code))
            return;

        // Avoid wiping unsaved changes on repeated clicks of the already-selected row.
        if (string.Equals(category.Code, selectedCategoryCode, StringComparison.OrdinalIgnoreCase))
            return;

        if (isRowSelecting)
            return;

        isRowSelecting = true;
        try
        {
        model = new CategoryDto
        {
            Code = category.Code,
            Name = category.Name,
            A = category.A,
            B = category.B,
            C = category.C,
            Major = category.Major
        };

        recordExists = true;
        isCodeLocked = true;
        selectedCategoryCode = category.Code;

        await InvokeAsync(StateHasChanged);
        await nameInput.FocusAsync();
        }
        finally
        {
            isRowSelecting = false;
        }
    }

    private string GetCategoryRowClass(CategoryDto item) =>
        string.Equals(item.Code, selectedCategoryCode, StringComparison.OrdinalIgnoreCase)
            ? "table-primary"
            : string.Empty;
    public async ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();
        if (!string.IsNullOrWhiteSpace(shortcutRegistrationId))
        {
            try
            {
                await JS.InvokeVoidAsync("blazorShortcuts.unregister", shortcutRegistrationId);
            }
            catch
            {
                // Ignore JS disconnection during teardown.
            }
        }
    }

}
