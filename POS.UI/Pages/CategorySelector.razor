@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@inject ICategoryService CategoryService
@inject IJSRuntime JS
@implements IAsyncDisposable

<div class="position-relative" @ref="root" tabindex="0">
    <div class="form-control d-flex justify-content-between align-items-center"
         style="cursor:pointer; min-height: calc(1.5em + 0.75rem + 2px);"
         @onclick="Toggle">
        <span class="text-truncate">@Display</span>
        <span class="d-inline-flex align-items-center gap-2 ms-2">
            @if (!string.IsNullOrWhiteSpace(Code) || !string.IsNullOrWhiteSpace(Name))
            {
                <button type="button"
                        title="Clear"
                        aria-label="Clear selection"
                        style="width:18px; height:18px; border:none; border-radius:50%; background:gray; color:white; display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; line-height:1; padding:0;"
                        @onclick="ClearSelection"
                        @onclick:stopPropagation="true">
                    ×
                </button>
            }
            <i class="bi bi-chevron-down"></i>
        </span>
    </div>

    @if (open)
    {
        <div class="border bg-white shadow p-2"
             style="position:absolute; top:100%; left:0; z-index:1055; width:clamp(300px, 150%, 560px); max-width:calc(100vw - 1rem); height:260px; min-height:230px; max-height:80vh; display:flex; flex-direction:column; resize:both; overflow:hidden;">
            <div class="p-2 border-bottom">
                <input class="form-control border"
                       @ref="searchInput"
                       @oninput="OnInput" />

            </div>
           

            <div style="flex:1 1 auto; min-height:80px; overflow:auto">
                @foreach (var c in filtered)
                {
                    <button class="list-group-item list-group-item-action"
                            @onclick="() => Select(c)">
                        @c.Code - @c.Name
                    </button>
                }
            </div>

            <div class="border-top p-2 bg-light">
                <button type="button"
                        class="btn text-primary p-0"
                        @onclick="OpenManage"
                        @onclick:stopPropagation="true">
                    <i class="bi bi-gear me-1"></i>Manage
                </button>
            </div>
        </div>
    }
</div>

@if (showManage)
{
    <div class="modal fade show d-block"
         style="background:rgba(0,0,0,.5); position:fixed; inset:0; z-index:3000; overflow:auto;">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Manage Categories</h5>
                    <button class="btn-close" @onclick="CloseManage"></button>
                </div>

                <div class="modal-body">
                 @*    <CategoryEditor OnSaved="OnCategorySaved"
                                    OnCancel="CloseManage" /> *@
                    <Categories  />
                </div>

            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string Level { get; set; } = "A";

    [Parameter] public string? Code { get; set; }
    [Parameter] public EventCallback<string?> CodeChanged { get; set; }

    [Parameter] public string? Name { get; set; }
    [Parameter] public EventCallback<string?> NameChanged { get; set; }

    bool open, showManage;
    string search = "";
    List<CategoryDto> list = new();
    ElementReference root;
    ElementReference searchInput;
    IJSObjectReference? module;
    IJSObjectReference? outsideHandler;
    DotNetObjectReference<CategorySelector>? dotNetRef;
    string Display =>
     !string.IsNullOrEmpty(Name)
         ? Name
         : !string.IsNullOrEmpty(Code)
             ? Code
             : " ";


    IEnumerable<CategoryDto> filtered => list;
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./clickOutside.js");

            outsideHandler = await JS.InvokeAsync<IJSObjectReference>(
                "registerClickOutside", root, dotNetRef);

        }
    }

    [JSInvokable]
    public void OnClickOutside()
    {
        if (open)
        {
            open = false;
            InvokeAsync(StateHasChanged);
        }
    }
    void Toggle() => open = !open;

    [JSInvokable]
    public async Task OnF5()
    {
        open = true;
        showManage = false;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        await searchInput.FocusAsync();
    }

    protected override async Task OnInitializedAsync()
    {
        list = await CategoryService.GetAllCategory(Level);

        // Default binding (Code → Name)
        if (!string.IsNullOrWhiteSpace(Code))
        {
            var match = list.FirstOrDefault(x =>
                x.Code.Equals(Code, StringComparison.OrdinalIgnoreCase));

            if (match != null)
            {
                Name = match.Name;
                await NameChanged.InvokeAsync(Name);
            }
        }
    }

    async Task OnInput(ChangeEventArgs e)
    {
        search = e.Value?.ToString() ?? "";

        if (search.Length < 3)
        {
            list = await CategoryService.GetAllCategory(Level);
            return;
        }

        list = await CategoryService.Suggest(Level, search)
               ?? new List<CategoryDto>();
    }

    async Task Select(CategoryDto c)
    {
        Code = c.Code;
        Name = c.Name;

        await CodeChanged.InvokeAsync(Code);
        await NameChanged.InvokeAsync(Name);

        open = false;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        await root.FocusAsync();
    }

    async Task ClearSelection()
    {
        Code = "";
        Name = "";
        search = "";
        await CodeChanged.InvokeAsync(Code);
        await NameChanged.InvokeAsync(Name);
        open = false;
        await InvokeAsync(StateHasChanged);
        await Task.Yield();
        await root.FocusAsync();
    }

    void OpenManage()
    {
        open = false;
        showManage = true;
    }

    async Task OnCategorySaved(CategoryDto c)
    {
        Code = c.Code;
        Name = c.Name;

        await CodeChanged.InvokeAsync(Code);
        await NameChanged.InvokeAsync(Name);

        showManage = false;
    }

    void CloseManage() => showManage = false;

    public async ValueTask DisposeAsync()
    {
        if (outsideHandler != null)
            await outsideHandler.InvokeVoidAsync("dispose");

        dotNetRef?.Dispose();
    }
}
