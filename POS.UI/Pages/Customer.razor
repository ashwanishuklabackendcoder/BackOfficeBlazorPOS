@page "/customer"
@using BackOfficeBlazor.Shared.DTOs
@using System.Linq
@using System.Text.Json
@using POS.UI.Services
@using POS.UI.Shared

@inject ICustomerService CustomerService
@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject AppSnackbarService AppSnackbar
@inject IJSRuntime JS


<PageTitle>Customer Maintenance</PageTitle>

<FormGlassLayout Title="Customer Maintenance"
                 Id="customer-form"
                 ScopeId="customer-form">
    <ChildContent>
        <div class="glass-panel border rounded-3 px-3 py-3">
            <div class="row mb-3 align-items-center">
                <label class="col-sm-2 col-lg-1 form-label-custom">Account No</label>
                <div class="col-sm-3 col-lg-2">
                    <input id="AccNo"
                           class="form-control"
                           @bind="model.AccNo"
                           maxlength="5"
                           @onkeydown="OnAccKeyDown"
                           data-enter-skip="true"
                           disabled="@isAccLocked"
                           @ref="accInput" />
                    <div class="form-text text-muted small mt-1">
                        Leave blank to auto-generate after saving.
                    </div>
                </div>
                <div class="col-sm-2 col-lg-1">
                    <button type="button"
                            class="btn btn-primary w-100 search-btn"
                            @onclick="Search">
                        Search
                    </button>
                </div>
            </div>
        </div>

        <div class="section-divider"></div>

        <div class="glass-panel border rounded-3 px-3 py-3">
            <div class="info-header">
                <h6 class="fw-bold mb-0 text-primary">Billing Details</h6>
            </div>

        <div class="row">
            <div class="col-md-6">

                <div class="row mb-2">
                    <div class="col-sm-3">
                        <label class="form-label-custom">Title</label>
                        <input class="form-control"
                               @bind="model.Title"
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Title)))"
                               @ref="titleInput" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Initials</label>
                        <input class="form-control"
                               @bind="model.Initials"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Initials)))" />
                    </div>
              
        @*             <div class="col-sm-2">
                        <label>House Name</label>
                        <input class="form-control" @bind="model.HouseName" />
                    </div> *@
                    <div class="col-sm-3">
                        <label class="form-label-custom">Firstname</label>
                        <input class="form-control"
                               @bind="model.Firstname"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Firstname)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Surname</label>
                        <input class="form-control"
                               @bind="model.Surname"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Surname)))" />
                    </div>
                </div>
                <div class="row mb-2">
             
                </div>
                <div class="row mb-2">

                    <div class="col-sm-3">
                        <label class="form-label-custom">Address 1</label>
                        <input class="form-control"
                               @bind="model.Address1"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Address1)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Address 2</label>
                        <input class="form-control mb-1"
                               @bind="model.Address2"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Address2)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Address 3</label>
                        <input class="form-control mb-1"
                               @bind="model.Address3"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Address3)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Address 4</label>
                        <input class="form-control mb-2"
                               @bind="model.Address4"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Address4)))" />
                    </div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-3">
                        <label class="form-label-custom">Country</label>
                        <input class="form-control"
                               @bind="model.Country"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Country)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Postcode</label>
                        <input class="form-control"
                               @bind="model.Postcode"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Postcode)))" />
                    </div>
          
                </div>
                <div class="row mb-2">
                    <div class="col-sm-3">
                        <label class="form-label-custom">Email</label>
                        <input class="form-control"
                               @bind="model.Email"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Email)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Telephone</label>
                        <input class="form-control"
                               @bind="model.Telephone"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Telephone)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Mobile</label>
                        <input class="form-control"
                               @bind="model.Mobile"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Mobile)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Work Phone</label>
                        <input class="form-control"
                               @bind="model.WorkPhone"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.WorkPhone)))" />
                    </div>
                 
                </div>
            

               

            </div>

            <div class="col-md-6">
                <div class="row mb-2">
                    <div class="col-sm-2">
                        <label class="form-label-custom">Category</label>
                        <input class="form-control"
                               @bind="model.Category"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.Category)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Loyalty No</label>
                        <input class="form-control"
                               @bind="model.LoyaltyNo"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.LoyaltyNo)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Date of Birth</label>
                        <input type="date"
                               class="form-control"
                                
                               @bind="model.DOB" />
                    </div>
                </div>
                <label class="form-label-custom">Credit & Discounts</label>
                <div class="row mb-2">
                    <div class="col-sm-6">
                        <input type="number"
                               step="0.01"
                               class="form-control"
                               @bind="model.CreditLimit"
                                
                               placeholder="Credit Limit" />
                    </div>
                    <div class="col-sm-6">
                        <input type="number"
                               step="0.01"
                               class="form-control"
                               @bind="model.Balance"
                                
                               placeholder="Balance" />
                    </div>
                </div>

                <div class="row mb-2">
                    <div class="col-sm-6">
                        <input type="number"
                               class="form-control"
                               @bind="model.DiscountMinor"
                                
                               placeholder="Minor Discount" />
                    </div>
                    <div class="col-sm-6">
                        <input type="number"
                               class="form-control"
                               @bind="model.DiscountMajor"
                                
                               placeholder="Major Discount" />
                    </div>
                </div>

            

              

              

           

                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch"  @bind="model.Stop" id="custStop" />
                    <label class="form-check-label" for="custStop">Stop</label>
                </div>

                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch"   @bind="model.SendLetter" id="custSendLetter" />
                    <label class="form-check-label" for="custSendLetter">Send Letter</label>
                </div>

                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch"   @bind="model.VATExempt" id="custVatExempt" />
                    <label class="form-check-label" for="custVatExempt">VAT Exempt</label>
                </div>

                <div class="form-check form-switch">
                    <input class="form-check-input" type="checkbox" role="switch"   @bind="model.Autopay" id="custAutopay" />
                    <label class="form-check-label" for="custAutopay">Autopay</label>
                </div>

            </div>
        </div>

        </div>

        <div class="section-divider"></div>

        <div class="glass-panel border rounded-3 px-3 py-3">
        <div class="info-header">
            <h6 class="fw-bold mb-0 text-primary">Delivery Details</h6>
        </div>

        <div class="row">
            <div class="col-md-6">

                <div class="row mb-2">
                    <div class="col-sm-3">
                        <label class="form-label-custom">Title</label>
                        <input class="form-control"
                               @bind="model.DeliveryTitle"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.DeliveryTitle)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Initials</label>
                        <input class="form-control"
                               @bind="model.DeliveryInitials"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.DeliveryInitials)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Firstname</label>
                        <input class="form-control"
                               @bind="model.DeliveryFirstname"
                                
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.DeliveryFirstname)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Surname</label>
                        <input class="form-control"
                               @bind="model.DeliverySurname"
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.DeliverySurname)))" />
                    </div>
                </div>
                <div class="row mb-2">
                    <div class="col-sm-3">
                        <label class="form-label-custom">House Name</label>
                        <input class="form-control"
                               @bind="model.DeliveryHousename"
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.DeliveryHousename)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Address 1</label>
                        <input class="form-control mb-1"
                               @bind="model.DeliveryAddress1"
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.DeliveryAddress1)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Address 2</label>
                        <input class="form-control mb-1"
                               @bind="model.DeliveryAddress2"
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.DeliveryAddress2)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Address 3</label>
                        <input class="form-control mb-1"
                               @bind="model.DeliveryAddress3"
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.DeliveryAddress3)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Address 4</label>
                        <input class="form-control mb-2"
                               @bind="model.DeliveryAddress4"
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.DeliveryAddress4)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Postcode</label>
                        <input class="form-control"
                               @bind="model.DeliveryPostcode"
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.DeliveryPostcode)))" />
                    </div>
                    <div class="col-sm-3">
                        <label class="form-label-custom">Country</label>
                        <input class="form-control"
                               @bind="model.DeliveryCountry"
                               maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.DeliveryCountry)))" />
                    </div>
                </div>

            </div>
        </div>
        </div>
        </ChildContent>
        <FooterContent>
            <div>
                @if (recordExists)
                {
                    <button type="button" class="btn btn-danger" @onclick="Delete">Delete</button>
                }
            </div>
            <div class="d-flex justify-content-end gap-2 ms-auto">
                <button type="button" class="btn btn-primary px-4" @onclick="Save">OK</button>
                <button type="button" class="btn btn-outline-secondary px-4" @onclick="Reset">Cancel</button>
            </div>
        </FooterContent>
</FormGlassLayout>

<div class="card mt-4 shadow-sm border-0">
    
    <div class="card-body p-0">
        <GenericGrid @ref="savedCustomersGrid"
                     Title="Saved Customers"
                     GridKey="saved-customers"
                     Columns="SavedCustomerColumns"
                     LoadData="LoadSavedCustomersForGrid"
                     OnRowClick="@( (CustomerDto item) => FillFormFromRow(item) )"
                     RowCssClass="GetCustomerRowClass" />
    </div>
</div>

@code {
    CustomerDto model = new();
    bool recordExists = false;
    bool isAccLocked = false;
    private string? selectedCustomerAccNo;
    private bool isRowSelecting;
    private GenericGrid<CustomerDto>? savedCustomersGrid;
    private readonly List<GridColumn<CustomerDto>> SavedCustomerColumns = new()
    {
        new GridColumn<CustomerDto>
        {
            Title = "Account",
            Key = nameof(CustomerDto.AccNo),
            Value = c => c.AccNo,
            ColumnFilterType = GridFilterType.Text,
            IsHideable = false,
            IsVisible = true
        },
        new GridColumn<CustomerDto>
        {
            Title = "Name",
            Key = "CustomerName",
            Value = c => RenderCustomerNameForGrid(c),
            ColumnFilterType = GridFilterType.Text,
            IsVisible = true
        },
        new GridColumn<CustomerDto>
        {
            Title = "Email",
            Key = nameof(CustomerDto.Email),
            Value = c => c.Email,
            ColumnFilterType = GridFilterType.Text,
            IsVisible = true
        },
        new GridColumn<CustomerDto>
        {
            Title = "Telephone",
            Key = nameof(CustomerDto.Telephone),
            Value = c => c.Telephone,
            ColumnFilterType = GridFilterType.Text,
            IsVisible = true
        }
    };

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
    }

    ElementReference accInput;
    ElementReference titleInput;
    DotNetObjectReference<Customer>? dotNetRef;
    string? shortcutRegistrationId;
    async Task OnAccKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter")
            return;
        await Task.Yield();
        // 🔹 CASE 1 — Blank Account No → New Customer Mode
        if (string.IsNullOrWhiteSpace(model.AccNo))
        {
            model = new CustomerDto();
            recordExists = false;

            isAccLocked = true;

            await AppSnackbar.Show(
                "New customer mode activated.",
                SnackbarType.Info);

            await Task.Delay(50); // allow render

            await titleInput.FocusAsync();

            return;
        }

        // 🔹 CASE 2 — Search Existing
        await Search();
        await titleInput.FocusAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        dotNetRef = DotNetObjectReference.Create(this);
        shortcutRegistrationId = await JS.InvokeAsync<string>(
            "blazorShortcuts.register",
            dotNetRef,
            new
            {
                scopeSelector = "#customer-form",
                enableEsc = true,
                enableEnter = true
            });

        await accInput.FocusAsync();
    }
   
    [JSInvokable]
    public async Task OnEsc()
    {
        await Reset();
        await AppSnackbar.Show("Enter Account Number to search customer", SnackbarType.Info);
    }
    async Task Search()
    {
        // 🔹 Case 1: Blank → New Customer Mode
        if (string.IsNullOrWhiteSpace(model.AccNo))
        {
            model = new CustomerDto();
            recordExists = false;

            await AppSnackbar.Show(
                "New customer mode activated. Enter details and Save.",
                SnackbarType.Info);
            await accInput.FocusAsync();
            return;
        }

        // 🔹 Case 2: Search Existing
        var res = await CustomerService.GetAsync(model.AccNo);

        if (res?.Success == true && res.Data != null)
        {
            model = res.Data;
            recordExists = true;

            await AppSnackbar.Show("Customer loaded", SnackbarType.Success);
        }
        else
        {
            var acc = model.AccNo;

            model = new CustomerDto { AccNo = acc };
            recordExists = false;

            await AppSnackbar.Show("Customer not found. New record will be created.",
                SnackbarType.Warning);
        
            model.AccNo = "";
            isAccLocked = true;
        }
    }
    async Task Save()
    {
        var isNewInsert = string.IsNullOrWhiteSpace(model.AccNo);
        var res = await CustomerService.SaveAsync(model);

        if (res?.Success == true)
        {
            if (isNewInsert)
            {
                await AppSnackbar.Show(res?.Message ?? "Saved", SnackbarType.Success);
                await Reset();
            }
            else
            {
                if (res.Data != null)
                {
                    model = res.Data;
                }

                await AppSnackbar.Show(res?.Message ?? "Saved", SnackbarType.Success);
                recordExists = true;
                selectedCustomerAccNo = model.AccNo;
                isAccLocked = true;

                if (savedCustomersGrid != null)
                    await savedCustomersGrid.ReloadAsync();
            }
        }
        else
        {
            await AppSnackbar.Show(res?.Message ?? "Save failed", SnackbarType.Error);
        }
    }

    async Task Delete()
    {
        if (!recordExists) return;

        var res = await CustomerService.DeleteAsync(model.AccNo);

        if (res?.Success == true)
        {
            await AppSnackbar.Show(res?.Message ?? "Deleted", SnackbarType.Success);
            await Reset();
        }
        else
        {
            await AppSnackbar.Show(res?.Message ?? "Delete failed", SnackbarType.Error);
        }
    }

    async Task Reset()
    {
        model = new CustomerDto();
        recordExists = false;
        isAccLocked = false;   // 🔴 IMPORTANT
        selectedCustomerAccNo = null;

        await InvokeAsync(StateHasChanged);
        if (savedCustomersGrid != null)
            await savedCustomersGrid.ReloadAsync();
        await accInput.FocusAsync();
    }

    private async Task<List<CustomerDto>> LoadSavedCustomersForGrid()
    {
        var res = await CustomerService.GetAllAsync();

        if (res?.Success == true && res.Data != null)
        {
            return res.Data
                .Where(x => !string.IsNullOrWhiteSpace(x.AccNo))
                .OrderBy(x => x.AccNo)
                .ToList();
        }

        return new();
    }

    private async Task FillFormFromRow(CustomerDto customer)
    {
        if (customer == null || string.IsNullOrWhiteSpace(customer.AccNo))
            return;

        // Avoid wiping unsaved changes on repeated clicks of the already-selected row.
        if (string.Equals(customer.AccNo, selectedCustomerAccNo, StringComparison.OrdinalIgnoreCase))
            return;

        if (isRowSelecting)
            return;

        isRowSelecting = true;
        try
        {
        var clone = JsonSerializer.Deserialize<CustomerDto>(
            JsonSerializer.Serialize(customer)) ?? new CustomerDto();

        model = clone;
        recordExists = true;
        isAccLocked = true;
        selectedCustomerAccNo = customer.AccNo;

        await InvokeAsync(StateHasChanged);
        await titleInput.FocusAsync();
        }
        finally
        {
            isRowSelecting = false;
        }
    }

    private string RenderCustomerName(CustomerDto customer)
    {
        var names = new[] { customer.Firstname, customer.Surname }
           .Where(s => !string.IsNullOrWhiteSpace(s));
        return string.Join(" ", names);
    }

    private static string RenderCustomerNameForGrid(CustomerDto customer)
    {
        var names = new[] { customer.Firstname, customer.Surname }
           .Where(s => !string.IsNullOrWhiteSpace(s));
        return string.Join(" ", names);
    }

    private string GetCustomerRowClass(CustomerDto item) =>
        string.Equals(item.AccNo, selectedCustomerAccNo, StringComparison.OrdinalIgnoreCase)
            ? "table-primary"
            : string.Empty;
    public async ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();
        if (!string.IsNullOrWhiteSpace(shortcutRegistrationId))
        {
            try
            {
                await JS.InvokeVoidAsync("blazorShortcuts.unregister", shortcutRegistrationId);
            }
            catch
            {
                // Ignore JS disconnection during teardown.
            }
        }
    }
}

