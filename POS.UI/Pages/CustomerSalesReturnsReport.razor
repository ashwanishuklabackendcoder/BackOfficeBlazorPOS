@page "/customer-sales-returns-report"

@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@using System.Globalization
@using System.Net

@inject IReportService ReportService
@inject ILocationService LocationService
@inject AppSnackbarService AppSnackbar
@inject IJSRuntime JS

<PageTitle>Customer Sales/Returns Report</PageTitle>

<div class="card shadow-sm">
    <div class="card-header fw-bold">
        Customer Sales / Returns
    </div>

    <div class="card-body">
        <div class="row g-3 align-items-end mb-3">
            <div class="col-md-3">
                <label class="form-label">Customer Account (optional)</label>
                <input class="form-control"
                       @bind="CustomerAccNo"
                       maxlength="@(MaxLengthHelper.For<CustomerDto>(nameof(CustomerDto.AccNo)))" />
            </div>

            <div class="col-md-3">
                <label class="form-label">From Date</label>
                <input type="date" class="form-control" @bind="FromDate" />
            </div>

            <div class="col-md-3">
                <label class="form-label">To Date</label>
                <input type="date" class="form-control" @bind="ToDate" />
            </div>

            <div class="col-md-2">
                <button class="btn btn-primary w-100"
                        disabled="@(!HasTransactionSelection)"
                        @onclick="() => LoadReport()">
                    LOAD
                </button>
            </div>
        </div>
        <div class="row g-3 align-items-center mb-3">
            <div class="col-md-4">
                <div class="form-check form-switch">
                    <input class="form-check-input"
                           type="checkbox"
                           id="toggleSales"
                           checked="@ShowSales"
                           @onchange="OnSalesToggle" />
                    <label class="form-check-label" for="toggleSales">
                        Include Sales
                    </label>
                </div>
                <div class="form-check form-switch">
                    <input class="form-check-input"
                           type="checkbox"
                           id="toggleReturns"
                           checked="@ShowReturns"
                           @onchange="OnReturnsToggle" />
                    <label class="form-check-label" for="toggleReturns">
                        Include Returns
                    </label>
                </div>
                @if (!HasTransactionSelection)
                {
                    <small class="text-danger">
                        Select at least one transaction type.
                    </small>
                }
            </div>
        </div>
        <div class="mb-3">
            <label class="form-label">Locations</label>
            <div>
                <button class="btn btn-outline-secondary"
                        @onclick="ToggleLocationDropdown">
                    @LocationSummary
                </button>
            </div>
            @if (ShowLocationDropdown)
            {
                <div class="border rounded p-2 mt-2" style="max-width:420px;">
                    <div class="form-check mb-2">
                        <input class="form-check-input"
                               type="checkbox"
                               id="loc_all"
                               checked="@(SelectedLocationCodes.Count == 0)"
                               @onchange="ToggleAllLocations" />
                        <label class="form-check-label" for="loc_all">
                            All Locations
                        </label>
                    </div>

                    @foreach (var loc in Locations)
                    {
                        var isChecked = SelectedLocationCodes.Contains(loc.Code);
                        <div class="form-check">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="@($"loc_{loc.Code}")"
                                   checked="@isChecked"
                                   @onchange="e => ToggleLocation(loc.Code, e)" />
                            <label class="form-check-label" for="@($"loc_{loc.Code}")">
                                @loc.Code - @loc.Name
                            </label>
                        </div>
                    }
                </div>
            }
        </div>
        <div class="d-flex gap-2 mb-3">
            <button class="btn btn-outline-secondary"
                    disabled="@(Lines == null || !Lines.Any())"
                    @onclick="ExportCsv">
                Export CSV
            </button>
            <button class="btn btn-outline-secondary"
                    disabled="@(Lines == null || !Lines.Any())"
                    @onclick="ExportPdf">
                Export PDF
            </button>
        </div>

        <table class="table table-sm table-bordered">
            <thead class="table-light">
                <tr>
                    <th>Date</th>
                    
                    <th>Part</th>
                    <th>Description</th>
                    <th>Manufacturer</th>
                    <th>Brand</th>
                    <th>Type</th>
                    <th>Invoice</th>
                    <th>StockNo</th>
                    <th>Qty</th>
                    <th>Sell</th>
                    <th>Net</th>
                    <th>Location</th>
                    <th>Terminal</th>
                </tr>
            </thead>
            <tbody>
                @if (Lines == null)
                {
                    <tr><td colspan="13">Load a report</td></tr>
                }
                else if (!Lines.Any())
                {
                    <tr><td colspan="13">No records</td></tr>
                }
                else
                {
                    @foreach (var line in Lines)
                    {
                        <tr class="@(line.InOut == "R" ? "table-warning" : "")">
                            <td>@line.DateAndTime.ToString("dd-MM-yyyy", CultureInfo.InvariantCulture)</td>
                          
                            <td>@line.PartNumber</td>
                            <td>@line.Description</td>
                            <td>@line.Manufacturer</td>
                            <td>@line.Brand</td>
                            <td>@(line.InOut == "R" ? "Return" : "Sale")</td>
                            <td>@line.InvoiceNumber</td>
                            <td>@line.StockNo</td>
                            <td>@line.Quantity</td>
                            <td>@line.Sell</td>
                            <td>@line.Net</td>
                            <td>@line.Location</td>
                            <td>@line.Terminal</td>
                        </tr>
                    }
                }
            </tbody>
        </table>

        @if (Lines != null && Lines.Any())
        {
            <div class="d-flex justify-content-end gap-4 mt-3">
                <div>
                    <span class="text-muted">Total Sales:</span>
                    <b>@TotalSales.ToString("0.00")</b>
                </div>
                <div>
                    <span class="text-muted">Total Returns:</span>
                    <b>@TotalReturns.ToString("0.00")</b>
                </div>
            </div>
        }
    </div>
</div>

@code {
    string? CustomerAccNo;
    DateTime FromDate = DateTime.Today;
    DateTime ToDate = DateTime.Today;
    List<LocationDto> Locations = new();
    HashSet<string> SelectedLocationCodes = new();
    bool ShowLocationDropdown;

    List<CustomerSalesReturnLineDto>? Lines;
    bool ShowSales = true;
    bool ShowReturns = true;

    bool HasTransactionSelection => ShowSales || ShowReturns;

    decimal TotalSales =>
        Lines?.Where(x => x.InOut == "O").Sum(x => x.Net) ?? 0m;

    decimal TotalReturns =>
        Lines?.Where(x => x.InOut == "R").Sum(x => Math.Abs(x.Net)) ?? 0m;

    async Task LoadReport(bool showWarning = true)
    {
        if (!HasTransactionSelection)
        {
            if (showWarning)
            {
                await AppSnackbar.Show("Select at least one transaction type before loading the report.",
                    SnackbarType.Warning);
            }
            return;
        }

        var request = new CustomerSalesReturnReportRequestDto
        {
            CustomerAccNo = string.IsNullOrWhiteSpace(CustomerAccNo) ? null : CustomerAccNo.Trim(),
            From = FromDate.Date,
            To = ToDate.Date.AddDays(1).AddTicks(-1),
            Locations = SelectedLocationCodes.ToList(),
            TransactionTypes = GetSelectedTransactionTypes()
        };

        var res = await ReportService.GetCustomerSalesReturnsAsync(request);

        if (!res.Success)
        {
            await AppSnackbar.Show(res.Message, SnackbarType.Error);
            return;
        }

        Lines = res.Data;
    }

    protected override async Task OnInitializedAsync()
    {
        Locations = await LocationService.GetAllAsync();
    }

    string LocationSummary =>
        SelectedLocationCodes.Count == 0
            ? "All Locations"
            : $"{SelectedLocationCodes.Count} selected";

    void ToggleLocationDropdown()
    {
        ShowLocationDropdown = !ShowLocationDropdown;
    }

    void ToggleAllLocations(ChangeEventArgs e)
    {
        SelectedLocationCodes.Clear();
    }

    void ToggleLocation(string code, ChangeEventArgs e)
    {
        var isChecked = e.Value is bool b && b;
        if (isChecked)
            SelectedLocationCodes.Add(code);
        else
            SelectedLocationCodes.Remove(code);
    }

    List<string> GetSelectedTransactionTypes()
    {
        var types = new List<string>();
        if (ShowSales)
            types.Add("O");
        if (ShowReturns)
            types.Add("R");
        return types;
    }

    async Task OnTransactionSelectionChanged()
    {
        await LoadReport(false);
    }

    async Task OnSalesToggle(ChangeEventArgs e)
    {
        ShowSales = e.Value is bool b && b;
        await OnTransactionSelectionChanged();
    }

    async Task OnReturnsToggle(ChangeEventArgs e)
    {
        ShowReturns = e.Value is bool b && b;
        await OnTransactionSelectionChanged();
    }

    async Task ExportCsv()
    {
        if (Lines == null || !Lines.Any())
            return;

        var cust = string.IsNullOrWhiteSpace(CustomerAccNo) ? "all-customers" : CustomerAccNo;
        var filename = $"customer-sales-returns-{cust}-{DateTime.Now:yyyyMMddHHmmss}.csv";
        var csv = BuildCsv(Lines);

        await JS.InvokeVoidAsync("reportExport.downloadCsv", filename, csv);
    }

    async Task ExportPdf()
    {
        if (Lines == null || !Lines.Any())
            return;

        var title = $"Customer Sales/Returns - {(string.IsNullOrWhiteSpace(CustomerAccNo) ? "All Customers" : CustomerAccNo)}";
        var html = BuildPrintHtml(title, Lines);

        await JS.InvokeVoidAsync("reportExport.printHtml", title, html);
    }

    static string BuildCsv(List<CustomerSalesReturnLineDto> lines)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("DateAndTime,Type,InvoiceNumber,PartNumber,Description,Manufacturer,Brand,StockNo,Qty,Sell,Net,Vat,Location,Terminal,Customer");

        foreach (var x in lines)
        {
            sb.AppendLine(string.Join(",",
                Csv(x.DateAndTime.ToString("yyyy-MM-dd HH:mm", CultureInfo.InvariantCulture)),
                Csv(x.InOut == "R" ? "Return" : "Sale"),
                Csv(x.InvoiceNumber),
                Csv(x.PartNumber),
                Csv(x.Description),
                Csv(x.Manufacturer),
                Csv(x.Brand),
                Csv(x.StockNo),
                Csv(x.Quantity.ToString(CultureInfo.InvariantCulture)),
                Csv(x.Sell.ToString(CultureInfo.InvariantCulture)),
                Csv(x.Net.ToString(CultureInfo.InvariantCulture)),
                Csv(x.Vat.ToString(CultureInfo.InvariantCulture)),
                Csv(x.Location),
                Csv(x.Terminal),
                Csv(x.Customer)
            ));
        }

        return sb.ToString();
    }

    static string Csv(string value)
    {
        if (value.Contains('"') || value.Contains(',') || value.Contains('\n') || value.Contains('\r'))
        {
            value = value.Replace("\"", "\"\"");
            return $"\"{value}\"";
        }

        return value;
    }

    string BuildPrintHtml(string title, List<CustomerSalesReturnLineDto> lines)
    {
        var sb = new System.Text.StringBuilder();
        sb.Append("<html><head><meta charset=\"utf-8\" />");
        sb.Append("<style>");
        sb.Append("body{font-family:Arial, sans-serif;font-size:12px;padding:16px;}");
        sb.Append("h2{margin:0 0 8px 0;}table{width:100%;border-collapse:collapse;}");
        sb.Append("th,td{border:1px solid #ddd;padding:6px;}th{background:#f2f2f2;}");
        sb.Append(".totals{margin-top:12px;display:flex;gap:24px;justify-content:flex-end;}");
        sb.Append("</style></head><body>");
        sb.Append($"<h2>{WebUtility.HtmlEncode(title)}</h2>");
        sb.Append("<div>");
        sb.Append($"Customer: {WebUtility.HtmlEncode(string.IsNullOrWhiteSpace(CustomerAccNo) ? "All Customers" : CustomerAccNo)}<br/>");
        sb.Append($"From: {FromDate:yyyy-MM-dd} &nbsp;&nbsp; To: {ToDate:yyyy-MM-dd}");
        if (SelectedLocationCodes.Count > 0)
            sb.Append($" &nbsp;&nbsp; Locations: {WebUtility.HtmlEncode(string.Join(", ", SelectedLocationCodes))}");
        sb.Append("</div><br/>");

        sb.Append("<table><thead><tr>");
        sb.Append("<th>Date/Time</th><th>Type</th><th>Invoice</th><th>Part</th><th>Description</th><th>Manufacturer</th><th>Brand</th><th>StockNo</th>");
        sb.Append("<th>Qty</th><th>Sell</th><th>Net</th><th>Location</th><th>Terminal</th>");
        sb.Append("</tr></thead><tbody>");

        foreach (var x in lines)
        {
            sb.Append("<tr>");
            sb.Append($"<td>{x.DateAndTime:yyyy-MM-dd HH:mm}</td>");
            sb.Append($"<td>{(x.InOut == "R" ? "Return" : "Sale")}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(x.InvoiceNumber)}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(x.PartNumber)}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(x.Description)}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(x.Manufacturer)}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(x.Brand)}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(x.StockNo)}</td>");
            sb.Append($"<td>{x.Quantity}</td>");
            sb.Append($"<td>{x.Sell:0.00}</td>");
            sb.Append($"<td>{x.Net:0.00}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(x.Location)}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(x.Terminal)}</td>");
            sb.Append("</tr>");
        }

        sb.Append("</tbody></table>");
        sb.Append("<div class=\"totals\">");
        sb.Append($"<div>Total Sales: <b>{TotalSales:0.00}</b></div>");
        sb.Append($"<div>Total Returns: <b>{TotalReturns:0.00}</b></div>");
        sb.Append("</div>");
        sb.Append("</body></html>");

        return sb.ToString();
    }
}

