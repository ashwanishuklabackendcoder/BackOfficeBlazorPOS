@page "/location"
@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@inject ILocationService LocationService
@inject IJSRuntime JS

<div class="position-relative" @ref="root">
    <div class="form-control d-flex justify-content-between align-items-center"
         style="cursor:pointer"
         @onclick="Toggle">
        <span class="text-truncate">@(string.IsNullOrEmpty(Display) ? " " : Display)</span>
        <span class="d-inline-flex align-items-center gap-2 ms-2">
            @if (!string.IsNullOrWhiteSpace(Value))
            {
                <button type="button"
                        title="Clear"
                        aria-label="Clear selection"
                        style="width:18px; height:18px; border:none; border-radius:50%; background:#dc3545; color:#ffffff; display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; line-height:1; padding:0;"
                        @onclick="ClearSelection"
                        @onclick:stopPropagation="true">
                    ×
                </button>
            }
            <i class="bi bi-chevron-down"></i>
        </span>
    </div>

    @if (open)
    {
        <div class="border bg-white shadow p-2"
             style="position:absolute; top:100%; left:0; z-index:1055; width:clamp(300px, 150%, 560px); max-width:calc(100vw - 1rem); height:260px; min-height:230px; max-height:80vh; display:flex; flex-direction:column; resize:both; overflow:hidden;">

            <div class="p-2 border-bottom">
                <input class="form-control"
                       placeholder="Search..."
                       @bind="search"
                       @bind:event="oninput" />
            </div>

            <div style="flex:1 1 auto; min-height:80px; overflow:auto">
                @foreach (var l in Filtered)
                {
                    <button class="list-group-item list-group-item-action"
                            @onclick="() => Select(l)">
                        @l.Code - @(string.IsNullOrEmpty(l.Name) ? "NA" : l.Name)
                    </button>
                }
            </div>

            <div class="border-top p-2 bg-light">
                <button type="button"
                        class="btn text-primary p-0"
                        @onclick="OpenManage"
                        @onclick:stopPropagation="true">
                    <i class="bi bi-gear me-1"></i>Manage
                </button>
            </div>
        </div>
    }
</div>

@if (showManage)
{
    <div class="modal fade show d-block"
         style="background:rgba(0,0,0,.5); position:fixed; inset:0; z-index:3000; overflow:auto;">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Manage Locations</h5>
                    <button class="btn-close" @onclick="CloseManage"></button>
                </div>

                <div class="modal-body">
                    <LocationEditor OnSaved="OnLocationSaved"
                                    OnCancel="CloseManage" />
                </div>

            </div>
        </div>
    </div>
}

@code {

    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    List<LocationDto> locations = new();
    bool open, showManage;
    string search = "";
    string Display = "";

    ElementReference root;
    IJSObjectReference? module;
    IJSObjectReference? outsideHandler;
    DotNetObjectReference<LocationSelector>? dotNetRef;

    protected override async Task OnInitializedAsync()
    {
        locations = await LocationService.GetAllAsync();
        SyncDisplay();
    }

    protected override void OnParametersSet()
    {
        SyncDisplay();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);

            module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./clickOutside.js");

            outsideHandler = await JS.InvokeAsync<IJSObjectReference>(
                "registerClickOutside", root, dotNetRef);
        }
    }

    [JSInvokable]
    public void OnClickOutside()
    {
        if (open)
        {
            open = false;
            InvokeAsync(StateHasChanged);
        }
    }

    IEnumerable<LocationDto> Filtered =>
        string.IsNullOrEmpty(search)
            ? locations
            : locations.Where(x =>
                x.Name.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                x.Code.Contains(search, StringComparison.OrdinalIgnoreCase));

    void Toggle() => open = !open;

    async Task Select(LocationDto l)
    {
        Value = l.Code;
        Display = FormatDisplay(l);
        await ValueChanged.InvokeAsync(Value);
        open = false;
    }

    async Task ClearSelection()
    {
        Value = "";
        Display = "";
        search = "";
        await ValueChanged.InvokeAsync(Value);
        open = false;
    }

    void OpenManage()
    {
        open = false;
        showManage = true;
    }

    async Task OnLocationSaved(LocationDto l)
    {
        locations = await LocationService.GetAllAsync();
        await Select(l);
        showManage = false;
    }

    void CloseManage() => showManage = false;

    void SyncDisplay()
    {
        if (string.IsNullOrWhiteSpace(Value))
        {
            Display = "";
            return;
        }

        var match = locations.FirstOrDefault(x =>
            string.Equals(x.Code, Value, StringComparison.OrdinalIgnoreCase));

        Display = match == null ? Value ?? "" : FormatDisplay(match);
    }

    static string FormatDisplay(LocationDto location)
    {
        return string.IsNullOrWhiteSpace(location.Name) ? "NA" : location.Name;
    }

    public async ValueTask DisposeAsync()
    {
        if (outsideHandler != null)
            await outsideHandler.InvokeVoidAsync("dispose");

        dotNetRef?.Dispose();
    }
}
