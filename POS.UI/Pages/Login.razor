@page "/login"
@layout EmptyLayout
@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject AppSnackbarService AppSnackbar

<PageTitle>Login</PageTitle>

<div class="container mt-5" style="max-width:420px;">
    <div class="card shadow-sm">
        <div class="card-header fw-bold">Staff Login</div>
        <div class="card-body">
            <div class="mb-3">
                <label class="form-label">Username</label>
                <input class="form-control" @bind="Username" />
            </div>
            <div class="mb-3">
                <label class="form-label">Password</label>
                <input class="form-control" type="password" @bind="Password" />
            </div>
            <button class="btn btn-primary w-100" @onclick="DoLogin">Login</button>
        </div>
    </div>
</div>

@code {
    string Username = "";
    string Password = "";

    protected override void OnInitialized()
    {
        if (AuthService.IsAuthenticated)
        {
            Nav.NavigateTo("/", true);
        }
    }

    async Task DoLogin()
    {
        var result = await AuthService.LoginAsync(new LoginRequestDto
        {
            Username = Username,
            Password = Password
        });

        if (!result.Success)
        {
            AppSnackbar.Show(result.Message ?? "Login failed", SnackbarType.Error);
            return;
        }

        Nav.NavigateTo("/", true);
    }
}
