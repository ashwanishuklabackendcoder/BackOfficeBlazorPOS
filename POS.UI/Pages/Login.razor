@page "/login"
@layout EmptyLayout
@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@inject IAuthService AuthService
@inject NavigationManager Nav
@inject AppSnackbarService AppSnackbar

<PageTitle>Login</PageTitle>

<div class="container mt-5" style="max-width:420px;">
    <div class="card shadow-sm">
        <div class="card-header fw-bold">Staff Login</div>
        <div class="card-body">
            <EditForm Model="this" OnValidSubmit="DoLogin">
                <div class="mb-3">
                    <label class="form-label">Username</label>
                    <input class="form-control"
                           @bind="Username"
                           @bind:event="oninput"
                           @onkeydown="HandleKeyDown" />
                </div>
                <div class="mb-3">
                    <label class="form-label">Password</label>
                    <input class="form-control"
                           type="password"
                           @bind="Password"
                           @bind:event="oninput"
                           @onkeydown="HandleKeyDown" />
                </div>
                <button class="btn btn-primary w-100" type="submit" disabled="@IsLoggingIn">
                    @(IsLoggingIn ? "Logging in..." : "Login")
                </button>
            </EditForm>
        </div>
    </div>
</div>

@code {
    string Username = "";
    string Password = "";
    bool IsLoggingIn;

    protected override void OnInitialized()
    {
        if (AuthService.IsAuthenticated)
        {
            Nav.NavigateTo("/dashboard", true);
        }
    }

    async Task HandleKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
            await DoLogin();
    }

    async Task DoLogin()
    {
        if (IsLoggingIn)
            return;

        if (string.IsNullOrWhiteSpace(Username))
        {
            await AppSnackbar.Show("Username is required", SnackbarType.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(Password))
        {
            await AppSnackbar.Show("Password is required", SnackbarType.Warning);
            return;
        }

        IsLoggingIn = true;

        try
        {
            var result = await AuthService.LoginAsync(new LoginRequestDto
            {
                Username = Username.Trim(),
                Password = Password
            });

            if (!result.Success)
            {
                await AppSnackbar.Show(result.Message ?? "Invalid username or password", SnackbarType.Error);
                return;
            }

            await AppSnackbar.Show("Login successful", SnackbarType.Success);
            Nav.NavigateTo("/dashboard", true);
        }
        catch
        {
            await AppSnackbar.Show("Unable to complete login. Please try again.", SnackbarType.Error);
        }
        finally
        {
            IsLoggingIn = false;
        }
    }
}
