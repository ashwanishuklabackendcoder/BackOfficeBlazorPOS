@page "/overstock-report"

@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@using System.Globalization
@using System.Net
@using POS.UI.Shared

@inject IReportService ReportService
@inject AppSnackbarService AppSnackbar
@inject IJSRuntime JS
@inject ILocationService LocationService
@inject ICompanyBrandingService CompanyBrandingService

@implements IAsyncDisposable

<PageTitle>Overstock Report</PageTitle>

<FormGlassLayout Title="Overstock / Understock Analysis"
                 Subtitle="Live stock position analysis for locations 01-03"
                 Id="overstock-report-form"
                 ScopeId="overstock-report-form"
                 class="overstock-report-shell"
                 BodyClass="card-body form-shell-body p-3 p-lg-4 overstock-report-body"
                 HeaderActions="@HeaderActions">
    <ChildContent>
        <div class="glass-panel border rounded-3 px-3 py-3 mb-3 overstock-filter-panel">
            <div class="row g-3 align-items-end">
                <div class="col-md-3 col-lg-2">
                    <label class="form-label-custom">From Location</label>
                    <LocationSelector Value="@FromLocation"
                                      ValueChanged="OnFromLocationChanged" />
                </div>

                <div class="col-md-3 col-lg-2">
                    <label class="form-label-custom">To Location</label>
                    <LocationSelector Value="@ToLocation"
                                      ValueChanged="OnToLocationChanged" />
                </div>

                <div class="col-md-2 col-lg-2">
                    <label class="form-label-custom">From Year</label>
                    <input class="form-control"
                           type="text"
                           inputmode="numeric"
                           placeholder="From year"
                           value="@FromYearText"
                           @oninput="OnFromYearInput" />
                </div>

                <div class="col-md-2 col-lg-2">
                    <label class="form-label-custom">To Year</label>
                    <input class="form-control"
                           type="text"
                           inputmode="numeric"
                           placeholder="To year"
                           value="@ToYearText"
                           @oninput="OnToYearInput" />
                </div>

                <div class="col-md-2 col-lg-2">
                    <label class="form-label-custom">Print</label>
                    <select class="form-select"
                            value="@PrintMode"
                            @onchange="OnPrintModeChanged">
                        <option value="Both">Both</option>
                        <option value="Major">Major</option>
                        <option value="Minor">Minor</option>
                    </select>
                </div>

                <div class="col-md-3 col-lg-2">
                    <label class="form-label-custom">Position</label>
                    <div class="d-flex flex-wrap gap-2">
                        <button type="button"
                                class="@GetPositionButtonClass(OverstockOnly)"
                                @onclick="ToggleOverstockOnly">
                            Overstock
                        </button>
                        <button type="button"
                                class="@GetPositionButtonClass(UnderstockOnly)"
                                @onclick="ToggleUnderstockOnly">
                            Understock
                        </button>
                    </div>
                </div>
            </div>

            <div class="row g-3 mt-2">
                <div class="col-md-3">
                    <label class="form-label-custom">Category A</label>
                    <CategorySelector Level="A"
                                      Code="@CategoryACode"
                                      CodeChanged="OnCategoryACodeChanged"
                                      Name="@CategoryAName"
                                      NameChanged="OnCategoryANameChanged" />
                </div>

                <div class="col-md-3">
                    <label class="form-label-custom">Category B</label>
                    <CategorySelector Level="B"
                                      Code="@CategoryBCode"
                                      CodeChanged="OnCategoryBCodeChanged"
                                      Name="@CategoryBName"
                                      NameChanged="OnCategoryBNameChanged" />
                </div>

                <div class="col-md-3">
                    <label class="form-label-custom">Category C</label>
                    <CategorySelector Level="C"
                                      Code="@CategoryCCode"
                                      CodeChanged="OnCategoryCCodeChanged"
                                      Name="@CategoryCName"
                                      NameChanged="OnCategoryCNameChanged" />
                </div>

                <div class="col-md-3">
                    <label class="form-label-custom">Supplier</label>
                    <SupplierSelector Value="@Supplier"
                                      ValueChanged="OnSupplierChanged" />
                </div>
            </div>

            <div class="row g-3 mt-2 align-items-center">
                <div class="col-lg-5">
                    <div class="d-flex flex-wrap gap-3 checkbox-stack">
                        <div class="form-check form-switch">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="currentOnly"
                                   checked="@CurrentOnly"
                                   @onchange="OnCurrentOnlyChanged" />
                            <label class="form-check-label" for="currentOnly">Current only</label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="overstockOnly"
                                   checked="@OverstockOnly"
                                   @onchange="OnOverstockOnlyChanged" />
                            <label class="form-check-label" for="overstockOnly">Overstock only</label>
                        </div>
                        <div class="form-check form-switch">
                            <input class="form-check-input"
                                   type="checkbox"
                                   id="understockOnly"
                                   checked="@UnderstockOnly"
                                   @onchange="OnUnderstockOnlyChanged" />
                            <label class="form-check-label" for="understockOnly">Understock only</label>
                        </div>
                    </div>
                </div>

                <div class="col-lg-7 d-flex justify-content-lg-end gap-2 flex-wrap">
                    <button type="button"
                            class="btn btn-outline-secondary"
                            disabled="@(!HasRows || IsLoading)"
                            @onclick="ExportCsv">
                        Export CSV
                    </button>
                    <button type="button"
                            class="btn btn-outline-secondary"
                            disabled="@(!HasRows || IsLoading)"
                            @onclick="ExportPdf">
                        Export PDF
                    </button>
                </div>
            </div>
        </div>

        <div class="glass-panel border rounded-3 overflow-hidden overstock-table-panel">
            <div class="table-responsive overstock-table-wrap">
                <table class="table table-sm table-bordered align-middle mb-0 stock-table">
                    <thead class="table-light">
                        <tr>
                            <th>Part No</th>
                            <th>CAT A</th>
                            <th>CAT B</th>
                            <th>CAT C</th>
                            <th>Make</th>
                            <th>Size</th>
                            <th>Color</th>
                            <th class="text-end">RRP</th>
                            <th class="text-end">Promo</th>
                            <th>Location</th>
                            <th class="text-end">MIN</th>
                            <th class="text-end">MAX</th>
                            <th class="text-end">Stock</th>
                            <th class="text-end">Stock Diff.</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (IsLoading && Rows == null)
                        {
                            <tr>
                                <td colspan="14" class="text-muted py-4 text-center">
                                    Loading stock position analysis...
                                </td>
                            </tr>
                        }
                        else if (Rows == null)
                        {
                            <tr>
                                <td colspan="14" class="text-muted py-4 text-center">
                                    Change a filter to load the report.
                                </td>
                            </tr>
                        }
                        else if (Rows.Count == 0)
                        {
                            <tr>
                                <td colspan="14" class="text-muted py-4 text-center">
                                    No records match the selected filters.
                                </td>
                            </tr>
                        }
                        else
                        {
                            @foreach (var row in Rows)
                            {
                                <tr class="@GetRowClass(row)">
                                    <td>@row.PartNo</td>
                                    <td>@row.CategoryA</td>
                                    <td>@row.CategoryB</td>
                                    <td>@row.CategoryC</td>
                                    <td>@row.Make</td>
                                    <td>@row.Size</td>
                                    <td>@row.Color</td>
                                    <td class="text-end">@row.RRP.ToString("0.00", CultureInfo.InvariantCulture)</td>
                                    <td class="text-end">@row.Promo.ToString("0.00", CultureInfo.InvariantCulture)</td>
                                    <td>@GetLocationDisplay(row.Location)</td>
                                    <td class="text-end">@row.MIN</td>
                                    <td class="text-end">@row.MAX</td>
                                    <td class="text-end">@row.Stock</td>
                                    <td class="text-end fw-semibold">@row.StockDifference</td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </ChildContent>
</FormGlassLayout>

@code {

    private List<StockPositionLineDto>? Rows;
    private bool IsLoading;
    private int _requestVersion;
    private CancellationTokenSource? _reloadCts;
    private bool _disposed;
    private CompanyBrandingDto? _branding;
    private IReadOnlyDictionary<string, LocationDto> _locationLookup = new Dictionary<string, LocationDto>(StringComparer.OrdinalIgnoreCase);

    private string? FromLocation { get; set; }
    private string? ToLocation { get; set; }
    private string? FromYearText { get; set; }
    private string? ToYearText { get; set; }
    private string PrintMode { get; set; } = "Both";
    private string? CategoryACode { get; set; }
    private string? CategoryAName { get; set; }
    private string? CategoryBCode { get; set; }
    private string? CategoryBName { get; set; }
    private string? CategoryCCode { get; set; }
    private string? CategoryCName { get; set; }
    private string? Supplier { get; set; }
    private bool CurrentOnly { get; set; }
    private bool OverstockOnly { get; set; }
    private bool UnderstockOnly { get; set; }

    private bool HasRows => Rows is { Count: > 0 };

    protected override async Task OnInitializedAsync()
    {
        FromLocation = "01";
        ToLocation = "01";
        await LoadLocationLookupAsync();
        _branding = await CompanyBrandingService.GetAsync();
        await LoadReportAsync(showWarning: true);
    }

    private RenderFragment HeaderActions => builder =>
    {
        var seq = 0;
        builder.OpenElement(seq++, "div");
        builder.AddAttribute(seq++, "class", "d-flex align-items-center gap-2 flex-wrap justify-content-end");

        builder.OpenElement(seq++, "span");
        builder.AddAttribute(seq++, "class", "form-shell-meta");
        builder.AddContent(seq++, IsLoading ? "Refreshing..." : HasRows ? $"{Rows!.Count} rows" : "Ready");
        builder.CloseElement();

        builder.OpenElement(seq++, "button");
        builder.AddAttribute(seq++, "type", "button");
        builder.AddAttribute(seq++, "class", "btn btn-outline-secondary btn-sm");
        builder.AddAttribute(seq++, "disabled", IsLoading);
        builder.AddAttribute(seq++, "onclick", EventCallback.Factory.Create(this, RefreshNow));
        builder.AddContent(seq++, "Refresh");
        builder.CloseElement();

        builder.CloseElement();
    };

    private async Task RefreshNow()
        => await LoadReportAsync(showWarning: true);

    private async Task QueueReloadAsync()
    {
        if (_disposed)
            return;

        _reloadCts?.Cancel();
        _reloadCts?.Dispose();
        _reloadCts = new CancellationTokenSource();

        var token = _reloadCts.Token;

        try
        {
            await Task.Delay(250, token);
            await LoadReportAsync(showWarning: false);
        }
        catch (TaskCanceledException)
        {
        }
    }

    private async Task LoadReportAsync(bool showWarning)
    {
        var requestVersion = Interlocked.Increment(ref _requestVersion);
        IsLoading = true;
        await InvokeAsync(StateHasChanged);

        try
        {
            var request = new StockPositionReportRequestDto
            {
                FromLocation = NormalizeLocation(FromLocation),
                ToLocation = NormalizeLocation(ToLocation),
                FromYear = ParseYear(FromYearText),
                ToYear = ParseYear(ToYearText),
                CurrentOnly = CurrentOnly,
                PrintMode = string.IsNullOrWhiteSpace(PrintMode) ? "Both" : PrintMode,
                OverstockOnly = OverstockOnly,
                UnderstockOnly = UnderstockOnly,
                CategoryA = string.IsNullOrWhiteSpace(CategoryACode) ? null : CategoryACode.Trim(),
                CategoryB = string.IsNullOrWhiteSpace(CategoryBCode) ? null : CategoryBCode.Trim(),
                CategoryC = string.IsNullOrWhiteSpace(CategoryCCode) ? null : CategoryCCode.Trim(),
                Supplier = string.IsNullOrWhiteSpace(Supplier) ? null : Supplier.Trim()
            };

            var res = await ReportService.GetStockPositionAsync(request);

            if (requestVersion != _requestVersion)
                return;

            if (!res.Success)
            {
                if (showWarning)
                    await AppSnackbar.Show(res.Message ?? "Unable to load report.", SnackbarType.Error);

                Rows = new();
                return;
            }

            Rows = res.Data ?? new();
        }
        catch (Exception ex) when (!(_disposed || ex is TaskCanceledException))
        {
            if (requestVersion == _requestVersion && showWarning)
                await AppSnackbar.Show("Unable to load report.", SnackbarType.Error);

            if (requestVersion == _requestVersion)
                Rows = new();
        }
        finally
        {
            if (requestVersion == _requestVersion)
            {
                IsLoading = false;
                await InvokeAsync(StateHasChanged);
            }
        }
    }

    private static string? NormalizeLocation(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        var trimmed = value.Trim();
        return int.TryParse(trimmed, NumberStyles.Integer, CultureInfo.InvariantCulture, out var slot)
            ? slot.ToString("D2", CultureInfo.InvariantCulture)
            : trimmed.ToUpperInvariant();
    }

    private async Task LoadLocationLookupAsync()
    {
        try
        {
            var locations = await LocationService.GetAllAsync();
            _locationLookup = locations
                .Where(x => !string.IsNullOrWhiteSpace(x.Code))
                .GroupBy(x => DisplayLabelFormatter.NormalizeLocationCode(x.Code), StringComparer.OrdinalIgnoreCase)
                .ToDictionary(g => g.Key, g => g.First(), StringComparer.OrdinalIgnoreCase);
        }
        catch
        {
            _locationLookup = new Dictionary<string, LocationDto>(StringComparer.OrdinalIgnoreCase);
        }
    }

    private string GetLocationDisplay(string? code)
        => DisplayLabelFormatter.FormatLocation(code, _locationLookup);

    private static int? ParseYear(string? value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return null;

        return int.TryParse(value.Trim(), NumberStyles.Integer, CultureInfo.InvariantCulture, out var year)
            ? year
            : null;
    }

    private async Task OnFromLocationChanged(string? value)
    {
        FromLocation = value;
        await QueueReloadAsync();
    }

    private async Task OnToLocationChanged(string? value)
    {
        ToLocation = value;
        await QueueReloadAsync();
    }

    private async Task OnFromYearInput(ChangeEventArgs e)
    {
        FromYearText = e.Value?.ToString();
        await QueueReloadAsync();
    }

    private async Task OnToYearInput(ChangeEventArgs e)
    {
        ToYearText = e.Value?.ToString();
        await QueueReloadAsync();
    }

    private async Task OnPrintModeChanged(ChangeEventArgs e)
    {
        PrintMode = e.Value?.ToString() ?? "Both";
        await QueueReloadAsync();
    }

    private async Task OnCategoryACodeChanged(string? value)
    {
        CategoryACode = value;
        await QueueReloadAsync();
    }

    private async Task OnCategoryANameChanged(string? value)
    {
        CategoryAName = value;
        await QueueReloadAsync();
    }

    private async Task OnCategoryBCodeChanged(string? value)
    {
        CategoryBCode = value;
        await QueueReloadAsync();
    }

    private async Task OnCategoryBNameChanged(string? value)
    {
        CategoryBName = value;
        await QueueReloadAsync();
    }

    private async Task OnCategoryCCodeChanged(string? value)
    {
        CategoryCCode = value;
        await QueueReloadAsync();
    }

    private async Task OnCategoryCNameChanged(string? value)
    {
        CategoryCName = value;
        await QueueReloadAsync();
    }

    private async Task OnSupplierChanged(string? value)
    {
        Supplier = value;
        await QueueReloadAsync();
    }

    private async Task OnCurrentOnlyChanged(ChangeEventArgs e)
    {
        CurrentOnly = ToBool(e.Value);
        await QueueReloadAsync();
    }

    private async Task OnOverstockOnlyChanged(ChangeEventArgs e)
    {
        OverstockOnly = ToBool(e.Value);

        if (OverstockOnly && UnderstockOnly)
            UnderstockOnly = false;

        await QueueReloadAsync();
    }

    private async Task OnUnderstockOnlyChanged(ChangeEventArgs e)
    {
        UnderstockOnly = ToBool(e.Value);

        if (UnderstockOnly && OverstockOnly)
            OverstockOnly = false;

        await QueueReloadAsync();
    }

    private async Task ToggleOverstockOnly()
    {
        OverstockOnly = !OverstockOnly;

        if (OverstockOnly && UnderstockOnly)
            UnderstockOnly = false;

        await QueueReloadAsync();
    }

    private async Task ToggleUnderstockOnly()
    {
        UnderstockOnly = !UnderstockOnly;

        if (UnderstockOnly && OverstockOnly)
            OverstockOnly = false;

        await QueueReloadAsync();
    }

    private async Task ExportCsv()
    {
        if (!HasRows)
            return;

        var filename = $"overstock-report-{DateTime.Now:yyyyMMddHHmmss}.csv";
        var csv = BuildCsv(Rows ?? new());
        await JS.InvokeVoidAsync("reportExport.downloadCsv", filename, csv);
    }

    private async Task ExportPdf()
    {
        if (!HasRows)
            return;

        var title = "Overstock Report";
        _branding = await CompanyBrandingService.GetAsync();
        var html = BuildPrintHtml(title, Rows ?? new());
        await JS.InvokeVoidAsync("reportExport.printHtml", title, html);
    }

    private static string BuildCsv(List<StockPositionLineDto> rows)
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("Part No,CAT A,CAT B,CAT C,Make,Size,Color,RRP,Promo,Location,MIN,MAX,Stock,Stock Diff.");

        foreach (var row in rows)
        {
            sb.AppendLine(string.Join(",",
                Csv(row.PartNo),
                Csv(row.CategoryA),
                Csv(row.CategoryB),
                Csv(row.CategoryC),
                Csv(row.Make),
                Csv(row.Size),
                Csv(row.Color),
                Csv(row.RRP.ToString(CultureInfo.InvariantCulture)),
                Csv(row.Promo.ToString(CultureInfo.InvariantCulture)),
                Csv(row.Location),
                Csv(row.MIN.ToString(CultureInfo.InvariantCulture)),
                Csv(row.MAX.ToString(CultureInfo.InvariantCulture)),
                Csv(row.Stock.ToString(CultureInfo.InvariantCulture)),
                Csv(row.StockDifference.ToString(CultureInfo.InvariantCulture))
            ));
        }

        return sb.ToString();
    }

    private static string Csv(string? value)
    {
        value ??= string.Empty;

        if (value.Contains('"') || value.Contains(',') || value.Contains('\n') || value.Contains('\r'))
        {
            value = value.Replace("\"", "\"\"");
            return $"\"{value}\"";
        }

        return value;
    }

    private string BuildPrintHtml(string title, List<StockPositionLineDto> rows)
    {
        var sb = new System.Text.StringBuilder();
        var locationFrom = WebUtility.HtmlEncode(GetLocationDisplay(FromLocation));
        var locationTo = WebUtility.HtmlEncode(GetLocationDisplay(ToLocation));
        var yearFrom = FromYearText?.Trim();
        var yearTo = ToYearText?.Trim();
        var yearRange = string.IsNullOrWhiteSpace(yearFrom) && string.IsNullOrWhiteSpace(yearTo)
            ? "All"
            : $"{(string.IsNullOrWhiteSpace(yearFrom) ? "All" : yearFrom)} to {(string.IsNullOrWhiteSpace(yearTo) ? "All" : yearTo)}";
        var print = WebUtility.HtmlEncode(PrintMode);
        var categoryA = WebUtility.HtmlEncode(CategoryAName ?? CategoryACode ?? "All");
        var categoryB = WebUtility.HtmlEncode(CategoryBName ?? CategoryBCode ?? "All");
        var categoryC = WebUtility.HtmlEncode(CategoryCName ?? CategoryCCode ?? "All");
        var supplier = WebUtility.HtmlEncode(Supplier ?? "All");
        var positionLabel = OverstockOnly && UnderstockOnly
            ? "Overstock + Understock"
            : OverstockOnly
                ? "Overstock only"
                : UnderstockOnly
                    ? "Understock only"
                    : "All rows";

        sb.Append(PrintTheme.BuildDocumentStart(title, true, "table{width:100%;border-collapse:collapse;table-layout:auto;}th,td{border:1px solid #cfcfcf;padding:2px 3px;vertical-align:top;font-size:7px;white-space:nowrap;}th{background:#f3f3f3;font-weight:bold;}.num{text-align:right;}.over{background:#fdecec;}.under{background:#fff4db;}.neutral{background:#fff;}th:nth-child(1),td:nth-child(1){width:6%;}th:nth-child(2),td:nth-child(2){width:7%;}th:nth-child(3),td:nth-child(3){width:7%;}th:nth-child(4),td:nth-child(4){width:9%;}th:nth-child(5),td:nth-child(5){width:8%;}th:nth-child(6),td:nth-child(6){width:5%;}th:nth-child(7),td:nth-child(7){width:6%;}th:nth-child(8),td:nth-child(8){width:6%;}th:nth-child(9),td:nth-child(9){width:6%;}th:nth-child(10),td:nth-child(10){width:6%;}th:nth-child(11),td:nth-child(11){width:5%;}th:nth-child(12),td:nth-child(12){width:5%;}th:nth-child(13),td:nth-child(13){width:6%;}th:nth-child(14),td:nth-child(14){width:6%;}td:nth-child(2),td:nth-child(3),td:nth-child(4){white-space:normal;}"));
        sb.Append("<div class=\"page\">");
        sb.Append(PrintTheme.BuildHeader(title, _branding, "Stock position analysis"));
        sb.Append("<div class=\"meta section\">");
        sb.Append($"Locations: {locationFrom} to {locationTo}<br/>");
        sb.Append($"Year: {WebUtility.HtmlEncode(yearRange)} | Current only: {(CurrentOnly ? "Yes" : "No")}<br/>");
        sb.Append($"Print: {print} | Categories: A={categoryA}, B={categoryB}, C={categoryC} | Supplier: {supplier}<br/>");
        sb.Append($"Position: {positionLabel}");
        sb.Append("</div>");
        sb.Append("<table><thead><tr>");
        sb.Append("<th>Part No</th><th>CAT A</th><th>CAT B</th><th>CAT C</th><th>Make</th><th>Size</th><th>Color</th>");
        sb.Append("<th class=\"num\">RRP</th><th class=\"num\">Promo</th><th>Location</th><th class=\"num\">MIN</th><th class=\"num\">MAX</th><th class=\"num\">Stock</th><th class=\"num\">Stock Diff.</th>");
        sb.Append("</tr></thead><tbody>");

        foreach (var row in rows)
        {
            var css = row.StockDifference > 0 ? "over" : row.StockDifference < 0 ? "under" : "neutral";
            sb.Append($"<tr class=\"{css}\">");
            sb.Append($"<td>{WebUtility.HtmlEncode(row.PartNo)}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(row.CategoryA)}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(row.CategoryB)}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(row.CategoryC)}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(row.Make)}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(row.Size)}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(row.Color)}</td>");
            sb.Append($"<td class=\"num\">{row.RRP:0.00}</td>");
            sb.Append($"<td class=\"num\">{row.Promo:0.00}</td>");
            sb.Append($"<td>{WebUtility.HtmlEncode(GetLocationDisplay(row.Location))}</td>");
            sb.Append($"<td class=\"num\">{row.MIN}</td>");
            sb.Append($"<td class=\"num\">{row.MAX}</td>");
            sb.Append($"<td class=\"num\">{row.Stock}</td>");
            sb.Append($"<td class=\"num\">{row.StockDifference}</td>");
            sb.Append("</tr>");
        }

        sb.Append("</tbody></table></div>");
        sb.Append(PrintTheme.BuildDocumentEnd());
        return sb.ToString();
    }

    private static string GetRowClass(StockPositionLineDto row)
        => row.StockDifference > 0
            ? "table-danger"
            : row.StockDifference < 0
                ? "table-warning"
                : string.Empty;

    private static string GetPositionButtonClass(bool active)
        => active ? "btn btn-sm btn-primary position-button" : "btn btn-sm btn-outline-secondary position-button";

    private static bool ToBool(object? value)
        => value switch
        {
            bool b => b,
            string s when bool.TryParse(s, out var parsed) => parsed,
            _ => false
        };

    public async ValueTask DisposeAsync()
    {
        _disposed = true;
        _reloadCts?.Cancel();
        _reloadCts?.Dispose();
        await Task.CompletedTask;
    }
}
