@page "/pos-receipt/{InvoiceNo}"
@layout EmptyLayout
@using System.Net.Http.Json
@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@inject HttpClient Http
@inject IJSRuntime JS
@inject ICustomerService CustomerService
@inject ILocationService LocationService
@inject ICompanyBrandingService CompanyBrandingService
@inject ISysOptionsService SysOptionsService
@inject IAuthService AuthService

<style>
    :root {
        --invoice-page-width: 210mm;
        --invoice-font: 10px;
    }

    @@media print {
        @@page {
            size: A4;
            margin: 8mm;
        }

        html,
        body {
            margin: 0;
            padding: 0;
            color: #111;
            font-family: Arial, sans-serif;
            font-size: var(--invoice-font);
            background: white !important;
        }

        main,
        article.content {
            margin: 0 !important;
            padding: 0 !important;
            max-width: none !important;
        }

        .snackbar-container,
        .no-print {
            display: none !important;
        }

        .invoice-page {
            max-width: none;
            margin: 0;
            padding: 0;
        }
    }

    .invoice-page {
        max-width: var(--invoice-page-width);
        margin: 0 auto;
        padding: 12mm;
        box-sizing: border-box;
        color: #111;
        font-family: Arial, sans-serif;
        font-size: var(--invoice-font);
        line-height: 1.35;
    }

    .invoice-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 16px;
        padding-bottom: 12px;
        margin-bottom: 14px;
        border-bottom: 2px solid #d9e1ec;
    }

    .brand-block {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
    }

    .brand-logo {
        width: 54px;
        height: 54px;
        object-fit: contain;
        border-radius: 8px;
    }

    .brand-name {
        font-size: 18px;
        font-weight: 700;
        letter-spacing: 0.02em;
        line-height: 1.1;
    }

    .doc-block {
        flex: 1;
        text-align: center;
    }

    .doc-title {
        font-size: 18px;
        font-weight: 800;
        letter-spacing: 0.08em;
    }

    .doc-subtitle {
        font-size: 10px;
        color: #667085;
        margin-top: 2px;
    }

    .info-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 10px 16px;
        margin-bottom: 12px;
    }

    .info-card {
        border: 1px solid #e2e8f0;
        border-radius: 8px;
        background: #f9fbfd;
        padding: 10px 12px;
    }

    .info-label {
        color: #667085;
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.06em;
    }

    .info-value {
        margin-top: 2px;
        font-size: 11px;
        font-weight: 600;
    }

    .line-table {
        width: 100%;
        border-collapse: collapse;
        table-layout: fixed;
    }

    .line-table th,
    .line-table td {
        border: 1px solid #d5dbe5;
        padding: 6px 7px;
        vertical-align: top;
    }

    .line-table th {
        background: #f5f7fa;
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }

    .num {
        text-align: right;
        white-space: nowrap;
    }

    .item-code {
        font-weight: 600;
        white-space: pre-wrap;
    }

    .muted {
        color: #667085;
    }

    .small {
        font-size: 9px;
    }

    .totals {
        width: min(340px, 100%);
        margin-left: auto;
        margin-top: 14px;
        border: 1px solid #d5dbe5;
        border-radius: 8px;
        overflow: hidden;
    }

    .totals-row {
        display: flex;
        justify-content: space-between;
        gap: 8px;
        padding: 7px 10px;
        border-bottom: 1px solid #edf1f6;
    }

    .totals-row:last-child {
        border-bottom: 0;
    }

    .totals-row.total {
        background: #f5f7fa;
        font-weight: 700;
    }

    .footer-note {
        margin-top: 16px;
        padding-top: 10px;
        border-top: 1px solid #d9e1ec;
        text-align: center;
    }
</style>

<div class="invoice-page">
    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="muted">Error: @_error</div>
    }
    else if (_receipt == null)
    {
        <div class="muted">Loading invoice...</div>
    }
    else
    {
        <div class="invoice-header">
            <div class="brand-block">
                @if (!string.IsNullOrWhiteSpace(_branding?.CompanyLogoUrl))
                {
                    <img src="@_branding.CompanyLogoUrl" alt="Company logo" class="brand-logo" />
                }
                <div class="brand-name">@CompanyNameOrDefault</div>
            </div>
            <div class="doc-block">
                <div class="doc-title">INVOICE</div>
                <div class="doc-subtitle">Invoice @_receipt.InvoiceNumber</div>
            </div>
            <div style="width:54px;"></div>
        </div>

        <div class="info-grid">
            <div class="info-card">
                <div class="info-label">Invoice No</div>
                <div class="info-value">@_receipt.InvoiceNumber</div>
            </div>
            <div class="info-card">
                <div class="info-label">Date</div>
                <div class="info-value">@FormatDate(_receipt.ReceiptDateTime)</div>
            </div>
            <div class="info-card">
                <div class="info-label">Location</div>
                <div class="info-value">@LocationDisplay</div>
            </div>
            <div class="info-card">
                <div class="info-label">Terminal</div>
                <div class="info-value">@_receipt.Terminal</div>
            </div>
            <div class="info-card">
                <div class="info-label">Customer</div>
                <div class="info-value">@CustomerDisplay</div>
            </div>
            <div class="info-card">
                <div class="info-label">Sales Person</div>
                <div class="info-value">@(!string.IsNullOrWhiteSpace(_receipt.SalesPerson) ? _receipt.SalesPerson : "-")</div>
            </div>
        </div>

        <table class="line-table">
            <thead>
                <tr>
                    <th style="width:44%;">Item</th>
                    <th style="width:12%;" class="num">Qty</th>
                    <th style="width:22%;" class="num">Unit</th>
                    <th style="width:22%;" class="num">Line Total</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var line in _receipt.Lines)
                {
                    <tr>
                        <td>
                            <div class="item-code">@GetItemCode(line)</div>
                            @if (!string.IsNullOrWhiteSpace(line.Description))
                            {
                                <div class="muted small">@line.Description</div>
                            }
                            @if (line.IsCombo && line.ComboItems.Any())
                            {
                                <div class="muted small mt-1">
                                    @foreach (var child in line.ComboItems)
                                    {
                                        <div>@child.ProductName x @child.Qty</div>
                                        @if (child.IsMajor && child.StockNumbers.Any())
                                        {
                                            <div>Stock: @string.Join(", ", child.StockNumbers)</div>
                                        }
                                    }
                                </div>
                            }
                        </td>
                        <td class="num">@line.Quantity</td>
                        <td class="num">@line.Sell.ToString("0.00")</td>
                        <td class="num">@line.Net.ToString("0.00")</td>
                    </tr>
                }
            </tbody>
        </table>

        <div class="totals">
            <div class="totals-row">
                <span>SubTotal</span>
                <span>@_receipt.SubTotal.ToString("0.00")</span>
            </div>
            @if (TotalDiscount > 0)
            {
                <div class="totals-row">
                    <span>Discount</span>
                    <span>@TotalDiscount.ToString("0.00")</span>
                </div>
            }
            <div class="totals-row">
                <span>VAT</span>
                <span>@_receipt.VatAmount.ToString("0.00")</span>
            </div>
            <div class="totals-row total">
                <span>Net Total</span>
                <span>@_receipt.NetTotal.ToString("0.00")</span>
            </div>
            <div class="totals-row">
                <span>Total Paid</span>
                <span>@_receipt.Payment.TotalTendered.ToString("0.00")</span>
            </div>
            <div class="totals-row total">
                <span>Change</span>
                <span>@ChangeAmount.ToString("0.00")</span>
            </div>
        </div>

        <div class="footer-note">
            @if (!string.IsNullOrWhiteSpace(_sysOptions?.TillMsg))
            {
                <div>@_sysOptions.TillMsg</div>
            }
            <div class="mt-2 fw-semibold">THANK YOU</div>
            @if (!string.IsNullOrWhiteSpace(_sysOptions?.InvoiceMsg))
            {
                <div class="mt-1">@_sysOptions.InvoiceMsg</div>
            }
        </div>
    }
</div>

<button class="no-print btn btn-primary mt-3" @onclick="Print">
    Print
</button>

@code {
    [Parameter] public string InvoiceNo { get; set; } = "";

    private PosReceiptDto? _receipt;
    private string? _error;
    private bool _printed;
    private SysOptionsDto? _sysOptions;
    private CompanyBrandingDto? _branding;
    private string _customerDisplay = string.Empty;
    private string _locationDisplay = string.Empty;
    private IReadOnlyDictionary<string, LocationDto> _locationLookup = new Dictionary<string, LocationDto>(StringComparer.OrdinalIgnoreCase);

    protected override async Task OnParametersSetAsync()
    {
        _receipt = null;
        _error = null;
        _printed = false;
        _sysOptions = null;
        _branding = null;
        _customerDisplay = string.Empty;
        _locationDisplay = string.Empty;
        _locationLookup = new Dictionary<string, LocationDto>(StringComparer.OrdinalIgnoreCase);

        if (string.IsNullOrWhiteSpace(InvoiceNo))
        {
            _error = "Invoice number is missing.";
            return;
        }

        try
        {
            var result = await Http.GetFromJsonAsync<ApiResponse<PosReceiptDto>>(
                $"api/returns/receipt/{InvoiceNo}");

            if (result?.Success == true && result.Data != null)
                _receipt = result.Data;
            else
                _error = result?.Message ?? "Failed to load invoice.";
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }

        await LoadDisplayLabelsAsync();
        _branding = await CompanyBrandingService.GetAsync();
        await LoadSysOptionsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_receipt != null && !_printed && string.IsNullOrWhiteSpace(_error))
        {
            _printed = true;
            await Task.Delay(400);
            await JS.InvokeVoidAsync("window.print");
        }
    }

    private async Task LoadSysOptionsAsync()
    {
        if (AuthService.CurrentUser?.IsAdmin != true)
            return;

        var optResult = await SysOptionsService.GetAsync();
        if (optResult.Success && optResult.Data != null)
            _sysOptions = optResult.Data;
    }

    private string CompanyNameOrDefault
        => string.IsNullOrWhiteSpace(_branding?.CompanyName) ? "POS.UI" : _branding!.CompanyName;

    private string CustomerDisplay => string.IsNullOrWhiteSpace(_customerDisplay)
        ? (string.IsNullOrWhiteSpace(_receipt?.Customer) ? "-" : _receipt!.Customer)
        : _customerDisplay;

    private string LocationDisplay => string.IsNullOrWhiteSpace(_locationDisplay)
        ? (string.IsNullOrWhiteSpace(_receipt?.Location) ? "-" : _receipt!.Location)
        : _locationDisplay;

    private async Task LoadDisplayLabelsAsync()
    {
        if (_receipt == null)
            return;

        CustomerDto? customer = null;
        if (!string.IsNullOrWhiteSpace(_receipt.Customer))
        {
            try
            {
                var customerResult = await CustomerService.GetAsync(_receipt.Customer);
                if (customerResult.Success && customerResult.Data != null)
                    customer = customerResult.Data;
            }
            catch
            {
            }
        }

        try
        {
            var locations = await LocationService.GetAllAsync();
            _locationLookup = locations
                .Where(x => !string.IsNullOrWhiteSpace(x.Code))
                .GroupBy(x => DisplayLabelFormatter.NormalizeLocationCode(x.Code), StringComparer.OrdinalIgnoreCase)
                .ToDictionary(g => g.Key, g => g.First(), StringComparer.OrdinalIgnoreCase);
        }
        catch
        {
            _locationLookup = new Dictionary<string, LocationDto>(StringComparer.OrdinalIgnoreCase);
        }

        _customerDisplay = DisplayLabelFormatter.FormatCustomer(customer, _receipt.Customer);
        _locationDisplay = DisplayLabelFormatter.FormatLocation(_receipt.Location, _locationLookup);
    }

    private string GetItemCode(PosSaleLineDto line)
    {
        var code = string.IsNullOrWhiteSpace(line.PartNumber) ? line.StockNo : line.PartNumber;
        if (line.IsCombo)
            return code;

        if (_sysOptions?.MakeOnInvice == true && !string.IsNullOrWhiteSpace(line.Make))
            return $"{line.Make} {code}";

        return code;
    }

    private static string FormatDate(DateTime? dt)
        => dt.HasValue ? dt.Value.ToString("yyyy-MM-dd HH:mm:ss") : "";

    private decimal ChangeAmount
        => _receipt == null
            ? 0m
            : (_receipt.Payment.Cash > _receipt.NetTotal
                ? _receipt.Payment.Cash - _receipt.NetTotal
                : 0m);

    private decimal TotalDiscount
        => _receipt == null
            ? 0m
            : _receipt.Lines.Sum(x =>
            {
                var gross = x.Sell * x.Quantity;
                var discount = gross - x.Net;
                return discount > 0 ? discount : 0m;
            });

    private async Task Print()
        => await JS.InvokeVoidAsync("window.print");
}
