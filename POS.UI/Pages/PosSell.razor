    async Task ConfirmPendingComboSelection()
    {
        if (!PendingComboLines.Any() && !PendingComboSelections.Any())
            return;

        foreach (var selection in PendingComboSelections)
        {
            var chosenStockNumbers = selection.SelectedStockNumbers
                .Where(x => !string.IsNullOrWhiteSpace(x))
                .Select(x => x!.Trim())
                .ToList();

            if (chosenStockNumbers.Count != selection.Qty)
            {
                await AppSnackbar.Show("Select all stock numbers for combo major products", SnackbarType.Warning);
                return;
            }

            if (chosenStockNumbers.Distinct(StringComparer.OrdinalIgnoreCase).Count() != chosenStockNumbers.Count)
            {
                await AppSnackbar.Show("Duplicate stock numbers are not allowed in the same combo", SnackbarType.Warning);
                return;
            }

            if (chosenStockNumbers.Any(IsStockNumberAlreadyInCart))
            {
                await AppSnackbar.Show("One or more stock numbers are already in cart", SnackbarType.Warning);
                return;
            }

            for (var index = 0; index < chosenStockNumbers.Count; index++)
            {
                PendingComboLines.Add(new PosCartLine
                {
                    PartNumber = selection.PartNumber,
                    Description = selection.Description,
                    Qty = 1,
                    UnitPrice = selection.UnitPrice,
                    OriginalPrice = selection.OriginalPrice,
                    DiscountMode = DiscountMode.Amount,
                    DiscountAmount = selection.DiscountAmountPerUnit,
                    DiscountPercent = selection.UnitPrice == 0 ? 0 : (selection.DiscountAmountPerUnit / selection.UnitPrice) * 100m,
                    IsMajor = true,
                    IsCombo = true,
                    ComboId = selection.ComboId,
                    ComboGroupId = PendingComboGroupId,
                    IsComboReturnPolicyApplied = true,
                    StockNumber = chosenStockNumbers[index]
                });
            }
        }

        AddPendingComboLinesToCart();
        await AppSnackbar.Show("Combo items added", SnackbarType.Success);
        SaveUiState();
    }

