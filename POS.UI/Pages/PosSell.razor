    bool IsStockNumberAlreadyInCart(string stockNumber)
    {
        if (string.IsNullOrWhiteSpace(stockNumber))
            return false;

        return Cart.Any(x =>
            x.IsMajor &&
            string.Equals(x.StockNumber, stockNumber, StringComparison.OrdinalIgnoreCase));
    }

    void AddPendingComboLinesToCart()
    {
        foreach (var line in PendingComboLines)
            AddOrMergeCartLine(line);

        CancelPendingComboSelection();
    }

    void AddOrMergeCartLine(PosCartLine line)
    {
        if (line.IsMajor)
        {
            Cart.Add(line);
            return;
        }

        var existing = Cart.FirstOrDefault(x =>
            !x.IsMajor &&
            string.Equals(x.PartNumber, line.PartNumber, StringComparison.OrdinalIgnoreCase) &&
            string.IsNullOrWhiteSpace(x.StockNumber) &&
            x.UnitPrice == line.UnitPrice &&
            x.DiscountAmount == line.DiscountAmount &&
            x.DiscountMode == line.DiscountMode);

        if (existing == null)
        {
            Cart.Add(line);
            return;
        }

        existing.Qty += line.Qty;
    }

    void ApplyComboDiscountAllocation(
        List<PosCartLine> minorLines,
        List<PendingComboSelectionVm> majorSelections,
        decimal comboPrice,
        decimal comboBaseTotal)
    {
        var totalDiscount = comboBaseTotal - comboPrice;
        if (totalDiscount <= 0)
            return;

        var allTargets = new List<ComboDiscountTarget>();
        allTargets.AddRange(minorLines.Select(x => new ComboDiscountTarget
        {
            UnitPrice = x.UnitPrice,
            Qty = x.Qty,
            Apply = value =>
            {
                x.DiscountMode = DiscountMode.Amount;
                x.DiscountAmount = value;
                x.DiscountPercent = x.UnitPrice == 0 ? 0 : (value / x.UnitPrice) * 100m;
            }
        }));
        allTargets.AddRange(majorSelections.Select(x => new ComboDiscountTarget
        {
            UnitPrice = x.UnitPrice,
            Qty = x.Qty,
            Apply = value => x.DiscountAmountPerUnit = value
        }));

        decimal allocated = 0m;
        for (var index = 0; index < allTargets.Count; index++)
        {
            var target = allTargets[index];
            decimal perUnitDiscount;

            if (index == allTargets.Count - 1)
            {
                perUnitDiscount = target.Qty <= 0 ? 0 : (totalDiscount - allocated) / target.Qty;
            }
            else
            {
                var proportion = comboBaseTotal == 0 ? 0 : (target.UnitPrice * target.Qty) / comboBaseTotal;
                var lineDiscount = Math.Round(totalDiscount * proportion, 2, MidpointRounding.AwayFromZero);
                perUnitDiscount = target.Qty <= 0 ? 0 : lineDiscount / target.Qty;
                allocated += perUnitDiscount * target.Qty;
            }

            perUnitDiscount = Clamp(perUnitDiscount, 0, target.UnitPrice);
            target.Apply(perUnitDiscount);
        }
    }

    class ComboDiscountTarget
    {
        public decimal UnitPrice { get; set; }
        public int Qty { get; set; }
        public Action<decimal> Apply { get; set; } = _ => { };
    }

