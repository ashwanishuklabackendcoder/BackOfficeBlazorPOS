    async Task<string?> ResolveTransactionCustomerAccountAsync()
    {
        if (!ShouldCreateTemporaryCustomer())
            return SelectedCustomerAccount;

        var createResponse = await CustomerService.SaveAsync(new CustomerDto
        {
            Firstname = DayCustomerName,
            Balance = 0m
        });

        if (!createResponse.Success || createResponse.Data == null || string.IsNullOrWhiteSpace(createResponse.Data.AccNo))
        {
            await AppSnackbar.Show(
                createResponse.Message ?? "Unable to create customer account",
                SnackbarType.Error);
            return null;
        }

        SelectedCustomerAccount = createResponse.Data.AccNo.Trim().ToUpperInvariant();
        SelectedCustomerName = DayCustomerName;
        SaveUiState();
        return SelectedCustomerAccount;
    }

    async Task<ApiResponse<ProductDto>?> ResolveProductForSellAsync(string? input)
    {
        if (string.IsNullOrWhiteSpace(input))
            return null;

        var lookup = input.Trim();

        var partNumberResult = await ProductApi.GetProduct(lookup);
        if (partNumberResult?.Success == true && partNumberResult.Data != null)
            return partNumberResult;

        var barcodeResult = await Http.GetFromJsonAsync<ApiResponse<ProductDto>>(
            $"api/product/GetBarcode?Barcode={Uri.EscapeDataString(lookup)}");
        if (barcodeResult?.Success == true && barcodeResult.Data != null)
            return barcodeResult;

        var mfrResult = await Http.GetFromJsonAsync<ApiResponse<ProductDto>>(
            $"api/product/GetMFRPartNo?MfrpartNumber={Uri.EscapeDataString(lookup)}");
        if (mfrResult?.Success == true && mfrResult.Data != null)
            return mfrResult;

        return partNumberResult ?? barcodeResult ?? mfrResult;
    }

