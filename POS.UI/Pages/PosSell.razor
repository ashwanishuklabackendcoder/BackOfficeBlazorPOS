@page "/pos-sell"

@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@using Microsoft.AspNetCore.Components.Web
@using POS.UI.State
@inject IJSRuntime JS
@inject IProductApiService ProductApi
@inject IComboApiService ComboApi
@inject IStockService StockService
@inject ICustomerService CustomerService
@inject ILayawayService LayawayService
@inject AppSnackbarService AppSnackbar
@inject NavigationManager Nav
@inject HttpClient Http
@inject IAuthService AuthService
@inject ISysOptionsService SysOptionsService
@inject IQuickShortcutService QuickShortcutService
@implements IAsyncDisposable


<PageTitle>POS Sell</PageTitle>
<style>
    .pos-right-panel {
        height: 85vh;
    }

    .pos-cart-container {
        flex: 1;
        overflow: hidden;
        display: flex;
        flex-direction: column;
    }

    .pos-cart-scroll {
        overflow-y: auto;
        flex: 1;
    }

    .pos-customer-fixed {
        flex-shrink: 0;
    }

    .pos-total-fixed {
        flex-shrink: 0;
    }

    .pos-shortcut-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(110px, 1fr));
        gap: 10px;
    }

    .pos-shortcut-btn {
        height: 110px;
        border: 2px solid #0d6efd;
        border-radius: 10px;
        background: #f8f9fa;
        font-size: 14px;
        text-align: center;
        touch-action: manipulation;
    }

        .pos-shortcut-btn:active {
            background: #0d6efd;
            color: white;
        }

    .pin-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.5);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1050;
    }

    .pin-card {
        width: 100%;
        max-width: 380px;
        background: white;
        border-radius: 12px;
        padding: 20px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.25);
    }

    .pos-locked {
        pointer-events: none;
        opacity: 0.6;
    }

</style>
<div class="@(IsLocked ? "pos-locked" : "")">
<div class="row g-2">

    <!-- ================= LEFT : PRODUCT ENTRY ================= -->
    <div class="col-md-6">

        <div class="card shadow-sm mb-2">
            <div class="card-header fw-bold">Enter Product</div>
            <div class="card-body">

                <div class="col-md-4">
                    <label class="form-label">Part No / Barcode / MPN</label>
                        <input id="partNumber"
                            
                               class="form-control"
                               autocomplete="new-password"
                               autocorrect="off" 
                               autocapitalize="off"
                               spellcheck="false"
                               data-lpignore="true"
                               name="pos_part_number"
                               @bind="ProductCode"
                               @onkeydown="OnProductKeyDown"
                               placeholder="Scan or type and press Enter" />
                    <div class="small text-muted mt-1">F5 Search</div>
                </div>
                @if (PendingMajorLine != null)

                {
                    <div class="row mb-2">
                        <div class="col-md-4">
                            <label class="form-label small">Stock Number</label>

                            <select class="form-select"
                                    @bind="SelectedStockNumber"
                                    @bind:after="OnStockNumberSelected">

                                <option value="">-- Select Stock Number --</option>

                                @foreach (var sn in AvailableStockNumbers)
                                {
                                    <option value="@sn.StockNumber">
                                        @sn.StockNumber
                                    </option>
                                }
                            </select>
                        </div>
                    </div>

                    <hr />
                }
                @if (!string.IsNullOrWhiteSpace(PendingComboDescription))
                {
                    <div class="border rounded p-3 mb-2">
                        <div class="fw-semibold mb-2">Select combo stock numbers</div>
                        <div class="small text-muted mb-3">@PendingComboDescription</div>

                        @foreach (var selection in PendingComboSelections)
                        {
                            <div class="mb-3">
                                <div class="fw-semibold small">@selection.ProductName (@selection.PartNumber)</div>

                                @for (var serialIndex = 0; serialIndex < selection.SelectedStockNumbers.Count; serialIndex++)
                                {
                                    var currentIndex = serialIndex;
                                    <div class="mt-2">
                                        <label class="form-label small">Stock Number @(currentIndex + 1)</label>
                                        <select class="form-select"
                                                value="@GetPendingComboSelectedStockNumber(selection.PartNumber, currentIndex)"
                                                @onchange="e => OnPendingComboStockNumberChanged(selection.PartNumber, currentIndex, e.Value?.ToString())">
                                            <option value="">-- Select Stock Number --</option>

                                            @foreach (var sn in selection.AvailableStockNumbers)
                                            {
                                                <option value="@sn.StockNumber">@sn.StockNumber</option>
                                            }
                                        </select>
                                    </div>
                                }
                            </div>
                        }

                        <div class="d-flex gap-2">
                            <button class="btn btn-primary"
                                    @onclick="ConfirmPendingComboSelection"
                                    disabled="@(!CanConfirmPendingCombo)">
                                Add Combo
                            </button>
                            <button class="btn btn-outline-secondary" @onclick="CancelPendingComboSelection">
                                Cancel
                            </button>
                        </div>
                    </div>

                    <hr />
                }

               @*  <div class="small text-muted">
                    Current Location: <b>@CurrentLocation</b>
                </div> *@

            </div>
        </div>
        <div class="card shadow-sm mb-2">
            <div class="card-header fw-bold">
                Quick Items
            </div>
            <div class="card-body">
                @if (!ShortcutProducts.Any())
                {
                    <div class="text-muted small">No quick items configured for this location.</div>
                }
                else
                {
                    <div class="pos-shortcut-grid">
                        @foreach (var s in ShortcutProducts)
                        {
                            <PosShortcutButton PartNumber="@s.PartNumber"
                                               Title="@s.Title"
                                               SubTitle="@GetShortcutSubtitle(s)"
                                               BackgroundColor="@s.ColorHex"
                                               ForegroundColor="@s.ForeColorHex"
                                               OnClick="OnShortcutClick" />
                        }
                    </div>
                }

            </div>
        </div>

    </div>

    <!-- ================= RIGHT : CART + EDIT ================= -->
    <div class="col-md-6 d-flex flex-column pos-right-panel">


        <!-- CART GRID -->
        <!-- CART GRID -->
        <div class="card shadow-sm mb-2 pos-cart-container">

            <div class="card-header fw-bold">
                Cart
            </div>

            <div class="card-body p-0 pos-cart-scroll">

                <table class="table table-sm table-bordered mb-0">
                    <thead class="table-light sticky-top">
                        <tr>
                            <th>Product</th>
                            <th>Stock Number</th>
                            <th style="width:90px">View</th>
                            <th style="width:90px">Qty</th>
                            <th style="width:120px">Each</th>
                            <th style="width:120px">Disc</th>
                            <th style="width:120px">Total</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (!Cart.Any())
                        {
                            <tr>
                                <td colspan="7" class="text-center text-muted p-3">
                                    No items
                                </td>
                            </tr>
                        }

                        @foreach (var line in Cart)
                        {
                            <tr class="@(SelectedLine == line ? "table-primary" : "")"
                                style="cursor:pointer"
                                @onclick="() => SelectLine(line)">

                                    <td>
                                        <b>@line.PartNumber</b>

                                        @if (line.IsCombo)
                                        {
                                            <button class="btn btn-link btn-sm p-0 ms-2"
                                                    title="View combo items"
                                                    @onclick:stopPropagation="true"
                                                    @onclick="() => OpenComboPreview(line)">
                                                <span class="bi bi-eye"></span>
                                            </button>
                                        }

                                        @if (line.IsPromo)
                                        {
                                            <span class="badge bg-danger ms-1">PROMO</span>
                                        }

                                        <br />

                                        <small>@line.Description</small>

                                        @if (line.IsPromo && !string.IsNullOrWhiteSpace(line.PromoName))
                                        {
                                            <div class="text-danger small">
                                                @line.PromoName
                                            </div>
                                        }
                                    </td>

                                <td>@line.StockNumber</td>

                                <td class="text-center">
                                    @if (line.IsCombo)
                                    {
                                        <button class="btn btn-sm btn-outline-primary"
                                                @onclick:stopPropagation="true"
                                                @onclick="() => OpenComboPreview(line)">
                                            View
                                        </button>
                                    }
                                </td>

                                <td class="text-center fw-bold">
                                    @line.Qty
                                </td>

                                <td class="text-end">
                                    @line.UnitPrice.ToString("0.00")
                                </td>

                                <td class="text-end">
                                    @line.DiscountAmount.ToString("0.00")
                                    <div class="small text-muted">
                                        @line.DiscountPercent.ToString("0.##")%
                                    </div>
                                </td>

                                <td class="text-end fw-bold">
                                    @line.LineTotal.ToString("0.00")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>


        <!-- EXPANDED EDIT PANEL -->
        @if (SelectedLine != null)
        {
            <div class="card shadow-sm mb-2">
                <div class="card-header fw-bold">
                    Edit Line — @SelectedLine.PartNumber
                </div>
                <div class="card-body">

                    <div class="row g-2 align-items-center">

                        <!-- CHANGE PRICE -->
                        <div class="col-md-3">
                            <label class="form-label small">Change Price</label>
                            <input type="number"
                                   class="form-control"
                                   step="0.01"
                                   @bind-value="EditPrice"
                                   @bind-value:event="oninput" />
                        </div>
                        <div class="col-md-1 pt-4">
                            <button class="btn btn-sm btn-primary w-100"
                                    @onclick="ApplyPrice">
                                OK
                            </button>
                        </div>

                        <!-- DISCOUNT -->
                        <div class="col-md-3">
                            <label class="form-label small">Discount Mode</label>
                            <InputRadioGroup @bind-Value="EditDiscountMode" class="d-flex gap-2">
                                <label class="form-check form-check-inline">
                                    <InputRadio class="form-check-input"
                                                Value="DiscountMode.Percent"
                                                disabled="@(SelectedLine?.AllowDiscount != true)" />
                                    <span class="form-check-label">Percent</span>
                                </label>
                                <label class="form-check form-check-inline">
                                    <InputRadio class="form-check-input"
                                                Value="DiscountMode.Amount"
                                                disabled="@(SelectedLine?.AllowDiscount != true)" />
                                    <span class="form-check-label">Amount</span>
                                </label>
                            </InputRadioGroup>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label small">Discount %</label>
                            <input type="number"
                                   class="form-control"
                                   step="0.01"
                                   @bind-value="EditDiscountPercent"
                                   @bind-value:event="oninput"
                                   disabled="@(SelectedLine?.AllowDiscount != true || EditDiscountMode != DiscountMode.Percent)" />
                        </div>
                        <div class="col-md-1 pt-4">
                            <button class="btn btn-sm btn-primary w-100"
                                    @onclick="ApplyDiscount"
                                    disabled="@(SelectedLine?.AllowDiscount != true || EditDiscountMode != DiscountMode.Percent)">
                                OK
                            </button>
                        </div>

                        <div class="col-md-3">
                            <label class="form-label small">Discount Amount</label>
                            <input type="number"
                                   class="form-control"
                                   step="0.01"
                                   @bind-value="EditDiscountAmount"
                                   @bind-value:event="oninput"
                                   disabled="@(SelectedLine?.AllowDiscount != true || EditDiscountMode != DiscountMode.Amount)" />
                        </div>
                        <div class="col-md-1 pt-4">
                            <button class="btn btn-sm btn-primary w-100"
                                    @onclick="ApplyDiscount"
                                    disabled="@(SelectedLine?.AllowDiscount != true || EditDiscountMode != DiscountMode.Amount)">
                                OK
                            </button>
                        </div>

                        <!-- CHANGE DESCRIPTION -->
                        <div class="col-md-3">
                            <label class="form-label small">Description</label>
                            <input class="form-control"
                                   @bind-value="EditDescription"
                                   @bind-value:event="oninput" />
                        </div>
                        <div class="col-md-1 pt-4">
                            <button class="btn btn-sm btn-primary w-100"
                                    @onclick="ApplyDescription">
                                OK
                            </button>
                        </div>
                    </div>

                    <hr />

                    <!-- QUANTITY CONTROLS -->
                    <div class="d-flex align-items-center gap-3">
                        <button class="btn btn-danger btn-lg"
                                disabled="@(SelectedLine?.IsMajor == true)"
                                @onclick="DecreaseQty">

                            −
                        </button>

                        <div class="fs-3 fw-bold">
                            @(SelectedLine?.Qty)
                        </div>

                        <button class="btn btn-success btn-lg"
                                disabled="@(SelectedLine?.IsMajor == true)"
                                @onclick="IncreaseQty">
                            +
                        </button>

                        <button class="btn btn-outline-danger ms-auto"
                                @onclick="RemoveSelected">
                            Remove Item
                        </button>
                    </div>

                </div>
            </div>
        }
    
        
        <div class="card shadow-sm mb-2 pos-customer-fixed">

            <div class="card-body d-flex justify-content-between align-items-center">

                <div>
                    Customer:
                    <b>@SelectedCustomerName (@SelectedCustomerAccount)</b>
                </div>

                <div class="d-flex gap-2">
                    <button class="btn btn-outline-primary btn-lg"
                            @onclick="() => SetWalkInCustomer()">
                        No (Walk-in)
                    </button>

                    <button class="btn btn-primary btn-lg"
                            @onclick="() => ShowCustomerPicker = true">
                        Yes (Select Customer)
                    </button>
                </div>

            </div>
        </div>

        <!-- TOTALS -->
        <div class="card shadow-sm pos-total-fixed">

            <div class="card-body">

                <div class="row">
                    <div class="col-md-6 small">
                        Items: <b>@TotalItems</b>
                    </div>
                    <div class="col-md-6 text-end">
                        <div>Total: <b>@GrossTotal.ToString("0.00")</b></div>
                        <div>Discount: <b>@TotalDiscount.ToString("0.00")</b></div>
                        <div>VAT: <b>0.00</b></div>
                        <div class="fs-5">
                            Due: <b>@SubTotal.ToString("0.00")</b>
                        </div>
                    </div>
                </div>

                <hr />

                <div class="d-flex gap-2 justify-content-end">
                    <button class="btn btn-danger" @onclick="CancelAll">
                        Cancel All
                    </button>

                    <button class="btn btn-secondary" @onclick="Quote">
                        Quote
                    </button>
                    @if (AuthService.HasAccess(PermissionKeys.Layaway))
                    {
                        <button class="btn btn-outline-primary" @onclick="OpenLayawayWorkspace">
                            Layaway
                        </button>
                    }

                    <button class="btn btn-success" @onclick="Pay">
                        Pay
                    </button>
                </div>

            </div>
        </div>

    </div>
</div>
</div>
@if (ShowCustomerPicker)
{
    <PosCustomerPicker OnSelected="OnCustomerSelected"
                       OnCancel="CloseCustomerPicker" />
}
@if (ViewingComboLine != null)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,0.45)">
        <div class="modal-dialog modal-md">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Combo Items - @ViewingComboLine.PartNumber</h5>
                    <button type="button" class="btn-close" @onclick="CloseComboPreview"></button>
                </div>
                <div class="modal-body">
                    <div class="fw-semibold mb-2">@ViewingComboLine.Description</div>
                    <table class="table table-sm table-bordered mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>PartNumber</th>
                                <th>Product</th>
                                <th>Qty</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in ViewingComboLine.ComboItems)
                            {
                                <tr>
                                    <td>@item.PartNumber</td>
                                    <td>
                                        @item.ProductName
                                        @if (item.IsMajor && item.StockNumbers.Any())
                                        {
                                            <div class="small text-muted">Stock: @string.Join(", ", item.StockNumbers)</div>
                                        }
                                    </td>
                                    <td>@(item.Qty * ViewingComboLine.Qty)</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
}
@if (showPinModal)
{
    <div class="pin-overlay">
        <div class="pin-card">
            <div class="fw-bold mb-2">Enter PIN</div>
            <div class="text-muted small mb-3">PIN is required before adding items.</div>
            <input class="form-control mb-2"
                   type="password"
                   @bind="pinInput"
                   @bind:event="oninput"
                   autocomplete="new-password"
                   inputmode="numeric"
                   data-lpignore="true"
                   name="pos_pin_input"
                   @onkeydown="OnPinKeyDown" />
            @if (!string.IsNullOrWhiteSpace(pinError))
            {
                <div class="text-danger small mb-2">@pinError</div>
            }
            <div class="d-flex gap-2 justify-content-end">
                <button class="btn btn-secondary" @onclick="CancelPin">Cancel</button>
                <button class="btn btn-primary" @onclick="SubmitPin">Unlock</button>
            </div>
        </div>
    </div>
}

@code {

    string CurrentLocation = "01";

    string? ProductCode;

    List<PosCartLine> Cart = new();
    PosCartLine? SelectedLine;
    PosCartLine? PendingMajorLine;
    string? PendingComboDescription;
    string? PendingComboGroupId;
    PosCartLine? ViewingComboLine;
    DotNetObjectReference<PosSell>? dotNetRef;
    string? productSearchShortcutId;
    decimal EditPrice;
    decimal EditDiscountPercent;
    decimal EditDiscountAmount;
    DiscountMode EditDiscountMode = DiscountMode.Percent;
    string EditDescription = "";
    bool ShowCustomerPicker = false;
    bool NavigateToLayawayAfterCustomerPick;

    const string WalkInCustomerAccount = "WALKIN";
    const string DayCustomerName = "Day Customer";

    string SelectedCustomerAccount = WalkInCustomerAccount;
    string SelectedCustomerName = "Walk In";

    int TotalItems => Cart.Sum(x => x.Qty);
    decimal GrossTotal => Cart.Sum(x => x.GrossLineTotal);
    decimal TotalDiscount => Cart.Sum(x => x.LineDiscountTotal);
    decimal SubTotal => Cart.Sum(x => x.LineTotal);
    bool IsMajorProduct;
    List<StockNumberDto> AvailableStockNumbers = new();
    List<PendingComboSelectionVm> PendingComboSelections = new();
    string? SelectedStockNumber;
    private const string TillPinVerifiedUntilKey = "pos_till_pin_verified_until";
    private static readonly TimeSpan TillPinLifetime = TimeSpan.FromMinutes(5);
    List<PosCartLine> PendingComboLines = new();
    bool CanConfirmPendingCombo =>
        PendingComboLines.Count > 0 &&
        PendingComboSelections.All(x => x.SelectedStockNumbers.All(y => !string.IsNullOrWhiteSpace(y)));

    protected override async Task OnInitializedAsync()
    {
        LoadUiState();
        ImportPendingLayawayToCart();
        await LoadQuickItemsAsync();
        await RestoreTillPinStateAsync();
        await LoadSysOptionsAsync();
        await ConsumePendingProductSelectionAsync();
    }

    async Task OnProductKeyDown(KeyboardEventArgs e)
    {
        if (EnsureUnlocked() == false)
            return;

        if (e.Key == "Enter")
        {
            await Task.Yield();
            await LoadAndAddProduct();
        }
       
    }
    void OnStockNumberSelected()
    {
        if (string.IsNullOrWhiteSpace(SelectedStockNumber) || PendingMajorLine == null)
            return;

        // Prevent duplicate serial in cart
        if (IsStockNumberAlreadyInCart(SelectedStockNumber))
        {
            AppSnackbar.Show("This Stock Number is already in cart", SnackbarType.Warning);
            SelectedStockNumber = null;
            return;
        }

        PendingMajorLine.StockNumber = SelectedStockNumber;

        // Add finalized major line to cart
        Cart.Add(PendingMajorLine);

        AppSnackbar.Show($"Serial {SelectedStockNumber} added", SnackbarType.Success);

        // Reset entry state
        ProductCode = null;
        PendingMajorLine = null;
        AvailableStockNumbers.Clear();
        SelectedStockNumber = null;
        SaveUiState();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        dotNetRef = DotNetObjectReference.Create(this);

        await JS.InvokeVoidAsync("enableEnterNavigation");
        productSearchShortcutId = await JS.InvokeAsync<string>(
            "blazorShortcuts.register",
            dotNetRef,
            new
            {
                scopeSelector = "#partNumber",
                enableEsc = false,
                enableEnter = false,
                enableF1 = false,
                enableF5 = true
            });

        if (!IsLocked)
        {
            await JS.InvokeVoidAsync(
                "eval",
                "document.getElementById('partNumber')?.focus()"
            );
        }
    }

    [JSInvokable]
    public Task OnF5()
    {
        PosWorkflowState.PendingProductSearchReturnUri = Nav.Uri;
        Nav.NavigateTo("/products");
        return Task.CompletedTask;
    }

    private async Task ConsumePendingProductSelectionAsync()
    {
        if (IsLocked)
            return;

        var selected = PosWorkflowState.PendingProductSelection;
        if (selected?.PartNumber == null)
            return;

        PosWorkflowState.PendingProductSelection = null;
        PosWorkflowState.PendingProductSearchReturnUri = null;

        ProductCode = selected.PartNumber;
        await LoadAndAddProduct();
    }

    async Task LoadAndAddProduct()
    {
        if (EnsureUnlocked() == false)
            return;

        if (PendingMajorLine != null || PendingComboLines.Any())
        {
            await AppSnackbar.Show("Complete pending stock-number selection first", SnackbarType.Warning);
            return;
        }

        if (string.IsNullOrWhiteSpace(ProductCode))
            return;

        var res = await ResolveProductForSellAsync(ProductCode);

        if (res?.Success == true && res.Data != null)
        {
            var product = res.Data;
            var productPartNumber = product.PartNumber ?? "";
            var productDescription = product.Details ?? "";
            IsMajorProduct = product.Major;

            var effectivePrice = product.IsUsingPromoPrice() ? product.PromoPrice : product.CostPrice;

            if (IsMajorProduct)
            {
                AvailableStockNumbers =
                    await StockService.GetAvailableStockNumbersAsync(
                        productPartNumber, CurrentLocation);

                if (!AvailableStockNumbers.Any())
                {
                    await AppSnackbar.Show("No serialized stock available", SnackbarType.Warning);
                    return;
                }

                PendingMajorLine = new PosCartLine
                {
                    PartNumber = productPartNumber,
                    Description = productDescription,
                    Qty = 1,
                    UnitPrice = effectivePrice,
                    OriginalPrice = effectivePrice,
                    IsMajor = true,
                    IsPromo = product.IsUsingPromoPrice(),
                    PromoName = product.PromoName
                };

                ApplyProductDiscount(product, PendingMajorLine);
                return;
            }

            var available =
                await GetAvailableStockForCurrentLocationAsync(productPartNumber);

            if (available <= 0)
            {
                await AppSnackbar.Show("Out of stock", SnackbarType.Warning);
                return;
            }

            var existing = Cart.FirstOrDefault(x => !x.IsCombo && x.PartNumber == productPartNumber);

            if (existing != null)
            {
                var maxAvailableQty = available < 0 ? 0 : available;
                if (existing.Qty >= maxAvailableQty)
                {
                    existing.Qty = maxAvailableQty;
                    await AppSnackbar.Show($"Only {maxAvailableQty} item(s) available in stock", SnackbarType.Warning);
                    SaveUiState();
                    return;
                }

                existing.Qty++;
            }
            else
            {
                var line = new PosCartLine
                {
                    PartNumber = productPartNumber,
                    Description = productDescription,
                    Qty = 1,
                    UnitPrice = effectivePrice,
                    OriginalPrice = effectivePrice,
                    IsMajor = false,
                    IsPromo = product.IsUsingPromoPrice(),
                    PromoName = product.PromoName
                };

                ApplyProductDiscount(product, line);
                Cart.Add(line);
            }

            ProductCode = null;
            SaveUiState();
            return;
        }

        var comboResult = await ComboApi.GetByPartNumberAsync(ProductCode);
        if (comboResult?.Success != true || comboResult.Data == null)
        {
            await AppSnackbar.Show("Product not found", SnackbarType.Error);
            return;
        }

        var combo = comboResult.Data;
        var pendingComboLines = new List<PosCartLine>();
        var pendingSelections = new List<PendingComboSelectionVm>();
        var comboBaseTotal = 0m;

        foreach (var detail in combo.Details)
        {
            var childProductResult = await ProductApi.GetProduct(detail.PartNumber);
            if (childProductResult?.Success != true || childProductResult.Data == null)
            {
                await AppSnackbar.Show($"Combo child {detail.PartNumber} was not found", SnackbarType.Warning);
                return;
            }

            var childProduct = childProductResult.Data;
            var partNumber = childProduct.PartNumber ?? detail.PartNumber;
            var description = childProduct.Details ?? detail.ProductName ?? detail.PartNumber;
            var qty = detail.Qty <= 0 ? 1 : detail.Qty;
            var baseUnitPrice = detail.PromoPrice.GetValueOrDefault() > 0
                ? detail.PromoPrice.GetValueOrDefault()
                : detail.UnitPrice;

            if (baseUnitPrice <= 0)
                baseUnitPrice = childProduct.IsUsingPromoPrice() ? childProduct.PromoPrice : childProduct.CostPrice;

            comboBaseTotal += baseUnitPrice * qty;

            if (childProduct.Major)
            {
                var stockNumbers = await StockService.GetAvailableStockNumbersAsync(partNumber, CurrentLocation);
                if (stockNumbers.Count < qty)
                {
                    await AppSnackbar.Show("Major product stock is not available", SnackbarType.Warning);
                    return;
                }

                pendingSelections.Add(new PendingComboSelectionVm
                {
                    PartNumber = partNumber,
                    ProductName = description,
                    Qty = qty,
                    Description = description,
                    UnitPrice = baseUnitPrice,
                    OriginalPrice = baseUnitPrice,
                    ComboId = combo.ComboId,
                    AvailableStockNumbers = stockNumbers,
                    SelectedStockNumbers = Enumerable.Repeat<string?>(null, qty).ToList()
                });
            }
            else
            {
                var availableQty = await GetAvailableStockForCurrentLocationAsync(partNumber);
                if (availableQty < qty)
                {
                    await AppSnackbar.Show("Combo child stock is not available", SnackbarType.Warning);
                    return;
                }

                pendingComboLines.Add(new PosCartLine
                {
                    PartNumber = partNumber,
                    Description = description,
                    Qty = qty,
                    UnitPrice = baseUnitPrice,
                    OriginalPrice = baseUnitPrice,
                    IsMajor = false,
                    IsCombo = true,
                    ComboId = combo.ComboId
                });
            }
        }

        if (comboBaseTotal <= 0)
        {
            await AppSnackbar.Show("Combo price is invalid", SnackbarType.Warning);
            return;
        }

        ApplyComboDiscountAllocation(pendingComboLines, pendingSelections, combo.ComboPrice, comboBaseTotal);

        if (pendingSelections.Any())
        {
            PendingComboDescription = combo.ComboName;
            PendingComboGroupId = Guid.NewGuid().ToString("N");
            PendingComboLines = pendingComboLines;
            PendingComboSelections = pendingSelections;
            foreach (var line in PendingComboLines)
            {
                line.ComboGroupId = PendingComboGroupId;
                line.IsComboReturnPolicyApplied = true;
            }
            ProductCode = null;
            return;
        }

        var comboGroupId = Guid.NewGuid().ToString("N");
        foreach (var line in pendingComboLines)
        {
            line.ComboGroupId = comboGroupId;
            line.IsComboReturnPolicyApplied = true;
        }

        AddPendingComboLinesToCart();

        ProductCode = null;
        SaveUiState();
    }
    
