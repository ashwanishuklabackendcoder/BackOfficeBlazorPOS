    void ImportPendingLayawayToCart()
    {
        var pending = PosWorkflowState.PendingLayawayToSell;
        if (pending == null)
            return;

        foreach (var line in pending.Lines)
        {
            AddOrMergeImportedLine(line);
        }

        CurrentLocation = string.IsNullOrWhiteSpace(pending.Location)
            ? CurrentLocation
            : pending.Location;

        SelectedCustomerAccount = string.IsNullOrWhiteSpace(pending.CustomerAccNo)
            ? SelectedCustomerAccount
            : pending.CustomerAccNo;

        if (!string.IsNullOrWhiteSpace(pending.CustomerName))
            SelectedCustomerName = pending.CustomerName;

        PosWorkflowState.PendingLayawayToSell = null;
        PosPaymentState.CurrentLayawayNo = null;
        SaveUiState();
        AppSnackbar.Show(
            $"Layaway {pending.LayawayNo} items moved to POS cart",
            SnackbarType.Success);
    }

    void AddOrMergeImportedLine(LayawayLineDto line)
    {
        if (line.IsMajor)
        {
            Cart.Add(new PosCartLine
            {
                PartNumber = line.PartNumber,
                Description = "",
                Qty = 1,
                UnitPrice = line.Sell,
                OriginalPrice = line.Cost,
                DiscountPercent = 0,
                DiscountAmount = 0,
                AllowDiscount = true,
                DiscountMode = DiscountMode.Percent,
                IsMajor = true,
                StockNumber = line.StockNo
            });
            return;
        }

        var existing = Cart.FirstOrDefault(x =>
            !x.IsMajor &&
            x.PartNumber == line.PartNumber &&
            string.IsNullOrWhiteSpace(x.StockNumber));

        if (existing == null)
        {
            Cart.Add(new PosCartLine
            {
                PartNumber = line.PartNumber,
                Description = "",
                Qty = line.Quantity,
                UnitPrice = line.Sell,
                OriginalPrice = line.Cost,
                DiscountPercent = 0,
                DiscountAmount = 0,
                AllowDiscount = true,
                DiscountMode = DiscountMode.Percent,
                IsMajor = false,
                StockNumber = ""
            });
        }
        else
        {
            existing.Qty += line.Quantity;
            existing.UnitPrice = line.Sell;
            existing.OriginalPrice = line.Cost;
        }
    }

    private SysOptionsDto? _sysOptions;
    private DateTimeOffset? _tillPinVerifiedUntilUtc;
    private bool showPinModal;
    private string pinInput = string.Empty;
    private string? pinError;
    private bool IsLocked => _sysOptions?.EnterPinOnTill == true && !HasValidTillPin();

    private async Task LoadSysOptionsAsync()
    {
        if (AuthService.CurrentUser?.IsAdmin != true)
        {
            _sysOptions = null;
            return;
        }

        var res = await SysOptionsService.GetAsync();
        if (res.Success && res.Data != null)
        {
            _sysOptions = res.Data;
            if (_sysOptions.EnterPinOnTill == true && !HasValidTillPin())
            {
                showPinModal = true;
            }
            else
            {
                showPinModal = false;
            }
        }
        else
        {
            _sysOptions = null;
        }
    }

    private async Task SubmitPin()
    {
        var expected = _sysOptions?.Password1 ?? string.Empty;
        if (string.Equals(pinInput.Trim(), expected.Trim(), StringComparison.Ordinal))
        {
            _tillPinVerifiedUntilUtc = DateTimeOffset.UtcNow.Add(TillPinLifetime);
            showPinModal = false;
            pinError = null;
            pinInput = string.Empty;
            await PersistTillPinStateAsync();
            await InvokeAsync(StateHasChanged);
            await FocusPartNumberAsync();
        }
        else
        {
            pinError = "Invalid PIN";
            pinInput = string.Empty;
            await Task.Yield();
        }
    }

    private void CancelPin()
    {
        showPinModal = false;
        pinError = null;
        pinInput = string.Empty;
        Nav.NavigateTo("/");
    }

    private async Task OnPinKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await SubmitPin();
        }
        else if (e.Key == "Escape")
        {
            CancelPin();
        }
    }

    private bool EnsureUnlocked()
    {
        if (!IsLocked)
            return true;

        showPinModal = true;
        pinError = null;
        return false;
    }

    private bool HasValidTillPin()
    {
        if (_tillPinVerifiedUntilUtc == null)
            return false;

        if (_tillPinVerifiedUntilUtc <= DateTimeOffset.UtcNow)
        {
            _tillPinVerifiedUntilUtc = null;
            _ = ClearTillPinStateAsync();
            return false;
        }

        return true;
    }

    private async Task RestoreTillPinStateAsync()
    {
        var raw = await JS.InvokeAsync<string?>("localStorage.getItem", TillPinVerifiedUntilKey);
        if (string.IsNullOrWhiteSpace(raw))
            return;

        if (DateTimeOffset.TryParse(raw, out var verifiedUntil) && verifiedUntil > DateTimeOffset.UtcNow)
        {
            _tillPinVerifiedUntilUtc = verifiedUntil;
            return;
        }

        _tillPinVerifiedUntilUtc = null;
        await ClearTillPinStateAsync();
    }

    private Task PersistTillPinStateAsync()
    {
        var value = _tillPinVerifiedUntilUtc?.ToString("O") ?? string.Empty;
        return JS.InvokeVoidAsync("localStorage.setItem", TillPinVerifiedUntilKey, value).AsTask();
    }

    private Task ClearTillPinStateAsync()
        => JS.InvokeVoidAsync("localStorage.removeItem", TillPinVerifiedUntilKey).AsTask();

    private Task FocusPartNumberAsync()
        => JS.InvokeVoidAsync(
            "eval",
            "document.getElementById('partNumber')?.focus()").AsTask();

    public async ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();

        if (!string.IsNullOrWhiteSpace(productSearchShortcutId))
        {
            try
            {
                await JS.InvokeVoidAsync("blazorShortcuts.unregister", productSearchShortcutId);
            }
            catch
            {
                // Ignore JS disconnection during teardown.
            }
        }
    }
}
