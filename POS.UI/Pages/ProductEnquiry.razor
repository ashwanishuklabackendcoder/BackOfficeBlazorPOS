        {
            Title = "In Stock",
            Value = row => row.InStockQty,
            ColumnFilterType = GridFilterType.NumericRange
        },
        new GridColumn<ProductEnquiryLocationDto>
        {
            Title = "Stock Value",
            Value = row => row.StockValue,
            ColumnFilterType = GridFilterType.NumericRange,
            Filterable = false,
