    private static readonly List<GridColumn<ProductEnquiryTransferDto>> TransferGridColumns = new()
    {
        new GridColumn<ProductEnquiryTransferDto> { Title = "Date", Value = row => row.Date, ColumnFilterType = GridFilterType.Text },
        new GridColumn<ProductEnquiryTransferDto> { Title = "Dispatch Id", Value = row => row.DispatchId, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryTransferDto> { Title = "From", Value = row => row.FromLocation },
        new GridColumn<ProductEnquiryTransferDto> { Title = "To", Value = row => row.ToLocation },
        new GridColumn<ProductEnquiryTransferDto> { Title = "Qty", Value = row => row.Qty, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryTransferDto> { Title = "Serial", Value = row => row.SerialNumber },
        new GridColumn<ProductEnquiryTransferDto> { Title = "Sales Code", Value = row => row.SalesCode }
