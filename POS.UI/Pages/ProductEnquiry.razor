        },
        new GridColumn<ProductEnquiryLocationDto>
        {
            Title = "Returned",
            Value = row => row.ReturnedQty,
            ColumnFilterType = GridFilterType.NumericRange
        },
        new GridColumn<ProductEnquiryLocationDto>
        {
            Title = "Reserved",
            Value = row => row.ReservedQty,
            ColumnFilterType = GridFilterType.NumericRange
        },
