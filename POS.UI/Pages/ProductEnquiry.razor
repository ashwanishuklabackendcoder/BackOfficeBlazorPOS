        new GridColumn<ProductEnquiryTransactionDto> { Title = "Description", Value = row => row.Description },
        new GridColumn<ProductEnquiryTransactionDto> { Title = "Qty In", Value = row => row.QtyIn, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryTransactionDto> { Title = "Qty Out", Value = row => row.QtyOut, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryTransactionDto> { Title = "Location", Value = row => row.Location },
        new GridColumn<ProductEnquiryTransactionDto> { Title = "Balance", Value = row => row.StockBalanceAfter, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryTransactionDto> { Title = "Sales Person", Value = row => row.SalesPerson }
    };

    private static readonly List<GridColumn<ProductEnquirySaleDto>> SalesGridColumns = new()
    {
        new GridColumn<ProductEnquirySaleDto> { Title = "Invoice", Value = row => row.Invoice },
        new GridColumn<ProductEnquirySaleDto> { Title = "Customer", Value = row => row.Customer },
        new GridColumn<ProductEnquirySaleDto> { Title = "Qty", Value = row => row.Qty, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquirySaleDto> { Title = "Price", Value = row => row.Price, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquirySaleDto> { Title = "Cost", Value = row => row.Cost, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquirySaleDto> { Title = "Serial", Value = row => row.Serial },
        new GridColumn<ProductEnquirySaleDto> { Title = "Balance", Value = row => row.Balance, ColumnFilterType = GridFilterType.NumericRange }
    };

    private static readonly List<GridColumn<ProductEnquiryStockCheckDto>> StockCheckGridColumns = new()
    {
        new GridColumn<ProductEnquiryStockCheckDto> { Title = "Stock Check Date", Value = row => row.StockCheckDate },
        new GridColumn<ProductEnquiryStockCheckDto> { Title = "System Qty", Value = row => row.SystemQty, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryStockCheckDto> { Title = "Physical Qty", Value = row => row.PhysicalQty, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryStockCheckDto> { Title = "Difference", Value = row => row.Difference, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryStockCheckDto> { Title = "Location", Value = row => row.Location }
    };

    private static readonly List<GridColumn<ProductEnquiryLayawayDto>> LayawayGridColumns = new()
    {
        new GridColumn<ProductEnquiryLayawayDto> { Title = "Ref", Value = row => row.LayawayRef },
        new GridColumn<ProductEnquiryLayawayDto> { Title = "Customer", Value = row => row.Customer },
        new GridColumn<ProductEnquiryLayawayDto> { Title = "Qty", Value = row => row.Qty, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryLayawayDto> { Title = "Price", Value = row => row.Price, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryLayawayDto> { Title = "Status", Value = row => row.Status },
        new GridColumn<ProductEnquiryLayawayDto> { Title = "Date", Value = row => row.Date }
    };

    private static readonly List<GridColumn<ProductEnquiryLogDto>> LogGridColumns = new()
    {
        new GridColumn<ProductEnquiryLogDto> { Title = "Date", Value = row => row.Date },
        new GridColumn<ProductEnquiryLogDto> { Title = "User", Value = row => row.User },
        new GridColumn<ProductEnquiryLogDto> { Title = "Action", Value = row => row.Action },
        new GridColumn<ProductEnquiryLogDto> { Title = "Description", Value = row => row.Description }
    };

    private static readonly List<GridColumn<ProductEnquiryInternalOrderDto>> InternalOrderGridColumns = new()
    {
        new GridColumn<ProductEnquiryInternalOrderDto> { Title = "Date", Value = row => row.Date },
        new GridColumn<ProductEnquiryInternalOrderDto> { Title = "Order No", Value = row => row.InternalOrderNo },
        new GridColumn<ProductEnquiryInternalOrderDto> { Title = "From", Value = row => row.FromLocation },
        new GridColumn<ProductEnquiryInternalOrderDto> { Title = "To", Value = row => row.ToLocation },
        new GridColumn<ProductEnquiryInternalOrderDto> { Title = "Qty", Value = row => row.Qty, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryInternalOrderDto> { Title = "Status", Value = row => row.Status }
    };

    protected override async Task OnParametersSetAsync()
    {
        if (!string.IsNullOrWhiteSpace(PartNumber))
        {
            searchTerm = PartNumber!;
            await LoadHeaderAsync();
        }
    }

    private async Task LoadHeaderAsync()
    {
        var query = searchTerm?.Trim() ?? string.Empty;

        if (string.IsNullOrWhiteSpace(query))
        {
            await AppSnackbar.Show("Enter a part number", SnackbarType.Warning);
            return;
        }

        searchTerm = query;
        ResetTabCache();
        isLoadingHeader = true;

        try
        {
            header = await ProductEnquiryService.GetHeaderAsync(query);
            if (header == null)
            {
                await AppSnackbar.Show("Product not found", SnackbarType.Info);
            }
            else
            {
                await LoadTabData(activeTab);
            }
        }
        catch (Exception ex)
        {
            await AppSnackbar.Show($"Unable to load product info: {ex.Message}", SnackbarType.Error);
        }
        finally
        {
            isLoadingHeader = false;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        dotNetRef = DotNetObjectReference.Create(this);
    }

    private void ResetTabCache()
    {
        loadedTabs.Clear();
        historyDto = null;
        historyRows = new();
        locationRows = new();
        transferRows = new();
        purchaseOrderRows = new();
        transactionRows = new();
        saleRows = new();
        stockCheckRows = new();
        layawayRows = new();
        logRows = new();
        internalOrderRows = new();
    }

    private async Task SetActiveTab(string tab)
    {
        activeTab = tab;
        await LoadTabData(tab);
    }

    private async Task LoadTabData(string tab)
    {
        var query = searchTerm?.Trim();
        if (string.IsNullOrWhiteSpace(query) || tab == "Product Info")
            return;

        if (loadedTabs.Contains(tab))
            return;

        try
        {
            switch (tab)
            {
                case "History":
                    await EnsureHistoryDataAsync(query);
                    break;
                case "Location":
                    await EnsureLocationDataAsync(query);
                    break;
                case "Stock Transfers":
                    await EnsureTransferDataAsync(query);
                    break;
                case "Purchase Orders":
                    await EnsurePurchaseOrderDataAsync(query);
                    break;
                case "Transactions":
                    await EnsureTransactionDataAsync(query);
                    break;
                case "Sales":
                    await EnsureSalesDataAsync(query);
                    break;
                case "Stock Check History":
                    await EnsureStockCheckDataAsync(query);
                    break;
                case "Layaways":
                    await EnsureLayawayDataAsync(query);
                    break;
                case "Logs":
                    await EnsureLogDataAsync(query);
                    break;
                case "Internal Orders":
                    await EnsureInternalOrderDataAsync(query);
                    break;
            }

            loadedTabs.Add(tab);
        }
        catch (Exception ex)
        {
            await AppSnackbar.Show($"Unable to load {tab}: {ex.Message}", SnackbarType.Error);
        }
    }

    private async Task EnsureHistoryDataAsync(string query)
    {
        var data = await ProductEnquiryService.GetHistoryAsync(query);
        historyDto = data;
        historyRows = data?.MonthlySummaries ?? new();
        await historyGrid?.ReloadAsync();
    }

