        new GridColumn<ProductEnquiryPurchaseOrderDto> { Title = "Status", Value = row => row.Status },
        new GridColumn<ProductEnquiryPurchaseOrderDto> { Title = "Qty", Value = row => row.Qty, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryPurchaseOrderDto> { Title = "Outstanding", Value = row => row.OutstandingQty, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryPurchaseOrderDto> { Title = "Date", Value = row => row.Date },
        new GridColumn<ProductEnquiryPurchaseOrderDto> { Title = "Location", Value = row => row.Location },
        new GridColumn<ProductEnquiryPurchaseOrderDto> { Title = "Customer", Value = row => row.CustomerAccount },
        new GridColumn<ProductEnquiryPurchaseOrderDto> { Title = "Cost", Value = row => row.Cost, ColumnFilterType = GridFilterType.NumericRange },
        new GridColumn<ProductEnquiryPurchaseOrderDto> { Title = "Supplier", Value = row => row.Supplier }
    };

    private static readonly List<GridColumn<ProductEnquiryTransactionDto>> TransactionGridColumns = new()
