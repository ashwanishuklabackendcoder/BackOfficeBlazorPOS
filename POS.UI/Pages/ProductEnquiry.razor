    private Task<List<ProductEnquiryHistoryRowDto>> LoadHistoryGridData() => Task.FromResult(historyRows);
    private Task<List<ProductEnquiryLocationDto>> LoadLocationGridData() => Task.FromResult(locationRows);
    private Task<List<ProductEnquiryTransferDto>> LoadTransferGridData() => Task.FromResult(transferRows);
    private Task<List<ProductEnquiryPurchaseOrderDto>> LoadPurchaseOrderGridData() => Task.FromResult(purchaseOrderRows);
    private Task<List<ProductEnquiryTransactionDto>> LoadTransactionGridData() => Task.FromResult(transactionRows);
    private Task<List<ProductEnquirySaleDto>> LoadSalesGridData() => Task.FromResult(saleRows);
    private Task<List<ProductEnquiryStockCheckDto>> LoadStockCheckGridData() => Task.FromResult(stockCheckRows);
    private Task<List<ProductEnquiryLayawayDto>> LoadLayawayGridData() => Task.FromResult(layawayRows);
