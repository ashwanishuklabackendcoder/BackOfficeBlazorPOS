@page "/product-enquiry"
@page "/product-enquiry/{PartNumber}"
@using BackOfficeBlazor.Shared.DTOs
@using System
@using System.Collections.Generic
@using System.Linq
@using Microsoft.AspNetCore.Components.Web
@using POS.UI.Services
@inject IProductEnquiryService ProductEnquiryService
@inject AppSnackbarService AppSnackbar
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Product Enquiry</PageTitle>

<div class="card shadow-sm border-0 product-list-card">
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <div>
            <h5 class="fw-bold mb-0">Product Enquiry</h5>
            <div class="text-muted small">Lookup the lifecycle of a part number.</div>
        </div>
        <div class="d-flex gap-2 align-items-center flex-wrap">
            <input class="form-control form-control-sm"
                   placeholder="Part Number"
                   @bind="searchTerm"
                   @bind:event="oninput"
                   @ref="searchInput"
                   @onkeydown="HandleSearchKey" />
            <button class="btn btn-primary px-3" @onclick="LoadHeaderAsync">Search</button>
        </div>
    </div>

    <div class="card-body p-4">
        <div class="glass-panel border rounded-3 px-3 py-3">
            @if (isLoadingHeader)
            {
                <div class="text-center py-4 text-muted">Loading product data...</div>
            }
            else if (header == null)
            {
                <div class="text-center py-4 text-muted">Enter a Part Number to view analytics.</div>
            }
            else
            {
                <div class="row g-3 align-items-start">
                    <div class="col-lg-3">
                        <div class="text-muted small">Part Number</div>
                        <div class="d-flex align-items-center gap-2">
                            <span class="fs-5 fw-bold">@header.PartNumber</span>
                            @if (!string.IsNullOrWhiteSpace(header.ImageUrl))
                            {
                                <img src="@header.ImageUrl" alt="Product" class="img-fluid" style="max-height:60px;" />
                            }
                        </div>
                        <div class="text-muted small">@((header.MfrPartNumber ?? "N/A"))</div>
                    </div>
                    <div class="col-lg-9">
                        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 g-3">
                            <div class="col">
                                <div class="text-muted small">Brand / Make</div>
                                <div class="fw-semibold">@((header.Make ?? "N/A"))</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Barcode</div>
                                <div class="fw-semibold">@((header.Barcode ?? "N/A"))</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Supplier 1</div>
                                <div class="fw-semibold">@((header.Supplier1 ?? "N/A"))</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Supplier 2</div>
                                <div class="fw-semibold">@((header.Supplier2 ?? "N/A"))</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Size / Colour</div>
                                <div class="fw-semibold">@((header.Size ?? "N/A"))</div>
                                <div class="text-muted small">@((header.Color ?? "N/A"))</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Category</div>
                                <div class="fw-semibold">@((header.CategoryHierarchy ?? "N/A"))</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Search Keywords</div>
                                <div class="fw-semibold text-truncate">@((header.SearchKeywords ?? "N/A"))</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Total Stock</div>
                                <div class="fs-3 fw-bold">@header.TotalStock</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Last Sold</div>
                                <div class="fw-semibold">@((header.LastSoldDate?.ToString("yyyy-MM-dd")) ?? "N/A")</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Last Stock Check</div>
                                <div class="fw-semibold">@((header.LastStockCheck?.ToString("yyyy-MM-dd")) ?? "N/A")</div>
                            </div>
                        </div>
                        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-3 mt-3 text-center">
                            <div class="col">
                                <div class="text-muted small">Latest Cost</div>
                                <div class="fw-semibold">@header.LatestCost.ToString("C")</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Average Cost</div>
                                <div class="fw-semibold">@header.AverageCost.ToString("C")</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Suggested RRP</div>
                                <div class="fw-semibold">@((header.SuggestedRrp?.ToString("C")) ?? "N/A")</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Margin %</div>
                                <div class="fw-semibold">@($"{header.MarginPercent:0.00}%")</div>
                            </div>
                        </div>
                        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-3 mt-3 text-center">
                            <div class="col">
                                <div class="text-muted small">Total Sales</div>
                                <div class="fw-semibold">@header.TotalSalesValue.ToString("C")</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Revenue</div>
                                <div class="fw-semibold">@header.TotalRevenue.ToString("C")</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">VAT</div>
                                <div class="fw-semibold">@header.TotalVat.ToString("C")</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Faulty Stock</div>
                                <div class="fw-semibold">@header.FaultyStockQty</div>
                            </div>
                        </div>
                        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-4 g-3 mt-3 text-center">
                            <div class="col">
                                <div class="text-muted small">Back Orders</div>
                                <div class="fw-semibold">@header.BackOrdersQty</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Allocated</div>
                                <div class="fw-semibold">@header.AllocatedStock</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Min Stock</div>
                                <div class="fw-semibold">@header.MinStock</div>
                            </div>
                            <div class="col">
                                <div class="text-muted small">Max Stock</div>
                                <div class="fw-semibold">@header.MaxStock</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="section-divider mt-4"></div>
            }
        </div>
    </div>

    <div class="card-body pb-4 pt-2 px-4">
        <ul class="nav nav-tabs mb-2 nav-tabs-custom" role="tablist" style="flex-wrap: wrap;">
            @foreach (var tab in tabs)
            {
                <li class="nav-item" role="presentation">
                    <button type="button"
                            class="nav-link @(activeTab == tab ? "active fw-semibold" : "text-dark")"
                            role="tab"
                            @onclick="() => SetActiveTab(tab)">
                        @tab
                    </button>
                </li>
            }
        </ul>

        <div class="tab-content">
            @switch (activeTab)
            {
                case "Product Info":
                    <div class="tab-pane fade show active">
                        <div class="glass-panel border rounded-3 px-3 py-3">
                            <div class="row g-3 text-center">
                                <div class="col-md-3">
                                    <div class="text-muted small">Supplier 1</div>
                                    <div class="fw-semibold">@((header?.Supplier1) ?? "N/A")</div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-muted small">Supplier 2</div>
                                    <div class="fw-semibold">@((header?.Supplier2) ?? "N/A")</div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-muted small">Last Sold</div>
                                    <div class="fw-semibold">@((header?.LastSoldDate?.ToString("yyyy-MM-dd")) ?? "N/A")</div>
                                </div>
                                <div class="col-md-3">
                                    <div class="text-muted small">Qty Sold</div>
                                    <div class="fw-semibold">@header?.TotalQtySold ?? 0</div>
                                </div>
                            </div>
                        </div>
                    </div>
                    break;
                case "History":
                    <div class="tab-pane fade show active">
                        <div class="glass-panel border rounded-3 px-3 py-3">
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <strong>History</strong>
                                <div class="text-muted small">
                                    Suggested Stock:
                                    <span class="fw-semibold">@historyDto?.SuggestedStockLevel ?? 0</span>
                                </div>
                            </div>
                            <GenericGrid @ref="historyGrid"
                                         Title="History"
                                         GridKey="product-enquiry-history"
                                         Columns="HistoryGridColumns"
                                         LoadData="LoadHistoryGridData" />
                        </div>
                    </div>
                    break;
                case "Location":
                    <div class="tab-pane fade show active">
                        <div class="glass-panel border rounded-3 px-3 py-3">
                            <GenericGrid @ref="locationGrid"
                                         Title="Locations"
                                         GridKey="product-enquiry-location"
                                         Columns="LocationGridColumns"
                                         LoadData="LoadLocationGridData" />
                        </div>
                    </div>
                    break;
                case "Stock Transfers":
                    <div class="tab-pane fade show active">
                        <div class="glass-panel border rounded-3 px-3 py-3">
                            <GenericGrid @ref="transferGrid"
                                         Title="Stock Transfers"
                                         GridKey="product-enquiry-transfers"
                                         Columns="TransferGridColumns"
                                         LoadData="LoadTransferGridData" />
                        </div>
                    </div>
                    break;
                case "Purchase Orders":
                    <div class="tab-pane fade show active">
                        <div class="glass-panel border rounded-3 px-3 py-3">
                            <GenericGrid @ref="purchaseOrdersGrid"
                                         Title="Purchase Orders"
                                         GridKey="product-enquiry-purchase-orders"
                                         Columns="PurchaseOrderGridColumns"
                                         LoadData="LoadPurchaseOrderGridData" />
                        </div>
                    </div>
                    break;
                case "Transactions":
                    <div class="tab-pane fade show active">
                        <div class="glass-panel border rounded-3 px-3 py-3">
                            <GenericGrid @ref="transactionsGrid"
                                         Title="Transactions"
                                         GridKey="product-enquiry-transactions"
                                         Columns="TransactionGridColumns"
                                         LoadData="LoadTransactionGridData" />
                        </div>
                    </div>
                    break;
                case "Sales":
                    <div class="tab-pane fade show active">
                        <div class="glass-panel border rounded-3 px-3 py-3">
                            <GenericGrid @ref="salesGrid"
                                         Title="Sales"
                                         GridKey="product-enquiry-sales"
                                         Columns="SalesGridColumns"
                                         LoadData="LoadSalesGridData" />
                        </div>
                    </div>
                    break;
                case "Stock Check History":
                    <div class="tab-pane fade show active">
                        <div class="glass-panel border rounded-3 px-3 py-3">
                            <GenericGrid @ref="stockCheckGrid"
                                         Title="Stock Check History"
                                         GridKey="product-enquiry-stock-check"
                                         Columns="StockCheckGridColumns"
                                         LoadData="LoadStockCheckGridData" />
                        </div>
                    </div>
                    break;
                case "Layaways":
                    <div class="tab-pane fade show active">
                        <div class="glass-panel border rounded-3 px-3 py-3">
                            <GenericGrid @ref="layawayGrid"
                                         Title="Layaways"
                                         GridKey="product-enquiry-layaways"
                                         Columns="LayawayGridColumns"
                                         LoadData="LoadLayawayGridData" />
                        </div>
                    </div>
                    break;
                case "Logs":
                    <div class="tab-pane fade show active">
                        <div class="glass-panel border rounded-3 px-3 py-3">
                            <GenericGrid @ref="logGrid"
                                         Title="Logs"
                                         GridKey="product-enquiry-logs"
                                         Columns="LogGridColumns"
                                         LoadData="LoadLogGridData" />
                        </div>
                    </div>
                    break;
                case "Internal Orders":
                    <div class="tab-pane fade show active">
                        <div class="glass-panel border rounded-3 px-3 py-3">
                            <GenericGrid @ref="internalOrderGrid"
                                         Title="Internal Orders"
                                         GridKey="product-enquiry-internal-orders"
                                         Columns="InternalOrderGridColumns"
                                         LoadData="LoadInternalOrderGridData" />
                        </div>
                    </div>
                    break;
                default:
                    <div class="tab-pane fade show active">
                        <div class="glass-panel border rounded-3 px-3 py-5 text-center text-muted">
                            <div>This tab is not yet implemented.</div>
                        </div>
                    </div>
                    break;
            }
        </div>
    </div>
</div>

@code {
    [Parameter] public string? PartNumber { get; set; }

    private ProductEnquiryHeaderDto? header;
    private string searchTerm = string.Empty;
    private bool isLoadingHeader;
    private ElementReference searchInput;
    private DotNetObjectReference<ProductEnquiry>? dotNetRef;

    private readonly string[] tabs = new[]
    {
        "Product Info",
        "History",
        "Location",
        "Stock Transfers",
        "Purchase Orders",
        "Transactions",
        "Sales",
        "Stock Check History",
        "Layaways",
        "Logs",
        "Internal Orders"
    };

    private string activeTab = "Product Info";
    private readonly HashSet<string> loadedTabs = new(StringComparer.OrdinalIgnoreCase);

    private ProductEnquiryHistoryDto? historyDto;
    private List<ProductEnquiryHistoryRowDto> historyRows = new();
    private GenericGrid<ProductEnquiryHistoryRowDto>? historyGrid;

    private List<ProductEnquiryLocationDto> locationRows = new();
    private GenericGrid<ProductEnquiryLocationDto>? locationGrid;

    private List<ProductEnquiryTransferDto> transferRows = new();
    private GenericGrid<ProductEnquiryTransferDto>? transferGrid;

    private List<ProductEnquiryPurchaseOrderDto> purchaseOrderRows = new();
    private GenericGrid<ProductEnquiryPurchaseOrderDto>? purchaseOrdersGrid;

    private List<ProductEnquiryTransactionDto> transactionRows = new();
    private GenericGrid<ProductEnquiryTransactionDto>? transactionsGrid;

    private List<ProductEnquirySaleDto> saleRows = new();
    private GenericGrid<ProductEnquirySaleDto>? salesGrid;

    private List<ProductEnquiryStockCheckDto> stockCheckRows = new();
    private GenericGrid<ProductEnquiryStockCheckDto>? stockCheckGrid;

    private List<ProductEnquiryLayawayDto> layawayRows = new();
    private GenericGrid<ProductEnquiryLayawayDto>? layawayGrid;

    private List<ProductEnquiryLogDto> logRows = new();
    private GenericGrid<ProductEnquiryLogDto>? logGrid;

    private List<ProductEnquiryInternalOrderDto> internalOrderRows = new();
    private GenericGrid<ProductEnquiryInternalOrderDto>? internalOrderGrid;

