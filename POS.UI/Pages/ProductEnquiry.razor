    private Task<List<ProductEnquiryInternalOrderDto>> LoadInternalOrderGridData() => Task.FromResult(internalOrderRows);

    private Task HandleSearchKey(KeyboardEventArgs args)
    {
        if (args.Key == "Enter")
        {
            return LoadHeaderAsync();
        }

        return Task.CompletedTask;
    }

    public async ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();
    }
}
