@page "/stock-input"

@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@using POS.UI.State
@using Microsoft.AspNetCore.Components.Forms
@using Microsoft.AspNetCore.Components.Web
@using System.Linq
@inject IJSRuntime JS
@inject IProductApiService ProductApi
@inject IStockService StockService
@inject AppSnackbarService AppSnackbar

<PageTitle>Stock Input</PageTitle>

<style>
    .stock-label {
        font-size: 13px;
        color: #333;
        padding-top: 6px;
    }

    .readonly-box {
        background-color: #f8f9fa;
    }

    .section-divider {
        border-top: 1px solid #e5e5e5;
        margin: 18px 0;
    }
</style>

<div class="card shadow-sm">
    <div class="card-header bg-white fw-bold">
        Stock Input
    </div>

    <div class="card-body">

        <!-- PART NUMBER -->
        <div class="row mb-3 align-items-center">
            <label class="col-sm-1 stock-label">Part No</label>
            <div class="col-sm-2">
                <input id="partNumber"
                       class="form-control"
                       @bind-value="PartNumber"
                       maxlength="@(MaxLengthHelper.For<StockInputDto>(nameof(StockInputDto.PartNumber)))"
                       @bind-value:event="oninput"
                       @onkeydown="OnPartKeyDown" />

            </div>
            <div class="col-sm-2">
                <button class="btn btn-primary w-100" @onclick="() => showProductSearch = true">
                    Search
                </button>

            </div>

            @if (IsMajor)
            {
                <div class="col-sm-4">
                    <label class="me-2 fw-bold">Divide Stock</label>
                    <input type="radio" checked disabled /> No
                    <input type="radio" class="ms-2" disabled /> Yes
                </div>
            }
        </div>

        <!-- PRODUCT INFO -->
        <div class="row mb-2">
            <label class="col-sm-1 stock-label">Size</label>
            <div class="col-sm-2">
                <input class="form-control readonly-box" value="@Product?.Size" readonly />
            </div>
        </div>

        <div class="row mb-2">
            <label class="col-sm-1 stock-label">Colour</label>
            <div class="col-sm-2">
                <input class="form-control readonly-box" value="@Product?.Color" readonly />
            </div>
        </div>

        <div class="row mb-3">
            <label class="col-sm-1 stock-label">Details</label>
            <div class="col-sm-2">
                <input class="form-control readonly-box" value="@Product?.Details" readonly />
            </div>
        </div>

        <div class="section-divider"></div>

        <!-- QTY -->
        <div class="row mb-3">
            <label class="col-sm-1 stock-label">Box Qty</label>
            <div class="col-sm-2">
                <input type="number" class="form-control readonly-box" @bind="BoxQty" disabled />
            </div>

            <label class="col-sm-1 stock-label">Qty In *</label>
            <div class="col-sm-2">
                <input type="number" class="form-control" @bind="QtyIn" />
            </div>

            <label class="col-sm-1 stock-label">Date In</label>
            <div class="col-sm-2">
                <input type="date" class="form-control" @bind="DateIn" />
            </div>
        </div>

        <!-- DOCUMENTS -->
        <div class="row mb-3">
            <label class="col-sm-1 stock-label">Invoice No</label>
            <div class="col-sm-2">
                <input class="form-control"
                       @bind="InvoiceNo"
                       maxlength="@(MaxLengthHelper.For<StockInputDto>(nameof(StockInputDto.InvoiceNumber)))" />
            </div>

            <label class="col-sm-1 stock-label">P/O No</label>
            <div class="col-sm-2">
                <input class="form-control"
                       @bind="PurchaseOrderNo"
                       maxlength="@(MaxLengthHelper.For<StockInputDto>(nameof(StockInputDto.PurchaseOrderNo)))" />
            </div>
        </div>

        <!-- COST -->
        <div class="row mb-3">
            <label class="col-sm-1 stock-label">Cost Each</label>
            <div class="col-sm-2">
                <div class="input-group">
                    <span class="input-group-text">£</span>
                    <input type="number" step="0.01" class="form-control" @bind="CostEach" />
                </div>
            </div>

            <label class="col-sm-1 stock-label">Total Cost</label>
            <div class="col-sm-2">
                <div class="input-group">
                    <span class="input-group-text">£</span>
                    <input class="form-control readonly-box" value="@TotalCost" readonly />
                </div>
            </div>
        </div>

        <!-- SUPPLIER / LOCATION -->
        <div class="row mb-3">
            <label class="col-sm-1 stock-label">Supplier</label>
            <div class="col-sm-2">
                <SupplierSelector @bind-Value="SupplierCode" />
            </div>

            <label class="col-sm-1 stock-label">Location *</label>
            <div class="col-sm-2">
                <LocationSelector @bind-Value="LocationCode" />
            </div>
        </div>

        <!-- STOCK -->
        <div class="row mb-3">
            <label class="col-sm-1 stock-label">In Stock</label>
            <div class="col-sm-2">
                <input class="form-control readonly-box" value="@CurrentStock" readonly />
            </div>
        </div>

        <div class="section-divider"></div>

        <!-- ACTIONS -->
        <div class="d-flex gap-2">
            <button class="btn btn-outline-primary" @onclick="Save">
                Save
            </button>
            <button class="btn btn-secondary" @onclick="Reset">
                Cancel
            </button>
        </div>

        <div class="section-divider"></div>

        <!-- HISTORY GRID -->
        <h6 class="fw-bold">Stock History</h6>
        <table class="table table-sm table-bordered">
            <thead>
                <tr>
                    <th>Part#</th>
                    <th>Loc</th>
                    <th>Qty</th>
                    <th>Cost</th>
                    <th>Total</th>
                </tr>
            </thead>
            <tbody>
                @if (History.Any())
                {
                    @foreach (var h in History)
                    {
                        <tr>
                            <td>@h.PartNumber</td>
                            <td>@h.Location</td>
                            <td>@h.Quantity</td>
                            <td>@h.Cost</td>
                            <td>@h.Total</td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="5" class="text-center text-muted">
                            No stock history
                        </td>
                    </tr>
                }
            </tbody>
        </table>

    </div>
    @if (showProductSearch)
    {
        <div class="modal fade show d-block" style="background:rgba(0,0,0,0.5)">
            <div class="modal-dialog modal-xl">
                <div class="modal-content">

                    <div class="modal-header"> 
                        <h5 class="modal-title">Search Product</h5>
                        <button class="btn-close"
                                @onclick="CloseProductSearch"></button>
                    </div>

                    <div class="modal-body">
                        <ProductList SelectionMode="true"
                                  OnProductSelected="OnProductSelected" />
                    </div>

                </div>
            </div>
        </div>
    }

</div>

@code {

    // -------------------------
    // STATE
    // -------------------------
    string? PartNumber;
    ProductDto? Product;
    bool showProductSearch;

    bool IsMajor => Product?.Major == true;

    int BoxQty;
    int QtyIn = 1;
    DateTime DateIn = DateTime.Today;

    string? InvoiceNo;
    string? PurchaseOrderNo;

    decimal CostEach;

    string? SupplierCode;
    string? LocationCode;

    int CurrentStock;
    DotNetObjectReference<ProductStockInput>? dotNetRef;
    List<StockHistoryRow> History = new();

    decimal TotalCost => QtyIn * CostEach;

    protected override void OnInitialized()
    {
        LocationCode = GetCurrentLocation();
    }

    // -------------------------
    // EVENTS
    // -------------------------


    async Task SearchProduct()
    {
        if (string.IsNullOrWhiteSpace(PartNumber))
        {
            await AppSnackbar.Show("Enter Part Number", SnackbarType.Warning);
            return;
        }

        var res = await ProductApi.GetProduct(PartNumber);

        if (res?.Success != true || res.Data == null)
        {
            Product = null;
            await AppSnackbar.Show("Product not found", SnackbarType.Error);
            return;
        }

        Product = res.Data;
        ApplyProductDefaults();

        // LOAD CURRENT STOCK
        CurrentStock = await StockService.GetCurrentStockAsync(PartNumber);

        // LOAD HISTORY
        var history = await StockService.GetHistoryAsync(PartNumber);

        History = history.Select(h => new StockHistoryRow
        {
            PartNumber = h.PartNumber,
            Location = h.LocationCode,
            Quantity = h.Quantity,
            Cost = h.Cost
        }).ToList();

        await AppSnackbar.Show("Product & stock loaded", SnackbarType.Success);
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        dotNetRef = DotNetObjectReference.Create(this);

        await JS.InvokeVoidAsync("enableProductShortcuts", dotNetRef);
        await JS.InvokeVoidAsync("enableEnterNavigation");

        await JS.InvokeVoidAsync(
            "eval",
            "document.getElementById('partNumber')?.focus()"
        );
    }
    async Task OnPartKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Task.Yield(); // allow bind to complete
            await SearchProduct();
        }
    }


    async Task Save()
    {
        if (Product == null)
        {
            await AppSnackbar.Show("Load a product first", SnackbarType.Error);
            return;
        }

        if (QtyIn <= 0)
        {
            await AppSnackbar.Show("Quantity must be greater than zero", SnackbarType.Error);
            return;
        }

        if (string.IsNullOrWhiteSpace(LocationCode))
        {
           await AppSnackbar.Show("Location is required", SnackbarType.Error);
            return;
        }

        if (string.IsNullOrWhiteSpace(SupplierCode))
        {
            await AppSnackbar.Show("Supplier is required", SnackbarType.Error);
            return;
        }

        var dto = new StockInputDto
        {
            PartNumber = Product.PartNumber,
            IsMajorProduct = Product.Major,
            LocationCode = LocationCode!,
            Quantity = QtyIn,
            BoxQuantity = BoxQty,
            DateIn = DateIn,
            CostEach = CostEach,
            SupplierCode = SupplierCode!,
            InvoiceNumber = InvoiceNo?.Trim() ?? string.Empty,
            PurchaseOrderNo = PurchaseOrderNo?.Trim() ?? string.Empty,
            StaffCode = "AD"
        };

        var result = await StockService.SaveAsync(dto);

        if (!result.Success)
        {
           await AppSnackbar.Show(result.Message, SnackbarType.Error);
            return;
        }

        await AppSnackbar.Show("Stock added successfully", SnackbarType.Success);
        Reset();
    }
    async Task OnProductSelected(ProductDto product)
    {
        showProductSearch = false;

        PartNumber = product.PartNumber;
        Product = product;
        ApplyProductDefaults();

        // Load stock info immediately
        CurrentStock = await StockService.GetCurrentStockAsync(product.PartNumber);

        var history = await StockService.GetHistoryAsync(product.PartNumber);
        History = history.Select(h => new StockHistoryRow
        {
            PartNumber = h.PartNumber,
            Location = h.LocationCode,
            Quantity = h.Quantity,
            Cost = h.Cost
        }).ToList();

        await AppSnackbar.Show("Product selected", SnackbarType.Success);
    }

    void CloseProductSearch()
    {
        showProductSearch = false;
    }

    void Reset()
    {
        PartNumber = null;
        Product = null;
        BoxQty = 0;
        QtyIn = 1;
        InvoiceNo = null;
        PurchaseOrderNo = null;
        CostEach = 0;
        SupplierCode = null;
        LocationCode = GetCurrentLocation();
        CurrentStock = 0;
        History.Clear();
    }

    void ApplyProductDefaults()
    {
        BoxQty = Product?.BoxQuantity ?? 0;
        SupplierCode = Product?.Supplier1Code;
        CostEach = Product?.CostPrice ?? 0m;
        LocationCode = GetCurrentLocation();
    }

    string GetCurrentLocation()
        => string.IsNullOrWhiteSpace(PosWorkflowState.PosLocation) ? "01" : PosWorkflowState.PosLocation;

    class StockHistoryRow
    {
        public string PartNumber { get; set; } = "";
        public string Location { get; set; } = "";
        public int Quantity { get; set; }
        public decimal Cost { get; set; }
        public decimal Total => Quantity * Cost;
    }
    public void Dispose()
    {
        dotNetRef?.Dispose();
    }
}

