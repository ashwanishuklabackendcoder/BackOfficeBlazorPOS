@using BackOfficeBlazor.Shared.DTOs

@using POS.UI.Services
@inject AppSnackbarService AppSnackbar

@if (!Enabled)
{
    return;
}

<div class="border rounded p-3 bg-light">

    <div class="mb-3">
        <label class="form-label fw-bold text-danger">Group Name *</label>
        <input id="variant-group-name"
               class="form-control @(groupError != null ? "is-invalid" : "")"
               @bind="Group.GroupName"
               @oninput="Validate" />
        @if (!string.IsNullOrWhiteSpace(groupError))
        {
            <div class="text-danger small">@groupError</div>
        }
    </div>

    <table class="table table-sm table-bordered align-middle">
        <thead class="table-light">
            <tr>
                <th class="text-danger">Color *</th>
                <th class="text-danger">Size *</th>
                <th class="text-danger">MFR *</th>
                <th>Barcode</th>
                <th style="width:60px"></th>
            </tr>
        </thead>
        <tbody>
            @for (var i = 0; i < Group.Variants.Count; i++)
            {
                var v = Group.Variants[i];
                <tr>
                    <td><input id="@GetInputId(i, "Color")" class="form-control form-control-sm @(GetInputCss(v, "Color"))" @bind="v.Color" maxlength="@(MaxLengthHelper.For<ProductDto>(nameof(ProductDto.Color)))" @oninput="Validate" /></td>
                    <td><input id="@GetInputId(i, "Size")" class="form-control form-control-sm @(GetInputCss(v, "Size"))" @bind="v.Size" maxlength="@(MaxLengthHelper.For<ProductDto>(nameof(ProductDto.Size)))" @oninput="Validate" /></td>
                    <td><input id="@GetInputId(i, "MfrPartNumber")" class="form-control form-control-sm @(GetInputCss(v, "MfrPartNumber"))" @bind="v.MfrPartNumber" maxlength="@(MaxLengthHelper.For<ProductDto>(nameof(ProductDto.MfrPartNumber)))" @oninput="Validate" /></td>
                    <td><input id="@GetInputId(i, "Barcode")" class="form-control form-control-sm @(GetInputCss(v, "Barcode"))" @bind="v.Barcode" maxlength="@(MaxLengthHelper.For<ProductDto>(nameof(ProductDto.Barcode)))" @oninput="Validate" /></td>
                    <td class="text-center">
                        <i class="fa fa-trash text-danger"
                           style="cursor:pointer"
                           @onclick="() => Remove(v)"></i>
                    </td>
                </tr>

                @if (errors.ContainsKey(v))
                {
                    <tr>
                        <td colspan="5" class="text-danger small">
                            @errors[v]
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>

    <button class="btn btn-sm btn-primary" @onclick="Add">+ Add Variant</button>
</div>

@code {

    HashSet<string> usedMfrs = new(StringComparer.OrdinalIgnoreCase);
    HashSet<string> usedBarcodes = new(StringComparer.OrdinalIgnoreCase);
    HashSet<string> usedColorSize = new(StringComparer.OrdinalIgnoreCase);
    bool disabledNoticeShown;


    [Parameter] public bool Enabled { get; set; }
    [Parameter] public GroupProductDto Group { get; set; } = new();
    [Parameter] public ProductDto Header { get; set; } = new();

    Dictionary<ProductDto, string> errors = new();
    Dictionary<ProductDto, string> errorFields = new();
    string? groupError;

    protected override void OnAfterRender(bool firstRender)
    {
        if (Enabled || disabledNoticeShown)
            return;

        disabledNoticeShown = true;
        AppSnackbar.Show("Enable \"Create Attributes & Options\" to add variants.", SnackbarType.Info);
    }

    void Add()
    {
        Group.Variants.Add(new ProductDto
        {
            Make = Header.Make,
            Details = Header.Details,
            CatACode = Header.CatACode,
            CatBCode = Header.CatBCode,
            CatCCode = Header.CatCCode,
            Website = Header.Website,
            GroupCode = Header.PartNumber,
            GroupName = Group.GroupName,
            IsVariant = true
        });

        Validate();
    }

    void Remove(ProductDto v)
    {
        Group.Variants.Remove(v);
        Validate();
    }

    void Validate()
    {
        errors.Clear();
        errorFields.Clear();
        usedMfrs.Clear();
        usedBarcodes.Clear();
        usedColorSize.Clear();


        groupError = string.IsNullOrWhiteSpace(Group.GroupName)
            ? "Group Name is required"
            : null;

        if (!string.IsNullOrWhiteSpace(Header.MfrPartNumber))
            usedMfrs.Add(Header.MfrPartNumber.Trim());

        if (!string.IsNullOrWhiteSpace(Header.Barcode))
            usedBarcodes.Add(Header.Barcode.Trim());

        if (!string.IsNullOrWhiteSpace(Header.Color) && !string.IsNullOrWhiteSpace(Header.Size))
        {
            usedColorSize.Add($"{Header.Color.Trim()}|{Header.Size.Trim()}");
        }


        foreach (var v in Group.Variants)
        {
            var mfr = v.MfrPartNumber?.Trim();
            var bar = v.Barcode?.Trim();
            var color = v.Color?.Trim();
            var size = v.Size?.Trim();

            if (string.IsNullOrWhiteSpace(mfr))
            {
                errors[v] = "MFR Part No is required";
                errorFields[v] = "MfrPartNumber";
                continue;
            }
            if (string.IsNullOrWhiteSpace(color))
            {
                errors[v] = "Color is required";
                errorFields[v] = "Color";
                continue;
            }
            if (string.IsNullOrWhiteSpace(size))
            {
                errors[v] = "Size is required";
                errorFields[v] = "Size";
                continue;
            }

            if (!usedMfrs.Add(mfr))
            {
                errors[v] = "MFR already exists in this group";
                errorFields[v] = "MfrPartNumber";
                continue;
            }
            if (!string.IsNullOrWhiteSpace(bar) && !usedBarcodes.Add(bar))
            {
                errors[v] = "Barcode already exists in this group";
                errorFields[v] = "Barcode";
                continue;
            }
            var combo = $"{color}|{size}";

            if (!usedColorSize.Add(combo))
            {
                errors[v] = "This Color + Size combination already exists in this Item Group";
                errorFields[v] = "Color";
                continue;
            }

        }
    }

    public bool IsValid()
    {
        Validate();
        return groupError == null && errors.Count == 0;
    }

    public string? GetFirstErrorMessage()
    {
        Validate();

        if (!string.IsNullOrWhiteSpace(groupError))
            return groupError;

        return Group.Variants
            .Select(v => errors.TryGetValue(v, out var error) ? error : null)
            .FirstOrDefault(x => !string.IsNullOrWhiteSpace(x));
    }

    public async Task FocusFirstInvalidAsync(IJSRuntime js)
    {
        Validate();

        if (!string.IsNullOrWhiteSpace(groupError))
        {
            await js.InvokeVoidAsync("blazorForms.focusById", "variant-group-name");
            return;
        }

        for (var i = 0; i < Group.Variants.Count; i++)
        {
            var variant = Group.Variants[i];
            if (!errorFields.TryGetValue(variant, out var field))
                continue;

            await js.InvokeVoidAsync("blazorForms.focusById", GetInputId(i, field));
            return;
        }
    }

    string GetInputCss(ProductDto variant, string field)
        => errorFields.TryGetValue(variant, out var invalidField) && invalidField == field
            ? "is-invalid"
            : string.Empty;

    static string GetInputId(int index, string field)
        => $"variant-{index}-{field}".ToLowerInvariant();
}
