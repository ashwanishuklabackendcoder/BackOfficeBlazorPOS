@page "/product"
@page "/product/{PartNumber}"
@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@using Microsoft.AspNetCore.Components.Forms
@using System.Linq
@using System.Text.RegularExpressions
@inject HttpClient Http
@inject NavigationManager Navigation
@inject IImageApiService ImageApi
@inject IProductApiService ProductApi
@inject ICategoryService CategoryApi
@inject ISupplierService SupplierApi
@inject IManufacturerService ManufacturerService
@inject IJSRuntime JS
@inject ILocationService LocationService
@inherits LayoutComponentBase
@implements IAsyncDisposable
@inject AppSnackbarService AppSnackbar





<PageTitle>Product Maintenance</PageTitle>

@* @if (!string.IsNullOrWhiteSpace(message))
{
    <div class="alert alert-info mt-3">@message</div>
} *@
<div id="product-form" class="card shadow-sm border-0 product-list-card" data-shortcuts-scope>
    <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
        <h5 class="fw-bold mb-0">@PageHeader</h5>
    
    </div>

    <div class="card-body p-4">
        <div class="border rounded-3 px-3 py-3 mt-2 mb-2 glass-panel">
            <div class="row mb-3 align-items-center">
                <label class="col-sm-1 form-label-custom required-label">Part Number</label>
                <div class="col-sm-2">
                    <input id="partNumber"
                           class="form-control"
                           @bind-value="model.PartNumber"
                           @bind-value:event="oninput"
                           maxlength="@(MaxLengthHelper.For<ProductDto>(nameof(ProductDto.PartNumber)))"
                           @onkeydown="OnPartNumberKeyDown"
                           @ref="partNumberInput"
                           data-enter-skip="true"
                           disabled="@isPartNumberDisabled" />
                </div>
                <div class="col-sm-1 ps-0">
                    <button class="btn btn-primary w-100 search-btn" @onclick="Search">Search</button>
                </div>
                <div class="col-sm-2 d-flex align-items-center">
                    <span class="badge rounded-pill text-bg-light border text-muted">F5 Search</span>
                </div>
            </div>
            <div class="row mb-0 align-items-center">
                <label class="col-sm-1 form-label-custom required-label">MFR Part No</label>
                <div class="col-sm-2">
                    <input class="form-control"
                           tabindex="2"
                           maxlength="@(MaxLengthHelper.For<ProductDto>(nameof(ProductDto.MfrPartNumber)))"
                           style="text-transform:uppercase"
                           @bind="model.MfrPartNumber"
                           @ref="mfrPartInput"
                           @oninput="e => model.MfrPartNumber = RegexKeepCapsAlnum(e.Value?.ToString(), 50)" />
                </div>
            </div>
        </div>
        <ul class="nav nav-tabs mb-2 nav-tabs-custom" role="tablist" style="flex-wrap: wrap;">
            <li class="nav-item" role="presentation">
                <button type="button" class="@TabClass(ProductTabs.ProductInfo)" role="tab" @onclick="() => SetActiveTab(ProductTabs.ProductInfo)">
                    Product Info
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="@TabClass(ProductTabs.MinMax)" role="tab" @onclick="() => SetActiveTab(ProductTabs.MinMax)">
                    MIN/MAX
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="@TabClass(ProductTabs.Description)" role="tab" @onclick="() => SetActiveTab(ProductTabs.Description)">
                    Description
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="@TabClass(ProductTabs.Images)" role="tab" @onclick="() => SetActiveTab(ProductTabs.Images)">
                    Images
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="@TabClass(ProductTabs.Ecommerce)" role="tab" @onclick="() => SetActiveTab(ProductTabs.Ecommerce)">
                    e-Commerce
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="@TabClass(ProductTabs.Specification)" role="tab" @onclick="() => SetActiveTab(ProductTabs.Specification)">
                    Specification
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="@TabClass(ProductTabs.Geometry)" role="tab" @onclick="() => SetActiveTab(ProductTabs.Geometry)">
                    Geometry
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button type="button" class="@TabClass(ProductTabs.ProductNotes)" role="tab" @onclick="() => SetActiveTab(ProductTabs.ProductNotes)">
                    Product Notes
                </button>
            </li>
        </ul>

        <div class="tab-content">
            @if (activeTab == ProductTabs.ProductInfo)
            {
            <div class="tab-pane fade show active">
                <div class="row mb-3">
                    <div class="col-md-6">
                        <div class="row mb-3 align-items-center">
                            <label class="col-sm-2 form-label-custom">Type</label>
                            <div class="col-md-4">
                                <div class="form-check form-check-inline mb-0">
                                    <input class="form-check-input" type="radio" name="itemType" id="goods" checked>
                                    <label class="form-check-label" for="goods">Goods</label>
                                </div>
                                <div class="form-check form-check-inline mb-0">
                                    <input class="form-check-input" type="radio" name="itemType" id="service">
                                    <label class="form-check-label" for="service">Service</label>
                                </div>
                            </div>
                        </div>
                        <div class="row mb-3 align-items-center">
                            <label class="col-sm-2 form-label-custom">Major</label>
                            <div class="col-sm-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           role="switch"
                                           @bind="model.Major" />
                                </div>
                            </div>
                        </div>
                        <div class="row mb-3 align-items-center">
                            <label class="col-sm-2 form-label-custom">Current</label>
                            <div class="col-sm-4">
                                <div class="form-check form-switch">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           role="switch"
                                           @bind="model.Current" />
                                </div>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-2 form-label-custom">Barcode</label>
                            <div class="col-sm-4">
                                <input class="form-control"
                                       @bind="model.Barcode"
                                       maxlength="@(MaxLengthHelper.For<ProductDto>(nameof(ProductDto.Barcode)))" />
                            </div>
                        </div>
                    </div>
                </div>

        <div class="section-divider"></div>
        <div class="row">
            <div class="col-md-6">
                <div class="row mb-3">
                    <label class="col-sm-2 form-label-custom required-label">Brand</label>
                    <div class="col-sm-4">
                        <BrandSelector @bind-Value="model.Make" />
                    </div>
                    <label class="col-sm-2 form-label-custom form-label-custom--indent">Gender</label>
                    <div class="col-sm-4">
                        <select class="form-select" @bind="model.Gender">
                            @foreach (ProductDto.Genders g in Enum.GetValues(typeof(ProductDto.Genders)))
                            {
                                <option value="@g">@g</option>
                            }
                        </select>
                    </div>
              

                </div>
                <div class="row mb-3">

                    <label class="col-sm-2 form-label-custom">Suitability</label>
                    <div class="col-sm-4">
                        <select class="form-select" @bind="model.Suitability">
                            @foreach (ProductDto.AgeRange a in Enum.GetValues(typeof(ProductDto.AgeRange)))
                            {
                                <option value="@a">@a</option>
                            }
                        </select>


                    </div>
                    <label class="col-sm-2 form-label-custom form-label-custom--indent">Season</label>
                    <div class="col-sm-4">
                        <select class="form-select" @bind="model.Season">
                            @foreach (ProductDto.Seasons a in Enum.GetValues(typeof(ProductDto.Seasons)))
                            {
                                <option value="@a">@a</option>
                            }
                        </select>


                    </div>


                </div>
                <div class="row mb-3">
                    <label class="col-sm-2 form-label-custom required-label">Supplier</label>
                    <div class="col-sm-4">
                        <SupplierSelector @bind-Value="model.Supplier1Code" />
                    </div>
                </div>
                <div class="row mb-3">
                    <label class="col-sm-2 form-label-custom required-label">Search 1</label>
                    <div class="col-sm-4">
                        <div class="input-group">
                            <input class="form-control"
                                   @bind="model.Search1"
                                   maxlength="@(MaxLengthHelper.For<ProductDto>(nameof(ProductDto.Search1)))" />
                            @*  <span class="input-group-text bg-light"></span> *@
                        </div>
                    </div>
                    <label class="col-sm-2 form-label-custom form-label-custom--indent">Search 2</label>
                    <div class="col-sm-4">
                        <div class="input-group">
                            <input class="form-control"
                                   @bind="model.Search2"
                                   maxlength="@(MaxLengthHelper.For<ProductDto>(nameof(ProductDto.Search2)))" />
                            @* <span class="input-group-text bg-light"></span> *@
                        </div>
                    </div>


                </div>
                <div class="row mb-3">
                    <label class="col-sm-2 form-label-custom required-label">Details</label>
                    <div class="col-sm-10">
                        <div class="input-group">
                            <input class="form-control"
                                   @bind="model.Details"
                                   maxlength="@(MaxLengthHelper.For<ProductDto>(nameof(ProductDto.Details)))" />
                            @*  <span class="input-group-text bg-light"></span> *@
                        </div>
                    </div>

                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-2 form-label-custom">Weight</label>
                    <div class="col-sm-2">
                        <input type="number" step="0.01" class="form-control" @bind="model.Weight" />
                    </div>
                    <label class="col-sm-2 offset-sm-2 form-label-custom form-label-custom--indent">Size</label>
                    <div class="col-sm-2">
                        <input class="form-control"
                               @bind="model.Size"
                               maxlength="@(MaxLengthHelper.For<ProductDto>(nameof(ProductDto.Size)))" />
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-2 form-label-custom">Color</label>
                    <div class="col-sm-4">
                        <input class="form-control"
                               @bind="model.Color"
                               maxlength="@(MaxLengthHelper.For<ProductDto>(nameof(ProductDto.Color)))" />
                    </div>
                </div>
            </div>

            <div class="col-lg-4">
                  <div class="form-check form-switch mb-3">
                <input class="form-check-input" type="checkbox" @bind="isGroupItem" />
                <label class="form-check-label fw-bold">
                    Create Attributes & Options (Variants)
                </label>
            </div>

            <ProductVariants Enabled="isGroupItem"
                             Group="group"
                             Header="model" />

            </div>
        </div>
     


        <div class="section-divider"></div>
        <div class="row mb-3">

            <div class="col-md-6">
                <div class="row align-items-center">
                    <label class="col-sm-2 form-label-custom required-label">Category A</label>
                    <div class="col-sm-4">
                        <CategorySelector Level="A"
                                          @bind-Code="model.CatACode"
                                          @bind-Name="model.CatA" />
                    </div>
                    <label class="col-sm-2 form-label-custom form-label-custom--indent">Category B</label>
                    <div class="col-sm-4">
                        <CategorySelector Level="B"
                                          @bind-Code="model.CatBCode"
                                          @bind-Name="model.CatB" />
                    </div>

                </div>
            </div>
            <div class="col-md-6">
                <div class="row align-items-center">
                </div>
            </div>
        </div>

        <div class="row mb-3">
            <div class="col-md-6">
                <div class="row align-items-center">
                    <label class="col-sm-2 form-label-custom">Category C</label>
                    <div class="col-sm-4">
                        <CategorySelector Level="C"
                                          @bind-Code="model.CatCCode"
                                          @bind-Name="model.CatC" />
                    </div>

                </div>
            </div>
            <div class="col-md-6">
                <div class="row align-items-center">
                </div>
            </div>
        </div>
        <div class="section-divider"></div>
        <div class="row mb-3">
            <div class="col-md-6">
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-2 form-label-custom">Cost Price</label>
                    <div class="col-sm-4">
                        <div class="input-group">
                            <span class="input-group-text currency-pill">£</span>
                            <input type="number"
                                    step="0.01"
                                    class="form-control"
                                    @bind="model.CostPrice" />
                        </div>
                    </div>
                    <label class="col-sm-2 form-label-custom form-label-custom--indent">Store Price</label>
                    <div class="col-sm-4">
                        <div class="input-group">
                            <span class="input-group-text currency-pill">£</span>
                            <input type="number"
                                    step="0.01"
                                    class="form-control"
                                    @bind="model.StorePrice" />
                        </div>
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-2 form-label-custom">RRP</label>
                    <div class="col-sm-4">
                        <div class="input-group">
                            <span class="input-group-text currency-pill">£</span>
                            <input type="number"
                                    step="0.01"
                                    class="form-control"
                                    @bind="model.SuggestedRRP" />
                        </div>
                    </div>
                    <label class="col-sm-2 form-label-custom form-label-custom--indent">Web Price</label>
                    <div class="col-sm-4">
                        <div class="input-group">
                            <span class="input-group-text currency-pill">£</span>
                            <input type="number"
                                    step="0.01"
                                    class="form-control"
                                    @bind="model.WebPrice" />
                        </div>
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-2 form-label-custom">Website</label>
                    <div class="col-sm-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input"
                                   type="checkbox"
                                   role="switch"
                                   @bind="model.Website" />
                        </div>
                    </div>
                    <label class="col-sm-2 form-label-custom form-label-custom--indent">Web Only</label>
                    <div class="col-sm-4">
                        <div class="form-check form-switch">
                            <input class="form-check-input"
                                   type="checkbox"
                                   role="switch"
                                   @bind="model.WebOnly" />
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="section-divider"></div>
        <div class="row mb-3">
            <div class="col-md-6">
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-2 form-label-custom">Promo Name</label>
                    <div class="col-sm-4">
                        <input class="form-control"
                               @bind="model.PromoName"
                               maxlength="@(MaxLengthHelper.For<ProductDto>(nameof(ProductDto.PromoName)))" />
                    </div>
                    <label class="col-sm-2 form-label-custom form-label-custom--indent">Promo Price</label>
                    <div class="col-sm-4">
                        <input type="number" step="0.01" class="form-control" @bind="model.PromoPrice" />
                    </div>
                </div>
                <div class="row mb-3 align-items-center">
                    <label class="col-sm-2 form-label-custom">Promo Start</label>
                    <div class="col-sm-4">
                        <input type="date" class="form-control" @bind="model.PromoStart" />
                    </div>
                    <label class="col-sm-2 form-label-custom form-label-custom--indent">Promo End</label>
                    <div class="col-sm-4">
                        <input type="date" class="form-control" @bind="model.PromoEnd" />
                    </div>
                </div>
            </div>
        </div>
                </div>
            }
            else if (activeTab == ProductTabs.MinMax)
            {
                <div class="tab-pane fade show active">
                    @if (isLocationLoading)
                    {
                        <div class="text-center text-muted py-4">
                            Loading location thresholds...
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(locationError))
                    {
                        <div class="alert alert-warning py-2 px-3">
                            @locationError
                        </div>
                    }
                    else
                    {
                        <div class="row g-3">
                            <div class="col-md-6">
                                <div class="minmax-column-header">
                                    <span class="flex-grow-1">Location</span>
                                    <span class="label-gap text-end">Min</span>
                                    <span class="label-gap text-end">Max</span>
                                    <span class="label-toggle text-end">Replenish</span>
                                </div>
                                @foreach (var location in locationThresholds.Take(15))
                                {
                                    <div class="minmax-location-row d-flex align-items-center gap-2 mt-2" @key="location.LocationCode">
                                        <div class="flex-grow-1">
                                            <div class="fw-semibold">@location.LocationCode</div>
                                            <div class="small text-muted">@location.LocationName</div>
                                        </div>
                                        <div class="label-gap">
                                            <input type="number"
                                                   class="form-control form-control-sm"
                                                   step="1"
                                                   min="0"
                                                   @bind="location.Min" />
                                        </div>
                                        <div class="label-gap">
                                            <input type="number"
                                                   class="form-control form-control-sm"
                                                   step="1"
                                                   min="0"
                                                   @bind="location.Max" />
                                        </div>
                                        <div class="label-toggle">
                                            <div class="form-check form-switch mb-0">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       role="switch"
                                                       @bind="location.Replenish" />
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                            <div class="col-md-6">
                                <div class="minmax-column-header">
                                    <span class="flex-grow-1">Location</span>
                                    <span class="label-gap text-end">Min</span>
                                    <span class="label-gap text-end">Max</span>
                                    <span class="label-toggle text-end">Replenish</span>
                                </div>
                                @foreach (var location in locationThresholds.Skip(15).Take(15))
                                {
                                    <div class="minmax-location-row d-flex align-items-center gap-2 mt-2" @key="location.LocationCode">
                                        <div class="flex-grow-1">
                                            <div class="fw-semibold">@location.LocationCode</div>
                                            <div class="small text-muted">@location.LocationName</div>
                                        </div>
                                        <div class="label-gap">
                                            <input type="number"
                                                   class="form-control form-control-sm"
                                                   step="1"
                                                   min="0"
                                                   @bind="location.Min" />
                                        </div>
                                        <div class="label-gap">
                                            <input type="number"
                                                   class="form-control form-control-sm"
                                                   step="1"
                                                   min="0"
                                                   @bind="location.Max" />
                                        </div>
                                        <div class="label-toggle">
                                            <div class="form-check form-switch mb-0">
                                                <input class="form-check-input"
                                                       type="checkbox"
                                                       role="switch"
                                                       @bind="location.Replenish" />
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            else if (activeTab == ProductTabs.Description)
            {
                <div class="tab-pane fade show active">
                    <div class="row mb-3 align-items-start">
                        <label class="col-sm-2 form-label-custom">Short Description</label>
                        <div class="col-sm-10">
                            <textarea class="form-control" rows="2" @bind="model.ShortDescription"></textarea>
                        </div>
                    </div>
                    <div class="row mb-3 align-items-start">
                        <label class="col-sm-2 form-label-custom">Full Description</label>
                        <div class="col-sm-10">
                            <RichTextEditor @ref="descEditor" @bind-Value="model.FullDescription" />
                        </div>
                    </div>
                </div>
            }
            else if (activeTab == ProductTabs.Images)
            {
                <div class="tab-pane fade show active">
                    <div class="row">
                        <div class="col-12">
                            <ImageUploader Model="model" @key="imageKey" />
                        </div>
                    </div>
                </div>
            }
            else if (activeTab == ProductTabs.Ecommerce)
            {
                <div class="tab-pane fade show active">
                    <div class="alert alert-info mb-0">
                        Use the Product Info tab for pricing, e-commerce visibility, and promotional controls.
                    </div>
                </div>
            }
            else if (activeTab == ProductTabs.Specification)
            {
                <div class="tab-pane fade show active">
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <RichTextEditor @bind-Value="model.Specifications" />
                        </div>
                    </div>
                </div>
            }
            else if (activeTab == ProductTabs.Geometry)
            {
                <div class="tab-pane fade show active">
                    <div class="row mb-3">
                        <div class="col-md-12">
                            <RichTextEditor @bind-Value="model.Geometry" />
                        </div>
                    </div>
                </div>
            }
            else if (activeTab == ProductTabs.ProductNotes)
            {
                <div class="tab-pane fade show active">
                    <div class="row mb-3">
                        <div class="col-md-6">
                            <textarea class="form-control" rows="5" @bind="model.Notes"></textarea>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    <div class="card-footer d-flex justify-content-start gap-2 bg-light py-3 px-4">
        <button class="btn btn-primary px-4" @onclick="OnSaveClicked">Save</button>

        @* <button class="btn btn-primary px-4" @onclick="Save">Save</button> *@
        <button class="btn btn-outline-secondary px-4" @onclick="Cancel">Cancel</button>
    </div>
    @if (showWarningModal)
    {
        <div class="modal fade show d-block" style="background:rgba(0,0,0,0.5)">
            <div class="modal-dialog modal-md">
                <div class="modal-content">
                    <div class="modal-header bg-warning">
                        <h5 class="modal-title">Incomplete Data</h5>
                    </div>
                    <div class="modal-body">
                        <p>The following fields are empty:</p>
                        <ul>
                            @foreach (var w in warnings)
                            {
                                <li>@w</li>
                            }
                        </ul>
                        <p>Do you want to continue anyway?</p>
                    </div>
                    <div class="modal-footer">
                        <button class="btn btn-secondary" @onclick="() => showWarningModal = false">
                            Cancel
                        </button>
                        <button class="btn btn-warning" @onclick="ConfirmSave">
                            Continue Anyway
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }

</div>



@code {
    bool isGroupItem = false;
    GroupProductDto group = new();
    ProductDto model = new();
    Guid imageKey = Guid.NewGuid();
    private string activeTab = ProductTabs.ProductInfo;
    private List<LocationMinMax> locationThresholds = new();
    private bool isLocationLoading = true;
    private string? locationError;
    private RichTextEditor? descEditor;
    InputFile? fileInput;
    [Parameter]
    public List<ImageUploadResultDto> Images { get; set; } = new();
    DotNetObjectReference<Products>? dotNetRef;
    ElementReference partNumberInput;
    ElementReference mfrPartInput;
    string? shortcutRegistrationId;
    bool showNewItemMessage;
    bool isPartNumberDisabled;
    List<string> hardErrors = new();
    List<string> warnings = new();
    bool showWarningModal;
    [Parameter]
    public string? PartNumber { get; set; }
    bool isEditMode => !string.IsNullOrWhiteSpace(PartNumber);
    string PageHeader =>
    isEditMode || isPartNumberDisabled
        ? "Add New Product"
        : "Product Maintenance";

    private void SetActiveTab(string tab)
    {
        activeTab = tab;
    }

    private string TabClass(string tab)
        => $"nav-link{(activeTab == tab ? " active fw-semibold" : " text-muted")}";

    protected override async Task OnInitializedAsync()
    {
        await base.OnInitializedAsync();
        await LoadLocationThresholdsAsync();
        await ConsumePendingProductSelectionAsync();
    }

    private async Task LoadLocationThresholdsAsync()
    {
        try
        {
            var locations = (await LocationService.GetAllAsync())
                .OrderBy(l => l.Code)
                .Take(30)
                .Select((location, index) => new LocationMinMax
                {
                    LocationCode = string.IsNullOrWhiteSpace(location.Code)
                        ? (index + 1).ToString("D2")
                        : location.Code,
                    LocationName = string.IsNullOrWhiteSpace(location.Name)
                        ? $"Location {(index + 1).ToString("D2")}"
                        : location.Name
                })
                .ToList();

            for (int i = locations.Count; i < 30; i++)
            {
                var code = (i + 1).ToString("D2");
                locations.Add(new LocationMinMax
                {
                    LocationCode = code,
                    LocationName = $"Location {code}"
                });
            }

            locationThresholds = locations;
        }
        catch (Exception)
        {
            locationError = "Unable to load location names from settings.";
        }
        finally
        {
            isLocationLoading = false;
        }
    }


    protected override async Task OnParametersSetAsync()
    {
        // Route-based edit
        if (!string.IsNullOrWhiteSpace(PartNumber))
        {
            model.PartNumber = PartNumber;
            isPartNumberDisabled = true;
            showNewItemMessage = false;

            var res = await ProductApi.GetProduct(PartNumber);

            if (res?.Success == true && res.Data != null)
            {
                model = res.Data;
                await AppSnackbar.Show("Product loaded for edit", SnackbarType.Success);
            }
            else
            {
                await AppSnackbar.Show("Product not found", SnackbarType.Error);
                await Reset();
            }
        }
    }


    bool ValidateHard()
    {
        hardErrors.Clear();

        if (string.IsNullOrWhiteSpace(model.Make))
            hardErrors.Add("Brand is required");
        if (string.IsNullOrWhiteSpace(model.MfrPartNumber))
            hardErrors.Add("MFR Part no is required");

        if (string.IsNullOrWhiteSpace(model.Supplier1Code))
            hardErrors.Add("Supplier is required");

        if (string.IsNullOrWhiteSpace(model.CatACode))
            hardErrors.Add("Category A is required");

        if (string.IsNullOrWhiteSpace(model.Search1))
            hardErrors.Add("Search1 is required");

        if (string.IsNullOrWhiteSpace(model.Details))
            hardErrors.Add("Details is required");

        return hardErrors.Count == 0;
    }
    bool ValidateWarnings()
    {
        warnings.Clear();

        if (string.IsNullOrWhiteSpace(model.CatBCode))
            warnings.Add("Category B is empty");

        if (string.IsNullOrWhiteSpace(model.CatCCode))
            warnings.Add("Category C is empty");

        if (model.StorePrice <= 0 && model.WebPrice <= 0 && model.SuggestedRRP <= 0)
            warnings.Add("No selling price is defined");

        return warnings.Count == 0;
    }
    string RegexKeepCapsAlnum(string? input, int max)
    {
        if (string.IsNullOrWhiteSpace(input))
            return "";

        var clean = Regex.Replace(input.ToUpper(), @"[^A-Z0-9]", "");
        return clean.Length > max ? clean.Substring(0, max) : clean;
    }
    async Task OnSaveClicked()
    {
        if (!ValidateHard())
        {
            foreach (var err in hardErrors)
                await AppSnackbar.Show(err, SnackbarType.Error);               

            return;
        }

        if (!ValidateWarnings())
        {
            showWarningModal = true;
            return;
        }

        await Save();
    }




    async Task ConfirmSave()
    {
        showWarningModal = false;
        await Save();
    }

    void OnPartNumberBlur()
    {
        if (string.IsNullOrWhiteSpace(model.PartNumber))
