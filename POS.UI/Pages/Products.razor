    async Task Save()
    {
        // =====================================================
        // SINGLE PRODUCT MODE (EXACT OLD BEHAVIOR)
        // =====================================================
        if (!isGroupItem)
        {
            var res = await ProductApi.SaveProduct(model);

            if (res?.Success == true && res.Data != null)
            {
                await AppSnackbar.Show("Product saved successfully", SnackbarType.Success);
                await Reset();
            }
            else
            {
                await AppSnackbar.Show(res?.Message ?? "New product mode activated", SnackbarType.Error);
                
            }

            return;
        }


        if (string.IsNullOrWhiteSpace(group.GroupName))
        {
            await AppSnackbar.Show("Group Name is required", SnackbarType.Error);
            return;
        }

        if (!group.Variants.Any())
        {
            await AppSnackbar.Show("Add at least one variant", SnackbarType.Error);
            return;
        }


        // 1) Save the MAIN item first
        model.GroupName = group.GroupName;
        model.IsVariant = false;

        var mainRes = await ProductApi.SaveProduct(model);

        if (mainRes?.Success != true || mainRes.Data == null)
        {
           await AppSnackbar.Show("Failed to save main product", SnackbarType.Error);
           
            return;
        }


        var main = mainRes.Data;

        // 2) Use main.PartNumber as GroupCode
        group.GroupCode = main.PartNumber;

        // 3) Copy header data to each variant
        foreach (var v in group.Variants)
        {
            v.GroupCode = group.GroupCode;
            v.IsVariant = true;

            v.Make = main.Make;
            v.Details = main.Details;
            v.CatACode = main.CatACode;
            v.CatBCode = main.CatBCode;
            v.CatCCode = main.CatCCode;
            v.CostPrice = main.CostPrice;
            v.StorePrice = main.StorePrice;
            v.WebPrice = main.WebPrice;
            v.ImageMain = main.ImageMain;
        }

        // 4) Save variants
        var groupRes = await ProductApi.SaveGroupProduct(group);

        if (groupRes?.Success == true)
        {
            await AppSnackbar.Show("Group saved successfully", SnackbarType.Success);
         
            await Reset();
        }
        else
        {
            await AppSnackbar.Show(groupRes?.Message ?? "Group save failed", SnackbarType.Error);
            
        }



    }



    void AddVariant()
    {
        group.Variants.Add(new ProductDto
        {
            PartNumber = model.PartNumber, // base
            Make = model.Make,
            Details = model.Details,
            CatACode = model.CatACode,
            CatBCode = model.CatBCode,
            CatCCode = model.CatCCode,
            Website = model.Website
        });
    }

    void RemoveVariant(ProductDto v)
    {
        group.Variants.Remove(v);
    }

    string GenerateSku(ProductDto v)
    {
        return $"{group.GroupCode}-{v.Color}-{v.Size}";
    }

