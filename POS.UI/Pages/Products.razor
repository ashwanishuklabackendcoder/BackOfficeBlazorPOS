    async Task OnPartNumberKeyDown(KeyboardEventArgs e)
    {
        if (e.Key != "Enter")
            return;

        // allow binding to update
        await Task.Yield();

        var part = model.PartNumber?.Trim();

        if (string.IsNullOrWhiteSpace(part))
        {
            showNewItemMessage = true;
            isPartNumberDisabled = true;
            await AppSnackbar.Show("New product mode activated", SnackbarType.Info);
            await mfrPartInput.FocusAsync();
            return;
        }

        await Search();
        await mfrPartInput.FocusAsync();
    }
    async Task Reset()
    {
        // Reset main product
        model = new ProductDto();

        // Reset variants
        group = new GroupProductDto();
        isGroupItem = false;

        // Reset images
        imageKey = Guid.NewGuid();

        // Reset UI flags
        showNewItemMessage = false;
        isPartNumberDisabled = false;
       

        // Clear rich text editors
        if (descEditor != null)
            await descEditor.Clear();

        // Force child components to rebind
        await InvokeAsync(StateHasChanged);
        await partNumberInput.FocusAsync();
    }



    void OnGroupToggle(ChangeEventArgs e)
    {
        isGroupItem = e.Value is bool b && b;

        // Optional: reset group when turning off
        if (!isGroupItem)
        {
            group = new GroupProductDto();
        }

        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
            return;

        dotNetRef = DotNetObjectReference.Create(this);
        shortcutRegistrationId = await JS.InvokeAsync<string>(
            "blazorShortcuts.register",
            dotNetRef,
            new
            {
                scopeSelector = "#product-form",
                enableEsc = true,
                enableEnter = true,
                enableF5 = true
            });

        await partNumberInput.FocusAsync();
    }

