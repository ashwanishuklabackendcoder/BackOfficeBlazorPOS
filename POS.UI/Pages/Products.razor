    async Task Search()
    {
        showNewItemMessage = false;

        if (string.IsNullOrWhiteSpace(model.PartNumber))
        {
           // AppSnackbar.Show("New item mode. Enter details and press Save.", SnackbarType.Info);
           
            return;
        }

        var res = await ProductApi.GetProduct(model.PartNumber);

        if (res?.Success == true && res.Data != null)
        {
            model = res.Data;
            await AppSnackbar.Show("Product loaded", SnackbarType.Success);
           
        }
        else
        {
            await AppSnackbar.Show("Product not found. New item will be created.", SnackbarType.Warning);
            
        }
    }

    private async Task ConsumePendingProductSelectionAsync()
    {
        var selected = POS.UI.State.PosWorkflowState.PendingProductSelection;
        if (selected?.PartNumber == null)
            return;

        POS.UI.State.PosWorkflowState.PendingProductSelection = null;
        POS.UI.State.PosWorkflowState.PendingProductSearchReturnUri = null;

        model.PartNumber = selected.PartNumber;
        isPartNumberDisabled = false;

        await Search();
        await InvokeAsync(StateHasChanged);
        await partNumberInput.FocusAsync();
    }

