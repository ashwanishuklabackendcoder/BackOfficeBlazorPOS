@page "/stock-transfer"

@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@using POS.UI.State
@using Microsoft.AspNetCore.Components.Web
@inject IJSRuntime JS
@inject IProductApiService ProductApi
@inject IStockService StockService
@inject IStockTransferUiService StockTransferService
@inject AppSnackbarService AppSnackbar


<PageTitle>Stock Transfer</PageTitle>

<div class="card shadow-sm border-0 form-shell-card product-list-card">
    <div class="card-header d-flex justify-content-between align-items-center py-3">
        <div>
            <h5 class="form-shell-title">Stock Transfer</h5>
            <div class="form-shell-subtitle">Move stock between locations without changing the workflow</div>
        </div>
    </div>

    <div class="card-body form-shell-body p-4">
        <div class="glass-panel border rounded-3 px-3 py-3">

        <!-- PART -->
        <div class="row mb-3">
            <label class="col-sm-2 form-label-custom required-label">Part No</label>
            <div  class="col-sm-3">
                    @* @ref="partNumberInput" *@
                    <input id="partNumber"
                       
                       class="form-control"
                       @bind-value="PartNumber"
                       maxlength="@(MaxLengthHelper.For<StockTransferInputDto>(nameof(StockTransferInputDto.PartNumber)))"
                       @bind-value:event="oninput"
                       @onkeydown="OnPartKeyDown" />
                @* <input id="partNumber" class="form-control"
                       @bind="PartNumber"
                       @onkeydown="OnPartKeyDown" /> *@
            </div>
            <div class="col-sm-2">
                <button class="btn btn-primary w-100 search-btn" @onclick="SearchProduct">
                    Search
                </button>
            </div>
        </div>

        <!-- PRODUCT INFO -->
        <div class="row mb-3">
                <div class="col-sm-3">
                    <input class="form-control readonly-box" value="@Product?.Make" readonly />
                </div>
            <div class="col-sm-3">
                <input class="form-control readonly-box" value="@Product?.Details" readonly />
            </div>
        </div>

        <div class="row">

            <!-- LEFT: TRANSFER INPUT -->
            <div class="col-md-6">
                <div class="soft-panel p-3">

                <div class="row mb-2">
                    <label class="col-sm-4 form-label-custom required-label">Transfer From</label>
                    <div class="col-sm-8">
                        <LocationSelector @bind-Value="FromLocation" @bind-Value:after="OnFromLocationChanged" />
                    
                    </div>
                </div>

                <div class="row mb-2">
                    <label class="col-sm-4 form-label-custom required-label">Transfer To</label>
                    <div class="col-sm-8">
                        <LocationSelector @bind-Value="ToLocation" />
                    </div>
                </div>

                <div class="row mb-2">
                    <label class="col-sm-4 form-label-custom required-label">Quantity (Available: @AvailableFromStock)</label>
                    <div class="col-sm-4">
                        <input type="number" class="form-control" @bind="Quantity" />
                    </div>
                </div>

                <div class="row mb-2">
                    <label class="col-sm-4 form-label-custom">Sales Code</label>
                    <div class="col-sm-4">
                        <StaffCodeLookup @bind-Value="SalesCode"
                                         MaxLength="@(MaxLengthHelper.For<StockTransferInputDto>(nameof(StockTransferInputDto.SalesCode)))" />
                    </div>
                </div>

                <div class="row mb-2">
                    <label class="col-sm-4 form-label-custom">Cost</label>
                    <div class="col-sm-4">
                        <input type="number"
                               step="0.01"
                               min="0"
                               class="form-control"
                               @bind-value="Cost"
                               @bind-value:event="oninput" />
                    </div>
                </div>

                <div class="row mb-2">
                    <label class="col-sm-4 form-label-custom">Stock No</label>
                    <div class="col-sm-4">
                        <input class="form-control"
                               @bind="StockNumber"
                               maxlength="@(MaxLengthHelper.For<StockTransferInputDto>(nameof(StockTransferInputDto.StockNumber)))" />
                    </div>
                </div>

                <div class="row mb-2">
                    <label class="col-sm-4 form-label-custom">Serial No</label>
                    <div class="col-sm-4">
                        <input class="form-control"
                               @bind="SerialNumber"
                               maxlength="@(MaxLengthHelper.For<StockTransferInputDto>(nameof(StockTransferInputDto.SerialNumber)))" />
                    </div>
                </div>

                <div class="row mb-3">
                    <label class="col-sm-4 form-label-custom">Notes</label>
                    <div class="col-sm-8">
                        <input class="form-control"
                               @bind="Notes"
                               maxlength="@(MaxLengthHelper.For<StockTransferInputDto>(nameof(StockTransferInputDto.Notes)))" />
                    </div>
                </div>

                <button class="btn btn-success px-4" @onclick="Transfer">
                    Transfer
                </button>
                </div>

            </div>

            <!-- RIGHT: SESSION TRANSFERS -->
            <div class="col-md-6">

                <div class="info-header">
                    <h6 class="form-section-title mb-0">Transfers This Session</h6>
                </div>

                <div style="max-height:220px; overflow-y:auto;">
                    <table class="table table-sm table-bordered">
                        <thead>
                            <tr>
                                <th>Part</th>
                                <th>From</th>
                                <th>To</th>
                                <th>Qty</th>
                                <th>Cost</th>
                                <th>Stock No</th>
                                <th>Serial No</th>
                                <th>Sales</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var t in SessionTransfers)
                            {
                                <tr>
                                    <td>@t.PartNumber</td>
                                    <td>@t.FromLocation</td>
                                    <td>@t.ToLocation</td>
                                    <td>@t.Quantity</td>
                                    <td>@t.Cost.ToString("0.00")</td>
                                    <td>@t.StockNumber</td>
                                    <td>@t.SerialNumber</td>
                                    <td>@t.SalesCode</td>
                                </tr>
                            }
                            @if (!SessionTransfers.Any())
                            {
                                <tr>
                                    <td colspan="8" class="text-center text-muted">
                                        No transfers yet
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>

            </div>

        </div>
        </div>
        </div>
    </div>

@code {

    string? PartNumber;
    ProductDto? Product;
    DotNetObjectReference<StockTransfer>? dotNetRef;
    string? FromLocation;
    private string? _fromLocation;
    string? ToLocation;
    int Quantity = 1;
    int AvailableFromStock;
    string? SalesCode;
    decimal Cost = 0m;
    string? StockNumber;
    string? SerialNumber;
    string? Notes;

    List<StockTransferInputDto> SessionTransfers = new();



    protected override void OnInitialized()
    {
        FromLocation = GetCurrentLocation();

    }
    string GetCurrentLocation()
     => string.IsNullOrWhiteSpace(PosWorkflowState.PosLocation) ? "01" : PosWorkflowState.PosLocation;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            if (string.IsNullOrWhiteSpace(FromLocation))
                FromLocation = "01";

            await RefreshAvailableFromStockAsync();
        }

        if (!firstRender)
            return;

        dotNetRef = DotNetObjectReference.Create(this);

        await JS.InvokeVoidAsync("enableProductShortcuts", dotNetRef);
        await JS.InvokeVoidAsync("enableEnterNavigation");

        await JS.InvokeVoidAsync(
            "eval",
            "document.getElementById('partNumber')?.focus()"
        );
    }
    async Task OnPartKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await Task.Yield(); // allow bind to complete
            await SearchProduct();
        }
    }
    async Task SearchProduct()
    {
        if (string.IsNullOrWhiteSpace(PartNumber))
        {
            await AppSnackbar.Show("Enter Part Number", SnackbarType.Warning);
            return;
        }

        var res = await ProductApi.GetProduct(PartNumber);

        if (res?.Success != true || res.Data == null)
        {
            Product = null;
            await AppSnackbar.Show("Product not found", SnackbarType.Error);
            return;
        }

        Product = res.Data;
        Cost = Product?.CostPrice ?? 0m;
        await RefreshAvailableFromStockAsync();
        await AppSnackbar.Show("Product loaded", SnackbarType.Success);
    }

    // async Task OnPartKeyDown(KeyboardEventArgs e)
    // {
    //     if (e.Key == "Enter")
    //         await SearchProduct();
    // }

    async Task Transfer()
    {
        if (Product == null)
        {
            await AppSnackbar.Show("Load product first", SnackbarType.Error);
            return;
        }

        if (string.IsNullOrWhiteSpace(FromLocation) ||
            string.IsNullOrWhiteSpace(ToLocation))
        {
            await AppSnackbar.Show("Select both From and To locations", SnackbarType.Error);
            return;
        }

        if (FromLocation == ToLocation)
        {
            await AppSnackbar.Show("From and To locations cannot be same", SnackbarType.Error);
            return;
        }

        if (Quantity <= 0)
        {
            await AppSnackbar.Show("Quantity must be greater than zero", SnackbarType.Error);
            return;
        }

        if (Quantity > AvailableFromStock)
        {
            if (AvailableFromStock==0)
            {
                await AppSnackbar.Show($"Stock is un-available in location {FromLocation}", SnackbarType.Warning);
                return;
            }
            else
            {
                Quantity = AvailableFromStock;
                await AppSnackbar.Show($"Only {AvailableFromStock} item(s) available in location {FromLocation}", SnackbarType.Warning);
                return;
            }
            
        }

        var dto = new StockTransferInputDto
        {
            PartNumber = Product.PartNumber,
            FromLocation = FromLocation,
            ToLocation = ToLocation,
            Quantity = Quantity,
            SalesCode = SalesCode ?? "",
            Cost = Cost,
            StockNumber = StockNumber,
            SerialNumber = SerialNumber,
            Notes = Notes ?? ""
        };

        var result = await StockTransferService.ApplyTransferAsync(dto);
        if (!result.Success)
        {
            await AppSnackbar.Show(result.Message, SnackbarType.Error);
            return;
        }

        SessionTransfers.Add(dto);
        await AppSnackbar.Show(result.Message ?? "Stock transferred successfully", SnackbarType.Success);
        await RefreshAvailableFromStockAsync();
        Quantity = 1;
        Cost = 0m;
        StockNumber = null;
        SerialNumber = null;
        Notes = null;
    }

    async Task OnFromLocationChanged()
    {
       
        await RefreshAvailableFromStockAsync();
    }

    async Task RefreshAvailableFromStockAsync()
    {
        if (string.IsNullOrWhiteSpace(PartNumber) || string.IsNullOrWhiteSpace(FromLocation))
        {
            AvailableFromStock = 0;
            Quantity = 0;
            return;
        }

        var levels = await StockService.GetStockLevelsAsync(PartNumber);

        AvailableFromStock = levels
            .FirstOrDefault(x => string.Equals(x.LocationCode, FromLocation, StringComparison.OrdinalIgnoreCase))
            ?.Quantity ?? 0;

        // Adjust quantity when location changes
        if (AvailableFromStock == 0)
        {
            Quantity = 0;
        }
        else if (Quantity > AvailableFromStock)
        {
            Quantity = AvailableFromStock;
        }
        else if (Quantity == 0)
        {
            Quantity = 1;
        }

        StateHasChanged();
    }

}

