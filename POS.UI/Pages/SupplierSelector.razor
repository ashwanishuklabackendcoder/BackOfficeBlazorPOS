@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@inject ISupplierService SupplierService
@inject IJSRuntime JS
@inject SelectorOverlayService OverlayService

<div class="position-relative" @ref="root">
    <div class="form-control d-flex justify-content-between align-items-center"
         style="cursor:pointer; min-height: calc(1.5em + 0.75rem + 2px);"
         @onclick="ToggleAsync">
        <span class="text-truncate">@(string.IsNullOrEmpty(Display) ? " " : Display)</span>
        <span class="d-inline-flex align-items-center gap-2 ms-2">
            @if (!string.IsNullOrWhiteSpace(Value))
            {
                <button type="button"
                        title="Clear"
                        aria-label="Clear selection"
                        style="width:18px; height:18px; border:none; border-radius:50%; background:gray; color:white; display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; line-height:1; padding:0;"
                        @onclick="ClearSelection"
                        @onclick:stopPropagation="true">
                    &times;
                </button>
            }
            <i class="bi bi-chevron-down"></i>
        </span>
    </div>
</div>

@if (showManage)
{
    <div class="modal fade show d-block"
         style="background:rgba(0,0,0,.5); position:fixed; inset:0; z-index:3000; overflow:auto;">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Manage Suppliers</h5>
                    <button class="btn-close" @onclick="CloseManage"></button>
                </div>

                <div class="modal-body">
                    <Supplier />
                </div>

            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    List<SupplierDto> suppliers = new();
    bool open, showManage;
    string search = "";
    string Display = "";
    SelectorOverlayPlacement? overlayPlacement;
    const string OverlayKey = nameof(SupplierSelector);

    ElementReference root;
    IJSObjectReference? selectorModule;

    protected override async Task OnInitializedAsync()
    {
        suppliers = await SupplierService.GetAllAsync();
        SyncDisplay();
    }

    protected override void OnParametersSet()
    {
        SyncDisplay();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            selectorModule = await JS.InvokeAsync<IJSObjectReference>("import", "./selectorOverlay.js");
    }

    IEnumerable<SupplierDto> Filtered =>
        string.IsNullOrEmpty(search)
            ? suppliers
            : suppliers.Where(x =>
                (x.Name ?? string.Empty).Contains(search, StringComparison.OrdinalIgnoreCase) ||
                (x.AccountNo ?? string.Empty).Contains(search, StringComparison.OrdinalIgnoreCase));

    async Task ToggleAsync()
    {
        if (open)
        {
            await CloseOverlayAsync();
            return;
        }

        await OpenOverlayAsync();
    }

    async Task Select(SupplierDto s)
    {
        Value = s.AccountNo;
        Display = s.Name;
        await ValueChanged.InvokeAsync(Value);
        await CloseOverlayAsync();
    }

    async Task ClearSelection()
    {
        Value = "";
        Display = " ";
        search = "";
        await ValueChanged.InvokeAsync(Value);
        await CloseOverlayAsync();
    }

    async Task OpenManage()
    {
        await CloseOverlayAsync();
        showManage = true;
    }

    async Task OnSupplierSaved(SupplierDto s)
    {
        suppliers = await SupplierService.GetAllAsync();
        await Select(s);
        showManage = false;
    }

    void CloseManage() => showManage = false;

    void SyncDisplay()
    {
        if (string.IsNullOrWhiteSpace(Value))
        {
            Display = " ";
            return;
        }

        var match = suppliers.FirstOrDefault(x =>
            string.Equals(x.AccountNo, Value, StringComparison.OrdinalIgnoreCase));

        Display = match?.Name ?? Value ?? "";
    }

    async Task OpenOverlayAsync()
    {
        open = true;
        showManage = false;
        overlayPlacement = selectorModule != null
            ? await selectorModule.InvokeAsync<SelectorOverlayPlacement>("measureAnchor", root)
            : null;
        await OverlayService.ShowAsync(
            OverlayKey,
            typeof(SelectorDropdownPanel<SupplierDto>),
            BuildOverlayParameters(),
            overlayPlacement,
            HandleOverlayDismissedAsync);
        await InvokeAsync(StateHasChanged);
    }

    async Task CloseOverlayAsync()
    {
        if (!open && OverlayService.Current is null)
            return;

        await OverlayService.RequestCloseAsync();
        open = false;
        overlayPlacement = null;
        await InvokeAsync(StateHasChanged);
    }

    async Task HandleOverlayDismissedAsync()
    {
        open = false;
        overlayPlacement = null;
        await InvokeAsync(StateHasChanged);
    }

    IDictionary<string, object> BuildOverlayParameters()
    {
        return new Dictionary<string, object>
        {
            ["Items"] = Filtered.ToList(),
            ["ItemText"] = (Func<SupplierDto, string>)(s => $"{s.AccountNo} - {(string.IsNullOrEmpty(s.Name) ? "NA" : s.Name)}"),
            ["IsSelected"] = (Func<SupplierDto, bool>)(s => string.Equals(Value, s.AccountNo, StringComparison.OrdinalIgnoreCase)),
            ["ItemSelected"] = EventCallback.Factory.Create<SupplierDto>(this, Select),
            ["SearchChanged"] = EventCallback.Factory.Create<string>(this, OnSearchChanged),
            ["OnManage"] = EventCallback.Factory.Create(this, OpenManage),
            ["InitialSearch"] = search,
            ["SearchPlaceholder"] = "Search...",
            ["ManageLabel"] = "Manage"
        };
    }

    async Task OnSearchChanged(string value)
    {
        search = value;

        if (open)
            await RefreshOverlayAsync();
    }

    async Task RefreshOverlayAsync()
    {
        if (!open || overlayPlacement is null)
            return;

        await OverlayService.ShowAsync(
            OverlayKey,
            typeof(SelectorDropdownPanel<SupplierDto>),
            BuildOverlayParameters(),
            overlayPlacement,
            HandleOverlayDismissedAsync);
    }
}
