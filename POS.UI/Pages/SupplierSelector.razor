@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@inject ISupplierService SupplierService
@inject IJSRuntime JS

<div class="position-relative" @ref="root">
    <div class="form-control d-flex justify-content-between align-items-center"
         style="cursor:pointer; min-height: calc(1.5em + 0.75rem + 2px);"
         @onclick="Toggle">
        <span class="text-truncate">@(string.IsNullOrEmpty(Display) ? " " : Display)</span>
        <span class="d-inline-flex align-items-center gap-2 ms-2">
            @if (!string.IsNullOrWhiteSpace(Value))
            {
                <button type="button"
                        title="Clear"
                        aria-label="Clear selection"
                        style="width:18px; height:18px; border:none; border-radius:50%; background:gray; color:white; display:inline-flex; align-items:center; justify-content:center; font-size:0.85rem; line-height:1; padding:0;"
                        @onclick="ClearSelection"
                        @onclick:stopPropagation="true">
                    ×
                </button>
            }
            <i class="bi bi-chevron-down"></i>
        </span>
    </div>

    @if (open)
    {
        <div class="border bg-white shadow p-2"
             style="position:absolute; top:100%; left:0; z-index:1055; width:clamp(300px, 150%, 560px); max-width:calc(100vw - 1rem); height:260px; min-height:230px; max-height:80vh; display:flex; flex-direction:column; resize:both; overflow:hidden;">

            
            <div class="p-2 border-bottom">
                <input class="form-control border"
                       @bind="search"
                       @bind:event="oninput" />
            </div>

            <div style="flex:1 1 auto; min-height:80px; overflow:auto">
                @foreach (var s in Filtered)
                {
                    <button class="list-group-item list-group-item-action"
                            @onclick="() => Select(s)">
                        @s.AccountNo - @(string.IsNullOrEmpty(s.Name) ? "NA" : s.Name)
                    </button>
                }
            </div>

            <div class="border-top p-2 bg-light">
                <button type="button"
                        class="btn text-primary p-0"
                        @onclick="OpenManage"
                        @onclick:stopPropagation="true">
                    <i class="bi bi-gear me-1"></i>Manage
                </button>
            </div>
        </div>
    }
</div>

@if (showManage)
{
    <div class="modal fade show d-block"
         style="background:rgba(0,0,0,.5); position:fixed; inset:0; z-index:3000; overflow:auto;">
        <div class="modal-dialog modal-lg modal-dialog-centered modal-dialog-scrollable">
            <div class="modal-content">

                <div class="modal-header">
                    <h5>Manage Suppliers</h5>
                    <button class="btn-close" @onclick="CloseManage"></button>
                </div>

                <div class="modal-body">
                    <Supplier/>
                 @*    <SupplierEditor OnSaved="OnSupplierSaved"
                                    OnCancel="CloseManage" /> *@
                </div>

            </div>
        </div>
    </div>
}

@code {
    [Parameter] public string? Value { get; set; }
    [Parameter] public EventCallback<string?> ValueChanged { get; set; }

    List<SupplierDto> suppliers = new();
    bool open, showManage;
    string search = "";
    string Display = "";
    ElementReference root;
    IJSObjectReference? module;
    IJSObjectReference? outsideHandler;
    DotNetObjectReference<SupplierSelector>? dotNetRef;
    protected override async Task OnInitializedAsync()
    {
        suppliers = await SupplierService.GetAllAsync();
        SyncDisplay();
    }

    protected override void OnParametersSet()
    {
        SyncDisplay();
    }


    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            module = await JS.InvokeAsync<IJSObjectReference>(
                "import", "./clickOutside.js");

            outsideHandler = await JS.InvokeAsync<IJSObjectReference>(
                "registerClickOutside", root, dotNetRef);

        }
    }

    [JSInvokable]
    public void OnClickOutside()
    {
        if (open)
        {
            open = false;
            InvokeAsync(StateHasChanged);
        }
    }
    IEnumerable<SupplierDto> Filtered =>
        string.IsNullOrEmpty(search)
            ? suppliers
            : suppliers.Where(x =>
                x.Name.Contains(search, StringComparison.OrdinalIgnoreCase) ||
                x.AccountNo.Contains(search));

    void Toggle() => open = !open;

    async Task Select(SupplierDto s)
    {
        Value = s.AccountNo;
        Display = s.Name;
        await ValueChanged.InvokeAsync(Value);
        open = false;
    }

    async Task ClearSelection()
    {
        Value = "";
        Display = " ";
        search = "";
        await ValueChanged.InvokeAsync(Value);
        open = false;
    }

    void OpenManage()
    {
        open = false;
        showManage = true;
    }

    async Task OnSupplierSaved(SupplierDto s)
    {
        suppliers = await SupplierService.GetAllAsync();
        await Select(s);
        showManage = false;
    }

    void CloseManage() => showManage = false;

    void SyncDisplay()
    {
        if (string.IsNullOrWhiteSpace(Value))
        {
            Display = " ";
            return;
        }

        var match = suppliers.FirstOrDefault(x =>
            string.Equals(x.AccountNo, Value, StringComparison.OrdinalIgnoreCase));

        Display = match?.Name ?? Value ?? "";
    }

    public async ValueTask DisposeAsync()
    {
        if (outsideHandler != null)
            await outsideHandler.InvokeVoidAsync("dispose");

        dotNetRef?.Dispose();
    }
}
