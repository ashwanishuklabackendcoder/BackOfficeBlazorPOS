@using BackOfficeBlazor.Shared.DTOs
@using POS.UI.Services
@using POS.UI.Pages
@using System.Text.Json
@inject IPurchaseOrderApiService PurchaseOrderApi
@inject AppSnackbarService AppSnackbar
@inject IAuthService AuthService
@inject IJSRuntime JS

@if (DirectRaiseMode)
{
    <div class="card shadow-sm border-0 form-shell-card product-list-card @WorkspaceClass po-raise-screen">
        <div class="card-header d-flex justify-content-between align-items-center py-3">
            <div>
                <h5 class="form-shell-title">@Title</h5>
                @if (!string.IsNullOrWhiteSpace(Subtitle))
                {
                    <div class="form-shell-subtitle">@Subtitle</div>
                }
            </div>
            <div class="form-shell-meta">
                @if (Header != null)
                {
                    <span>Status: <strong>@CurrentStatusText</strong></span>
                }
                else
                {
                    <span>Direct raise</span>
                }
            </div>
        </div>

        <div class="card-body p-4">
            <div class="row g-4">
                <div class="col-lg-7">
                    <div class="row g-3 align-items-end">
                        <div class="col-md-4 fw-semibold text-uppercase">Location</div>
                        <div class="col-md-8">
                            <LocationSelector @bind-Value="LocationCode" @bind-Value:after="OnDirectLocationChanged" />
                            <div class="small text-primary fw-semibold mt-1">@(string.IsNullOrWhiteSpace(LocationCode) ? "ALL LOC" : LocationCode)</div>
                        </div>

                        <div class="col-md-4 fw-semibold text-uppercase">Supplier</div>
                        <div class="col-md-8">
                            <div class="d-flex align-items-center gap-2">
                                <span class="text-danger fw-bold small">F5</span>
                                <div class="flex-grow-1">
                                    <SupplierSelector Value="@SupplierCode" ValueChanged="OnSupplierChanged" />
                                </div>
                            </div>
                            <div class="small text-primary fw-semibold mt-1">@SupplierNameOrFallback</div>
                        </div>

                        <div class="col-md-4 fw-semibold text-uppercase">Major / Minor</div>
                        <div class="col-md-8">
                            <select class="form-select" @bind="DirectItemScope">
                                <option value="@PurchaseOrderItemScope.All">Major &amp; Minor</option>
                                <option value="@PurchaseOrderItemScope.MajorOnly">Major Only</option>
                                <option value="@PurchaseOrderItemScope.MinorOnly">Minor Only</option>
                            </select>
                        </div>

                        <div class="col-md-4 fw-semibold text-uppercase">Sales Code</div>
                        <div class="col-md-8">
                            <StaffCodeLookup @bind-Value="DirectSalesCode" InputClass="form-control w-25" />
                        </div>

                        <div class="col-md-4 fw-semibold text-uppercase">Footer Message</div>
                        <div class="col-md-8">
                            <textarea class="form-control" rows="4" @bind="DirectFooterMessage"></textarea>
                        </div>
                    </div>

                    <div class="mt-3 d-flex flex-wrap gap-2 align-items-center">
                        <div class="form-check me-2">
                            <input class="form-check-input" type="checkbox" id="poPreviewOnly" @bind="DirectPreviewOnly" />
                            <label class="form-check-label" for="poPreviewOnly">Preview after raise</label>
                        </div>
                        <button class="btn btn-warning" @onclick="DirectRaiseOrder" disabled="@DirectBusy">
                            @(DirectBusy ? "Raising..." : "RAISE PURCHASE ORDERS")
                        </button>
                        <button class="btn btn-outline-secondary" @onclick="ResetDirectRaise" disabled="@DirectBusy">Reset</button>
                        <button class="btn btn-outline-primary" @onclick="PreviewCurrentReport" disabled="@(!CanPreviewCurrentReport || DirectBusy)">Preview</button>
                    </div>
                </div>

                <div class="col-lg-5">
                    <div class="border rounded p-3 bg-light h-100">
                        <div class="row g-2 mb-3">
                            <div class="col-6"><strong>Raised By</strong></div>
                            <div class="col-6 text-end">@RaisedByCode</div>
                            <div class="col-6"><strong>Location</strong></div>
                            <div class="col-6 text-end">@(string.IsNullOrWhiteSpace(LocationCode) ? "ALL LOC" : LocationCode)</div>
                            <div class="col-6"><strong>Supplier</strong></div>
                            <div class="col-6 text-end">@SupplierNameOrFallback</div>
                            <div class="col-6"><strong>Scope</strong></div>
                            <div class="col-6 text-end">@DirectItemScope</div>
                        </div>

                        <div class="border rounded p-3 bg-white">
                            <div class="small text-muted">Preview</div>
                            <div class="text-muted small">
                                The hidden draft will be generated from the selected supplier and location, then raised immediately.
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(LastDirectActionMessage))
            {
                <div class="alert alert-info mt-3 mb-0">@LastDirectActionMessage</div>
            }
        </div>
    </div>

    @if (ShowDirectPreview)
    {
        <div class="modal fade show d-block" style="background:rgba(0,0,0,0.5)">
            <div class="modal-dialog modal-xl modal-dialog-scrollable" style="max-width:95vw">
                <div class="modal-content">
                    <div class="modal-header">
                        <h5 class="modal-title">@DirectPreviewTitle</h5>
                        <button type="button" class="btn-close" @onclick="CloseDirectPreview"></button>
                    </div>
                    <div class="modal-body p-0" style="height:80vh">
                        <iframe title="@DirectPreviewTitle"
                                srcdoc="@DirectPreviewHtml"
                                style="width:100%; height:100%; border:0; display:block;"></iframe>
                    </div>
                </div>
            </div>
        </div>
    }
}
else
{
    <div class="card shadow-sm border-0 form-shell-card product-list-card @WorkspaceClass">
    <div class="card-header d-flex justify-content-between align-items-center py-3">
        <div>
            <h5 class="form-shell-title">@Title</h5>
            @if (!string.IsNullOrWhiteSpace(Subtitle))
            {
                <div class="form-shell-subtitle">@Subtitle</div>
            }
        </div>
        <div class="form-shell-meta">
            @if (Header != null)
            {
                <span>Status: <strong>@CurrentStatusText</strong></span>
            }
            else
            {
                <span>Draft workspace</span>
            }
        </div>
    </div>

        <div class="card-body p-4">
        @if (ShowOrderControls)
        {
            @if (IsReceiveLookupMode || IsAmendMode)
            {
                <div class="row g-3 align-items-end mb-3 po-top-controls">
                    <div class="col-lg-5 col-xl-4">
                        <label class="form-label">Order Number</label>
                        <input class="form-control"
                               @bind="OrderNumber"
                               @bind:event="oninput"
                               placeholder="0000000001" />
                    </div>
                    <div class="col-auto d-flex align-items-end">
                        <button type="button" class="btn btn-outline-secondary" @onclick="LoadOrder">Find</button>
                    </div>
                    <div class="col-auto d-flex align-items-end">
                        <button type="button" class="btn btn-primary" @onclick="OpenSupplierSearchModal">
                            F5 - Search by Supplier
                        </button>
                    </div>
                </div>
            }
            else
            {
                <div class="row g-3 align-items-end mb-3 po-top-controls">
                    @if (ShowDraftLoader)
                    {
                        <div class="col-md-2">
                            <label class="form-label">Draft Ref</label>
                            <input class="form-control" @bind="DraftRefText" placeholder="Draft ref" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button class="btn btn-outline-secondary w-100" @onclick="LoadDraft">Load Draft</button>
                        </div>
                    }

                    @if (ShowOrderNumberLookup)
                    {
                        <div class="col-md-2">
                            <label class="form-label">Order Number</label>
                            <input class="form-control" @bind="OrderNumber" placeholder="0000000001" />
                        </div>
                        <div class="col-md-2 d-flex align-items-end">
                            <button class="btn btn-outline-secondary w-100" @onclick="LoadOrder">Load Order</button>
                        </div>
                    }

                    <div class="col-md-3">
                        <label class="form-label">Search Orders</label>
                        <input class="form-control" @bind="SearchQuery" @bind:event="oninput" placeholder="Order no / supplier" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Supplier</label>
                        <div class="d-flex align-items-center gap-2">
                            <span class="text-danger fw-bold small">F5</span>
                            <div class="flex-grow-1">
                                <SupplierSelector Value="@SupplierCode" ValueChanged="OnSupplierChanged" />
                            </div>
                        </div>
                    </div>
                    <div class="col-md-2 d-flex gap-2 po-actions">
                        <button class="btn btn-primary" @onclick="SearchOrders">Search</button>
                        <button class="btn btn-outline-secondary" @onclick="NewDraft">New</button>
                    </div>
                </div>
            }
        }

        @if (!IsReceiveLookupMode && !IsAmendMode)
        {
            <div class="row g-3 align-items-end mb-3 po-summary-strip">
                <div class="col-md-2">
                    <label class="form-label">Raised By</label>
                    <input class="form-control" @bind="RaisedByCode" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Carriage Cost</label>
                    <input type="number" step="0.01" class="form-control" @bind="CarriageCost" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Shipping Cost</label>
                    <input type="number" step="0.01" class="form-control" @bind="ShippingCost" />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Settlement Discount</label>
                    <input type="number" step="0.01" class="form-control" @bind="SettlementDiscount" />
                </div>
                <div class="col-md-4 d-flex gap-2 flex-wrap po-actions">
                    @if (AllowSaveDraft)
                    {
                        <button class="btn btn-success" @onclick="SaveDraft">Save Draft</button>
                    }
                    @if (AllowRaise)
                    {
                        <button class="btn btn-warning" @onclick="RaiseOrder">Raise Order</button>
                    }
                    @if (AllowReceive)
                    {
                        <button class="btn btn-info" @onclick="ReceiveOrder" disabled="@(!CanReceive)">Receive</button>
                    }
                    @if (AllowCancel)
                    {
                        <button class="btn btn-danger" @onclick="CancelOrder" disabled="@string.IsNullOrWhiteSpace(OrderNumber)">Cancel</button>
                    }
                    @if (AllowAddProduct)
                    {
                        <button class="btn btn-secondary" @onclick="() => ShowProductSearch = true">Add Product</button>
                    }
                </div>
            </div>
        }

        <div class="mb-3 small text-muted">
            @if (!string.IsNullOrWhiteSpace(DraftRefDisplay))
            {
                <span>Draft Ref: <strong>@DraftRefDisplay</strong></span>
            }
            @if (!string.IsNullOrWhiteSpace(SupplierName))
            {
                <span class="ms-3">Supplier: <strong>@SupplierName</strong></span>
            }
        </div>

        <div class="table-responsive">
            <table class="table table-sm table-bordered align-middle">
                <thead class="table-light">
                    @if (IsReceiveLookupMode)
                    {
                        <tr>
                            <th>#</th>
                            <th>Part No</th>
                            <th>MFR Part</th>
                            <th>Description</th>
                            <th>Box Qty</th>
                            <th>Qty Required</th>
                            <th>Qty Received</th>
                            <th>Qty O/S</th>
                            <th>Cost</th>
                            <th>Notes</th>
                        </tr>
                    }
                    else if (IsAmendMode)
                    {
                        <tr>
                            <th>#</th>
                            <th>Part No</th>
                            <th>MFR Part</th>
                            <th>Description</th>
                            <th>Box Qty</th>
                            <th>Qty Required</th>
                            <th>Cost</th>
                            <th>Notes</th>
                            <th>Line Total</th>
                        </tr>
                    }
                    else
                    {
                        <tr>
                            <th>#</th>
                            <th>Part No</th>
                            <th>MFR Part</th>
                            <th>Description</th>
                            <th>Box Qty</th>
                            <th>Qty Required</th>
                            <th>Qty Received</th>
                            <th>Cost</th>
                            <th>Stock Loc</th>
                            <th>Delivery Loc</th>
                            <th>Notes</th>
                            <th></th>
                        </tr>
                    }
                </thead>
                <tbody>
                    @if (!Lines.Any())
                    {
                        <tr>
                            <td colspan="@(IsReceiveLookupMode ? 10 : IsAmendMode ? 9 : 12)" class="text-center text-muted">No purchase order lines</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var line in Lines.OrderBy(x => x.SequenceId))
                        {
                            if (IsReceiveLookupMode)
                            {
                                <tr>
                                    <td>@line.SequenceId</td>
                                    <td>@line.PartNumber</td>
                                    <td><input class="form-control form-control-sm" value="@line.MfrPartNumber" readonly /></td>
                                    <td><input class="form-control form-control-sm" value="@line.Description" readonly /></td>
                                    <td><input type="number" class="form-control form-control-sm" value="@line.BoxQty" readonly /></td>
                                    <td><input type="number" class="form-control form-control-sm" value="@line.QtyRequired" readonly /></td>
                                    <td>
                                        <input type="number"
                                               class="form-control form-control-sm"
                                               min="0"
                                               max="@line.QtyRequired"
                                               @bind="line.QtyRecieved"
                                               @bind:after="() => NormalizeReceivedQty(line)" />
                                    </td>
                                    <td class="fw-semibold text-primary">@OutstandingQty(line)</td>
                                    <td><input type="number" step="0.01" class="form-control form-control-sm" @bind="line.CostPrice" /></td>
                                    <td><input class="form-control form-control-sm" value="@line.Notes" readonly /></td>
                                </tr>
                            }
                            else if (IsAmendMode)
                            {
                                <tr>
                                    <td>@line.SequenceId</td>
                                    <td><input class="form-control form-control-sm" value="@line.PartNumber" readonly /></td>
                                    <td><input class="form-control form-control-sm" value="@line.MfrPartNumber" readonly /></td>
                                    <td><input class="form-control form-control-sm" value="@line.Description" readonly /></td>
                                    <td><input type="number" class="form-control form-control-sm" value="@line.BoxQty" readonly /></td>
                                    <td>
                                        <input type="number"
                                               class="form-control form-control-sm"
                                               min="1"
                                               @bind="line.QtyRequired"
                                               @bind:after="() => NormalizeAmendQty(line)" />
                                    </td>
                                    <td><input type="number" step="0.01" class="form-control form-control-sm" @bind="line.CostPrice" /></td>
                                    <td><input class="form-control form-control-sm" value="@line.Notes" readonly /></td>
                                    <td class="fw-semibold text-primary">@line.LineTotal.ToString("0.00")</td>
                                </tr>
                            }
                            else
                            {
                                <tr>
                                    <td>@line.SequenceId</td>
                                    <td>@line.PartNumber</td>
                                    <td><input class="form-control form-control-sm" @bind="line.MfrPartNumber" /></td>
                                    <td><input class="form-control form-control-sm" @bind="line.Description" /></td>
                                    <td><input type="number" class="form-control form-control-sm" @bind="line.BoxQty" /></td>
                                    <td><input type="number" class="form-control form-control-sm" @bind="line.QtyRequired" /></td>
                                    <td>
                                        <input type="number" class="form-control form-control-sm" @bind="line.QtyRecieved" disabled="@(!AllowReceive)" />
                                    </td>
                                    <td><input type="number" step="0.01" class="form-control form-control-sm" @bind="line.CostPrice" /></td>
                                    <td><input class="form-control form-control-sm" @bind="line.StockLocationCode" /></td>
                                    <td><input class="form-control form-control-sm" @bind="line.DeliveryLocationCode" /></td>
                                    <td><input class="form-control form-control-sm" @bind="line.Notes" /></td>
                                    <td class="text-center">
                                        <button class="btn btn-sm btn-outline-danger" @onclick="() => RemoveLine(line)">X</button>
                                    </td>
                                </tr>
                            }
                        }
                    }
                </tbody>
                <tfoot>
                    @if (IsReceiveLookupMode)
                    {
                        <tr class="table-light">
                            <th colspan="5" class="text-end">Totals</th>
                            <th>@TotalQtyRequired</th>
                            <th>@TotalQtyReceived</th>
                            <th>@TotalQtyOutstanding</th>
                            <th>@TotalCost.ToString("0.00")</th>
                            <th></th>
                        </tr>
                    }
                    else if (IsAmendMode)
                    {
                        <tr class="table-light">
                            <th colspan="5" class="text-end">Totals</th>
                            <th>@TotalQtyRequired</th>
                            <th></th>
                            <th></th>
                            <th>@TotalCost.ToString("0.00")</th>
                        </tr>
                    }
                    else
                    {
                        <tr class="table-light">
                            <th colspan="5" class="text-end">Totals</th>
                            <th>@TotalQtyRequired</th>
                            <th>@TotalQtyReceived</th>
                            <th>@TotalCost.ToString("0.00")</th>
                            <th colspan="4"></th>
                        </tr>
                    }
                </tfoot>
            </table>
        </div>

        @if (AllowAmend)
        {
            <div class="row g-3 mt-2">
                <div class="col-12">
                    <div class="card border-0 bg-light po-results-card">
                        <div class="card-header fw-semibold">Amendment Summary</div>
                        <div class="card-body">
                            <div class="row g-3">
                                <div class="col-md-3">
                                    <label class="form-label">Raised By</label>
                                    <input class="form-control" @bind="RaisedByCode" readonly />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Supplier</label>
                                    <input class="form-control" value="@SupplierNameOrFallback" readonly />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Status</label>
                                    <input class="form-control" value="@CurrentStatusText" readonly />
                                </div>
                                <div class="col-md-3">
                                    <label class="form-label">Total Cost</label>
                                    <input class="form-control" value="@TotalCost.ToString("0.00")" readonly />
                                </div>
                            </div>

                            <div class="d-flex flex-wrap gap-2 mt-3">
                                <button class="btn btn-warning" @onclick="AmendOrder" disabled="@(!CanAmend)">Save Amendment</button>
                                <button class="btn btn-outline-secondary" @onclick="ReloadCurrentOrder" disabled="@string.IsNullOrWhiteSpace(OrderNumber)">Reload</button>
                                @if (AllowCancel)
                                {
                                    <button class="btn btn-outline-danger" @onclick="CancelOrder" disabled="@string.IsNullOrWhiteSpace(OrderNumber)">Cancel</button>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
        else if (AllowReceiveAllocation)
        {
            <div class="row g-3 mt-2">
                <div class="col-md-6">
                    <div class="card border-0 bg-light po-allocation-card">
                        <div class="card-header fw-semibold">Receive Allocation</div>
                        <div class="card-body">
                            <div class="row g-2">
                                <div class="col-md-4">
                                    <label class="form-label">Divide Carriage</label>
                                    <input type="checkbox" class="form-check-input ms-2" @bind="DivideCarriageAcrossItems" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Divide Shipping</label>
                                    <input type="checkbox" class="form-check-input ms-2" @bind="DivideShippingAcrossItems" />
                                </div>
                                <div class="col-md-4">
                                    <label class="form-label">Divide Discount</label>
                                    <input type="checkbox" class="form-check-input ms-2" @bind="DivideSettlementDiscountAcrossItems" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    @if (IsReceiveLookupMode)
                    {
                        <div class="card border-0 bg-light po-results-card h-100">
                            <div class="card-header fw-semibold">Receive Summary</div>
                            <div class="card-body">
                                <div class="row g-3">
                                    <div class="col-md-6">
                                        <label class="form-label">Raised By</label>
                                        <input class="form-control" @bind="RaisedByCode" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Carriage Cost</label>
                                        <input type="number" step="0.01" class="form-control" @bind="CarriageCost" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Shipping Cost</label>
                                        <input type="number" step="0.01" class="form-control" @bind="ShippingCost" />
                                    </div>
                                    <div class="col-md-6">
                                        <label class="form-label">Settlement Discount</label>
                                        <input type="number" step="0.01" class="form-control" @bind="SettlementDiscount" />
                                    </div>
                                </div>

                                <div class="d-flex flex-wrap gap-2 mt-3">
                                    @if (AllowReceive)
                                    {
                                        <button class="btn btn-info" @onclick="ReceiveOrder" disabled="@(!CanReceive)">Receive</button>
                                    }
                                    @if (AllowCancel)
                                    {
                                        <button class="btn btn-danger" @onclick="CancelOrder" disabled="@string.IsNullOrWhiteSpace(OrderNumber)">Cancel</button>
                                    }
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="card border-0 bg-light po-results-card">
                            <div class="card-header fw-semibold">Search Results</div>
                            <div class="card-body">
                                <table class="table table-sm table-bordered mb-0">
                                    <thead class="table-light">
                                        <tr>
                                            <th>Order</th>
                                            <th>Supplier</th>
                                            <th>Status</th>
                                            <th>Date</th>
                                            <th>Qty</th>
                                            <th>Received</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (!SearchResults.Any())
                                        {
                                            <tr>
                                                <td colspan="6" class="text-center text-muted">No results</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var row in SearchResults)
                                            {
                                                <tr style="cursor:pointer" @onclick="() => LoadOrder(row.OrderNumber)">
                                                    <td>@row.OrderNumber</td>
                                                    <td>@row.SupplierName</td>
                                                    <td>@row.Status</td>
                                                    <td>@row.RaisedOnDate.ToString("dd/MM/yyyy")</td>
                                                    <td>@row.QtyOrdered</td>
                                                    <td>@row.QtyReceived</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else if (ShowOrderSearchResults)
        {
            <div class="row g-3 mt-2">
                <div class="col-12">
                    <div class="card border-0 bg-light po-results-card">
                        <div class="card-header fw-semibold">Search Results</div>
                        <div class="card-body">
                            <table class="table table-sm table-bordered mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Order</th>
                                        <th>Supplier</th>
                                        <th>Status</th>
                                        <th>Date</th>
                                        <th>Qty</th>
                                        <th>Received</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @if (!SearchResults.Any())
                                    {
                                        <tr>
                                            <td colspan="6" class="text-center text-muted">No results</td>
                                        </tr>
                                    }
                                    else
                                    {
                                        @foreach (var row in SearchResults)
                                        {
                                            <tr style="cursor:pointer" @onclick="() => LoadOrder(row.OrderNumber)">
                                                <td>@row.OrderNumber</td>
                                                <td>@row.SupplierName</td>
                                                <td>@row.Status</td>
                                                <td>@row.RaisedOnDate.ToString("dd/MM/yyyy")</td>
                                                <td>@row.QtyOrdered</td>
                                                <td>@row.QtyReceived</td>
                                            </tr>
                                        }
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@if (ShowSupplierSearchModal && SupplierSearchModalOpen)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-xl modal-dialog-scrollable" style="max-width:80vw">
            <div class="modal-content" style="height:85vh;">
                <div class="modal-header">
                    <div>
                        <h5 class="modal-title mb-0">Search Purchase Orders</h5>
                        <div class="small text-muted">
                            @(IsReceiveLookupMode || IsAmendMode
                                ? "Select from suppliers with raised orders only, then search and pick an order."
                                : "Select a supplier, search, then pick an order.")
                        </div>
                    </div>
                    <button type="button" class="btn-close" @onclick="CloseSupplierSearchModal"></button>
                </div>
                <div class="modal-body" style="overflow-y:auto;">
                    <div class="row g-3 align-items-end">
                        <div class="col-lg-5">
                            <label class="form-label">@(IsReceiveLookupMode || IsAmendMode ? "Supplier (raised orders only)" : "Supplier")</label>
                            @if (IsReceiveLookupMode || IsAmendMode)
                            {
                                <select class="form-select" @bind="SearchSupplierCode" @bind:after="SearchOrders">
                                    <option value="">All suppliers with raised orders</option>
                                    @foreach (var supplier in AmendmentSupplierOptions)
                                    {
                                        <option value="@supplier.SupplierCode">
                                            @(string.IsNullOrWhiteSpace(supplier.SupplierName) ? supplier.SupplierCode : supplier.SupplierName) (@supplier.SupplierCode)
                                        </option>
                                    }
                                </select>
                            }
                            else
                            {
                                <SupplierSelector Value="@SearchSupplierCode" ValueChanged="OnSearchSupplierChanged" />
                            }
                        </div>
                        <div class="col-lg-5">
                            <label class="form-label">Search Orders</label>
                            <input class="form-control"
                                   @bind="SearchQuery"
                                   @bind:event="oninput"
                                   placeholder="Order no / supplier" />
                        </div>
                        <div class="col-lg-2 d-flex gap-2">
                            <button type="button" class="btn btn-primary flex-grow-1" @onclick="SearchOrders">Search</button>
                            <button type="button" class="btn btn-outline-secondary" @onclick="CloseSupplierSearchModal">Close</button>
                        </div>
                    </div>

                    <div class="table-responsive mt-3">
                        <table class="table table-sm table-bordered align-middle mb-0">
                            <thead class="table-light">
                                <tr>
                                    <th>Order</th>
                                    <th>Supplier</th>
                                    <th>Status</th>
                                    <th>Date</th>
                                    <th>Qty</th>
                                    <th>Received</th>
                                </tr>
                            </thead>
                            <tbody>
                                @if (!SearchResults.Any())
                                {
                                    <tr>
                                        <td colspan="6" class="text-center text-muted py-4">No results</td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (var row in SearchResults)
                                    {
                                        <tr style="cursor:pointer" @onclick="() => SelectOrderFromSearch(row.OrderNumber)">
                                            <td>@row.OrderNumber</td>
                                            <td>@row.SupplierName</td>
                                            <td>@row.Status</td>
                                            <td>@row.RaisedOnDate.ToString("dd/MM/yyyy")</td>
                                            <td>@row.QtyOrdered</td>
                                            <td>@row.QtyReceived</td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@if (ShowProductSearch)
{
    <div class="modal fade show d-block" style="background:rgba(0,0,0,0.5)">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Select Product</h5>
                    <button class="btn-close" @onclick="() => ShowProductSearch = false"></button>
                </div>
                <div class="modal-body">
                    <ProductSearchGrid OnSelected="AddProductFromSearch" />
                </div>
            </div>
        </div>
    </div>
}

}

@code {
    [Parameter] public string Title { get; set; } = "Purchase Orders";
    [Parameter] public string Subtitle { get; set; } = string.Empty;
    [Parameter] public bool ShowDraftLoader { get; set; }
    [Parameter] public bool ShowOrderNumberLookup { get; set; }
    [Parameter] public bool AllowSaveDraft { get; set; } = true;
    [Parameter] public bool AllowRaise { get; set; } = true;
    [Parameter] public bool AllowReceive { get; set; }
    [Parameter] public bool AllowAmend { get; set; }
    [Parameter] public bool AllowCancel { get; set; }
    [Parameter] public bool AllowAddProduct { get; set; } = true;
    [Parameter] public bool AllowReceiveAllocation { get; set; }
    [Parameter] public bool ShowOrderSearchResults { get; set; } = true;
    [Parameter] public bool ShowSupplierSearchModal { get; set; }
    [Parameter] public string WorkspaceClass { get; set; } = string.Empty;
    [Parameter] public bool DirectRaiseMode { get; set; }

    int? DraftRef;
    string DraftRefText = string.Empty;
    string OrderNumber = string.Empty;
    string SearchQuery = string.Empty;
    string SupplierCode = string.Empty;
    string SearchSupplierCode = string.Empty;
    string SupplierName = string.Empty;
    string RaisedByCode = string.Empty;
    string LocationCode = string.Empty;
    string DirectSalesCode = string.Empty;
    string DirectFooterMessage = string.Empty;
    decimal CarriageCost;
    decimal ShippingCost;
    decimal SettlementDiscount;
    bool DivideCarriageAcrossItems = true;
    bool DivideShippingAcrossItems = true;
    bool DivideSettlementDiscountAcrossItems = true;
    bool ShowProductSearch;
    bool SupplierSearchModalOpen;
    bool DirectPreviewOnly = true;
    bool DirectBusy;
    string LastDirectActionMessage = string.Empty;
    bool ShowDirectPreview;
    string DirectPreviewHtml = string.Empty;
    string DirectPreviewTitle = string.Empty;
    PurchaseOrderItemScope DirectItemScope = PurchaseOrderItemScope.All;
    PurchaseOrderHeaderDto? Header;
    List<PurchaseOrderLineDto> Lines = new();
    List<PurchaseOrderSummaryDto> SearchResults = new();
    List<PurchaseOrderSupplierOptionDto> AmendmentSupplierOptions = new();
    readonly Dictionary<int, decimal> OriginalLineCosts = new();

    bool CanReceive =>
        !string.IsNullOrWhiteSpace(OrderNumber) &&
        Header != null &&
        Header.Status != (int)PurchaseOrderStatus.Cancelled &&
        Header.Status != (int)PurchaseOrderStatus.Received;
    bool CanAmend =>
        !string.IsNullOrWhiteSpace(OrderNumber) &&
        Header != null &&
        Header.Status == (int)PurchaseOrderStatus.Raised;

    string DraftRefDisplay => DraftRef?.ToString() ?? "-";
    string CurrentStatusText =>
        Header == null
            ? "Draft"
            : Enum.IsDefined(typeof(PurchaseOrderStatus), Header.Status)
                ? Enum.GetName(typeof(PurchaseOrderStatus), Header.Status) ?? $"Status {Header.Status}"
                : $"Status {Header.Status}";
    string SupplierNameOrFallback =>
        !string.IsNullOrWhiteSpace(SupplierName)
            ? SupplierName
            : (string.IsNullOrWhiteSpace(SupplierCode) ? "ALL SUPPLIERS" : SupplierCode);
    int TotalQtyRequired => Lines.Sum(x => x.QtyRequired);
    int TotalQtyReceived => Lines.Sum(x => x.QtyRecieved);
    int TotalQtyOutstanding => Lines.Sum(x => Math.Max(x.QtyRequired - x.QtyRecieved, 0));
    decimal TotalCost =>
        IsAmendMode
            ? Lines.Sum(x => x.QtyRequired * x.CostPrice)
            : Lines.Sum(x => x.QtyRecieved * x.CostPrice);
    bool ShowOrderControls => ShowDraftLoader || ShowOrderNumberLookup || ShowOrderSearchResults;
    bool IsReceiveLookupMode => AllowReceive && ShowOrderNumberLookup && !DirectRaiseMode;
    bool IsAmendMode => AllowAmend && ShowOrderNumberLookup && !DirectRaiseMode;
    bool CanPreviewCurrentReport => !string.IsNullOrWhiteSpace(JsonReport) || !string.IsNullOrWhiteSpace(Header?.JsonReport);
    string? JsonReport;

    protected override void OnInitialized()
    {
        RaisedByCode = AuthService.CurrentUser?.StaffCode ?? string.Empty;
    }

    async Task SearchOrders()
    {
        var searchStatus = (AllowReceive || AllowAmend) ? (int)PurchaseOrderStatus.Raised : (int?)null;
        var result = await PurchaseOrderApi.SearchAsync(SearchQuery, SearchSupplierCode, searchStatus);
        if (!result.Success)
        {
            await AppSnackbar.Show(result.Message, SnackbarType.Error);
            return;
        }

        SearchResults = result.Data ?? new();
    }

    async Task OnSupplierChanged(string? value)
    {
        SupplierCode = value ?? string.Empty;
        if (DirectRaiseMode)
        {
            LastDirectActionMessage = string.Empty;
            return;
        }
    }

    async Task OnSearchSupplierChanged(string? value)
    {
        SearchSupplierCode = value ?? string.Empty;
        if (SupplierSearchModalOpen)
            await SearchOrders();
    }

    async Task OpenSupplierSearchModal()
    {
        SupplierSearchModalOpen = true;
        SearchSupplierCode = SupplierCode;
        if (IsReceiveLookupMode || IsAmendMode)
            await LoadRaisedSupplierOptions();

        if (string.IsNullOrWhiteSpace(SearchQuery) && string.IsNullOrWhiteSpace(SearchSupplierCode))
        {
            SearchResults = new();
            return;
        }

        await SearchOrders();
    }

    void CloseSupplierSearchModal()
    {
        SupplierSearchModalOpen = false;
    }

    async Task SelectOrderFromSearch(string orderNo)
    {
        CloseSupplierSearchModal();
        await LoadOrder(orderNo);
    }

    Task OnDirectLocationChanged()
    {
        if (DirectRaiseMode)
            LastDirectActionMessage = string.Empty;

        return Task.CompletedTask;
    }

    async Task LoadDraft()
    {
        if (!int.TryParse(DraftRefText, out var draftRef))
        {
            await AppSnackbar.Show("Enter a valid draft ref", SnackbarType.Warning);
            return;
        }

        var result = await PurchaseOrderApi.GetDraftAsync(draftRef);
        if (!result.Success || result.Data == null)
        {
            await AppSnackbar.Show(result.Message, SnackbarType.Error);
            return;
        }

        ApplyWorkspace(result.Data);
        await AppSnackbar.Show("Draft loaded", SnackbarType.Success);
    }

    async Task LoadOrder()
    {
        if (string.IsNullOrWhiteSpace(OrderNumber))
        {
            await AppSnackbar.Show("Enter an order number", SnackbarType.Warning);
            return;
        }

        var result = await PurchaseOrderApi.GetAsync(OrderNumber);
        if (!result.Success || result.Data == null)
        {
            await AppSnackbar.Show(result.Message, SnackbarType.Error);
            return;
        }

        if (AllowAmend && result.Data.Header?.Status != (int)PurchaseOrderStatus.Raised)
        {
            await AppSnackbar.Show("Only raised purchase orders can be amended", SnackbarType.Warning);
            return;
        }

        ApplyWorkspace(result.Data);
        if (IsReceiveLookupMode)
            InitializeReceiveQuantities();
        await AppSnackbar.Show("Order loaded", SnackbarType.Success);
    }

    async Task LoadOrder(string orderNo)
    {
        OrderNumber = orderNo;
        await LoadOrder();
    }

    async Task ReloadCurrentOrder()
    {
        if (string.IsNullOrWhiteSpace(OrderNumber))
            return;

        await LoadOrder();
    }

    async Task SaveDraft()
    {
        var result = await PurchaseOrderApi.SaveDraftAsync(BuildUpsertRequest());
        if (!result.Success || result.Data == null)
        {
            await AppSnackbar.Show(result.Message, SnackbarType.Error);
            return;
        }

        ApplyWorkspace(result.Data);
        await AppSnackbar.Show("Draft saved", SnackbarType.Success);
    }

    async Task RaiseOrder()
    {
        var result = await PurchaseOrderApi.RaiseAsync(BuildUpsertRequest());
        if (!result.Success || result.Data == null)
        {
            await AppSnackbar.Show(result.Message, SnackbarType.Error);
            return;
        }

        ApplyWorkspace(result.Data);
        await AppSnackbar.Show("Purchase order raised", SnackbarType.Success);
    }

    async Task DirectRaiseOrder()
    {
        if (DirectBusy)
            return;

        if (string.IsNullOrWhiteSpace(SupplierCode))
        {
            await AppSnackbar.Show("Select supplier", SnackbarType.Warning);
            return;
        }

        DirectBusy = true;
        try
        {
            var result = await PurchaseOrderApi.RaiseDirectAsync(BuildDirectRaiseRequest());
            if (!result.Success || result.Data == null)
            {
                await AppSnackbar.Show(result.Message, SnackbarType.Error);
                return;
            }

            ApplyWorkspace(result.Data);
            LastDirectActionMessage = result.Message;
            await AppSnackbar.Show(result.Message, SnackbarType.Success);

            if (DirectPreviewOnly)
                await PreviewCurrentReport();
        }
        finally
        {
            DirectBusy = false;
        }
    }

    async Task ReceiveOrder()
    {
        if (!CanReceive)
        {
            await AppSnackbar.Show("Load a raised order first", SnackbarType.Warning);
            return;
        }

        NormalizeReceiveQuantities();
        var request = BuildReceiveRequest();
        if (HasProductItemPriceChanges())
        {
            var confirm = await JS.InvokeAsync<bool>(
                "confirm",
                "One or more product item prices will change from this receipt. Update product item prices?");

            request.UpdateProductItemPrices = confirm;
        }

        var result = await PurchaseOrderApi.ReceiveAsync(request);
        if (!result.Success || result.Data == null)
        {
            await AppSnackbar.Show(result.Message, SnackbarType.Error);
            return;
        }

        ApplyWorkspace(result.Data);
        await AppSnackbar.Show("Purchase order received", SnackbarType.Success);
    }

    async Task AmendOrder()
    {
        if (!CanAmend)
        {
            await AppSnackbar.Show("Load a raised order first", SnackbarType.Warning);
            return;
        }

        NormalizeAmendQuantities();

        var result = await PurchaseOrderApi.AmendAsync(BuildAmendRequest());
        if (!result.Success || result.Data == null)
        {
            await AppSnackbar.Show(result.Message, SnackbarType.Error);
            return;
        }

        ApplyWorkspace(result.Data);
        await AppSnackbar.Show("Purchase order amended", SnackbarType.Success);
    }

    async Task CancelOrder()
    {
        if (string.IsNullOrWhiteSpace(OrderNumber))
            return;

        var result = await PurchaseOrderApi.CancelAsync(OrderNumber, RaisedByCode);
        if (!result.Success)
        {
            await AppSnackbar.Show(result.Message, SnackbarType.Error);
            return;
        }

        Header ??= new PurchaseOrderHeaderDto();
        Header.Status = (int)PurchaseOrderStatus.Cancelled;
        await AppSnackbar.Show("Purchase order cancelled", SnackbarType.Success);
    }

    async Task LoadRaisedSupplierOptions()
    {
        if (AmendmentSupplierOptions.Any())
            return;

        var result = await PurchaseOrderApi.GetSupplierOptionsAsync((int)PurchaseOrderStatus.Raised);
        AmendmentSupplierOptions = result.Success && result.Data != null
            ? result.Data
            : new List<PurchaseOrderSupplierOptionDto>();
    }

    void NewDraft()
    {
        DraftRef = null;
        DraftRefText = string.Empty;
        OrderNumber = string.Empty;
        SupplierCode = string.Empty;
        SearchSupplierCode = string.Empty;
        SupplierName = string.Empty;
        Header = null;
        Lines = new();
        SearchResults = new();
        AmendmentSupplierOptions = new();
        CarriageCost = 0;
        ShippingCost = 0;
        SettlementDiscount = 0;
    }

    void ResetDirectRaise()
    {
        LocationCode = string.Empty;
        SupplierCode = string.Empty;
        SupplierName = string.Empty;
        DirectSalesCode = string.Empty;
        DirectFooterMessage = string.Empty;
        DirectItemScope = PurchaseOrderItemScope.All;
        DirectPreviewOnly = true;
        DirectBusy = false;
        LastDirectActionMessage = string.Empty;
        Header = null;
        JsonReport = null;
        ShowDirectPreview = false;
        DirectPreviewHtml = string.Empty;
        DirectPreviewTitle = string.Empty;
        OrderNumber = string.Empty;
        DraftRef = null;
    }

    void RemoveLine(PurchaseOrderLineDto line)
    {
        Lines.Remove(line);
        ReSequence();
    }

    async Task AddProductFromSearch(ProductDto product)
    {
        ShowProductSearch = false;

        if (product == null)
            return;

        var existing = Lines.FirstOrDefault(x => string.Equals(x.PartNumber, product.PartNumber, StringComparison.OrdinalIgnoreCase));
        if (existing != null)
        {
            existing.QtyRequired += 1;
            existing.CostPrice = existing.CostPrice > 0 ? existing.CostPrice : (product.CostPrice);
            existing.Description = string.IsNullOrWhiteSpace(existing.Description) ? product.Details ?? product.ShortDescription ?? product.PartNumber ?? string.Empty : existing.Description;
            return;
        }

        Lines.Add(new PurchaseOrderLineDto
        {
            SequenceId = Lines.Count + 1,
            PartNumber = product.PartNumber ?? string.Empty,
            MfrPartNumber = product.MfrPartNumber ?? string.Empty,
            Description = product.Details ?? product.ShortDescription ?? product.PartNumber ?? string.Empty,
            BoxQty = product.BoxQuantity ?? 1,
            QtyRequired = 1,
            CostPrice = product.CostPrice,
            QtyRecieved = 0,
            StockLocationCode = "01",
            DeliveryLocationCode = "01",
            CustomerAccNo = string.Empty,
            IsMajor = product.Major,
            XmasClub = false,
            SmsCustomerOnArrival = false,
            Notes = string.Empty,
            OrderedByCode = RaisedByCode,
            SupplierCode = SupplierCode,
            CreatedOnDate = DateTime.UtcNow,
            Reason = string.Empty
        });
    }

    PurchaseOrderUpsertRequestDto BuildUpsertRequest() =>
        new()
        {
            DraftRef = DraftRef,
            SupplierCode = SupplierCode,
            RaisedByStaffCode = RaisedByCode,
            CarriageCost = CarriageCost,
            DirectToStore = false,
            Lines = Lines.ToList()
        };

    PurchaseOrderDirectRaiseRequestDto BuildDirectRaiseRequest() =>
        new()
        {
            LocationCode = LocationCode,
            SupplierCode = SupplierCode,
            RaisedByStaffCode = RaisedByCode,
            SalesCode = DirectSalesCode,
            FooterMessage = DirectFooterMessage,
            ItemScope = DirectItemScope,
            PreviewOnly = DirectPreviewOnly
        };

    PurchaseOrderReceiveRequestDto BuildReceiveRequest() =>
        new()
        {
            OrderNumber = OrderNumber,
            ReceivedByCode = RaisedByCode,
            CarriageCost = CarriageCost,
            ShippingCost = ShippingCost,
            SettlementDiscount = SettlementDiscount,
            DivideCarriageAcrossItems = DivideCarriageAcrossItems,
            DivideShippingAcrossItems = DivideShippingAcrossItems,
            DivideSettlementDiscountAcrossItems = DivideSettlementDiscountAcrossItems,
            Lines = Lines.Select(x => new PurchaseOrderReceiveLineDto
            {
                ItemId = x.Id,
                PartNumber = x.PartNumber,
                SequenceId = x.SequenceId,
                QtyReceived = x.QtyRecieved,
                ReceivedUnitCost = x.CostPrice,
                StockLocationCode = x.StockLocationCode,
                DeliveryLocationCode = x.DeliveryLocationCode
            }).ToList()
        };

    PurchaseOrderAmendRequestDto BuildAmendRequest() =>
        new()
        {
            OrderNumber = OrderNumber,
            AmendedByCode = RaisedByCode,
            Lines = Lines.Select(x => new PurchaseOrderAmendLineDto
            {
                ItemId = x.Id,
                PartNumber = x.PartNumber,
                SequenceId = x.SequenceId,
                QtyRequired = x.QtyRequired,
                CostPrice = x.CostPrice
            }).ToList()
        };

    void ApplyWorkspace(PurchaseOrderWorkspaceDto workspace)
    {
        DraftRef = workspace.DraftRef == 0 ? null : workspace.DraftRef;
        DraftRefText = DraftRef?.ToString() ?? string.Empty;
        Header = workspace.Header;
        JsonReport = workspace.JsonReport ?? workspace.Header?.JsonReport;
        OrderNumber = workspace.Header?.OrderNumber ?? OrderNumber;
        SupplierCode = workspace.Header?.SupplierCode ?? SupplierCode;
        SupplierName = workspace.SupplierName;
        Lines = workspace.Lines.ToList();
        CaptureOriginalLineCosts();
        ReSequence();
    }

    void CaptureOriginalLineCosts()
    {
        OriginalLineCosts.Clear();
        foreach (var line in Lines)
            OriginalLineCosts[line.Id] = line.CostPrice;
    }

    void InitializeReceiveQuantities()
    {
        foreach (var line in Lines)
            line.QtyRecieved = Math.Clamp(line.QtyRequired, 0, line.QtyRequired);
    }

    void NormalizeReceiveQuantities()
    {
        foreach (var line in Lines)
            line.QtyRecieved = Math.Clamp(line.QtyRecieved, 0, line.QtyRequired);
    }

    void NormalizeReceivedQty(PurchaseOrderLineDto line)
    {
        line.QtyRecieved = Math.Clamp(line.QtyRecieved, 0, line.QtyRequired);
    }

    void NormalizeAmendQuantities()
    {
        foreach (var line in Lines)
            line.QtyRequired = Math.Max(line.QtyRequired, 1);
    }

    void NormalizeAmendQty(PurchaseOrderLineDto line)
    {
        line.QtyRequired = Math.Max(line.QtyRequired, 1);
    }

    int OutstandingQty(PurchaseOrderLineDto line) =>
        Math.Max(line.QtyRequired - line.QtyRecieved, 0);

    bool HasProductItemPriceChanges()
    {
        if (!AllowReceive)
            return false;

        var totalOrderedQty = Lines.Sum(x => Math.Max(x.QtyRequired, 0));
        if (totalOrderedQty <= 0)
            return false;

        var perUnitAdjustment = 0m;
        if (DivideCarriageAcrossItems)
            perUnitAdjustment += CarriageCost / totalOrderedQty;

        if (DivideShippingAcrossItems)
            perUnitAdjustment += ShippingCost / totalOrderedQty;

        if (DivideSettlementDiscountAcrossItems)
            perUnitAdjustment -= SettlementDiscount / totalOrderedQty;

        return Lines.Any(line =>
        {
            var originalCost = OriginalLineCosts.TryGetValue(line.Id, out var cost)
                ? cost
                : line.CostPrice;
            var effectiveCost = decimal.Round(line.CostPrice + perUnitAdjustment, 2, MidpointRounding.AwayFromZero);
            return originalCost != effectiveCost;
        }) || perUnitAdjustment != 0m;
    }

    async Task PreviewCurrentReport()
    {
        var reportJson = JsonReport ?? Header?.JsonReport;
        if (string.IsNullOrWhiteSpace(reportJson))
        {
            await AppSnackbar.Show("No preview available", SnackbarType.Warning);
            return;
        }

        PurchaseOrderReportEnvelopeDto? envelope;
        try
        {
            envelope = JsonSerializer.Deserialize<PurchaseOrderReportEnvelopeDto>(reportJson, new JsonSerializerOptions
            {
                PropertyNameCaseInsensitive = true
            });
        }
        catch
        {
            envelope = null;
        }

        if (envelope?.Result?.ReportHeader == null)
        {
            await AppSnackbar.Show("Unable to render purchase order preview", SnackbarType.Error);
            return;
        }

        DirectPreviewTitle = $"Purchase Order {envelope.Result.ReportHeader.OrderNumber}";
        DirectPreviewHtml = BuildPreviewHtml(envelope);
        ShowDirectPreview = true;
        await InvokeAsync(StateHasChanged);
    }

    void CloseDirectPreview()
    {
        ShowDirectPreview = false;
    }
    static string BuildPreviewHtml(PurchaseOrderReportEnvelopeDto envelope)
    {
        var header = envelope.Result.ReportHeader;
        var rows = envelope.Result.Rows ?? new List<PurchaseOrderReportRowDto>();

        static string E(string? value) => System.Net.WebUtility.HtmlEncode(value ?? string.Empty);

        var sb = new System.Text.StringBuilder();

        sb.AppendLine("<!doctype html><html><head><meta charset='utf-8'>");
        sb.AppendLine("<title>Purchase Order</title>");

        sb.AppendLine("<style>");
        sb.AppendLine(@"
        body{font-family:Arial;margin:0;background:#f5f5f5}
        .page{width:900px;margin:20px auto;background:white;border:1px solid #ccc;padding:20px}
        .header{display:flex;justify-content:space-between;align-items:center;border-bottom:2px solid #333;padding-bottom:10px}
        .logo{width:120px}
        .title{text-align:center;flex-grow:1}
        .title h2{margin:0}
        .company{text-align:right;font-size:13px}
        .section{border:1px solid #aaa;margin-top:15px}
        .section-title{background:#eee;padding:6px;font-weight:bold;border-bottom:1px solid #aaa}
        .grid{display:flex}
        .cell{flex:1;padding:10px;border-right:1px solid #aaa}
        .cell:last-child{border-right:none}
        .info{padding:10px}
        table{width:100%;border-collapse:collapse}
        th,td{border:1px solid #aaa;padding:6px;font-size:13px}
        th{background:#eee}
        .right{text-align:right}
        .notes{height:80px}
        .footer{margin-top:20px;font-size:12px;color:#666}
    ");
        sb.AppendLine("</style></head><body>");

        sb.AppendLine("<div class='page'>");

        // HEADER
        sb.AppendLine("<div class='header'>");
        // sb.AppendLine($"<img class='logo' src='{E(header.LogoUrl)}' />");
        sb.AppendLine($"<img class='logo' src='#' />");
        sb.AppendLine($"<div class='title'><h2>Purchase Order</h2><div>Order #: {E(header.OrderNumber)}</div></div>");
        // sb.AppendLine($"<div class='company'><strong>{E(header.CompanyName)}</strong><br>Tel: {E(header.CompanyPhone)}<br>Email: {E(header.CompanyEmail)}<br>{E(header.CompanyWebsite)}</div>");
        sb.AppendLine($"<div class='company'><strong>Bicycle Chain Pvt. Ltd.</strong><br>Tel: 000000000<br>Email: info@bicyclechain.com<br>bicyclechain.com</div>");
        sb.AppendLine("</div>");

        // ORDER INFO
        sb.AppendLine("<div class='section'>");
        sb.AppendLine("<div class='section-title'>Order Information</div>");
        sb.AppendLine("<div class='grid'>");

        sb.AppendLine($"<div class='cell'><strong>SUPPLIER ADDRESS</strong><br>{E(header.SupplierName)}</div>");

        // sb.AppendLine($@"
        // <div class='cell'>
        // <strong>DELIVERY ADDRESS</strong><br>
        // {E(header.CompanyName)}<br>
        // {E(header.DeliveryAddress1)}<br>
        // {E(header.DeliveryAddress2)}<br>
        // {E(header.PostCode)}<br>
        // Tel: {E(header.CompanyPhone)}
        // </div>");
        sb.AppendLine($@"
        <div class='cell'>
        <strong>DELIVERY ADDRESS</strong><br>
        Bicycle Chain Pvt. Ltd.<br>
        Dorset<br>        
        SP08<br>
        Tel: 000000000
        </div>");

        sb.AppendLine("</div></div>");

        // DATE BLOCK
        sb.AppendLine("<div class='section'>");
        sb.AppendLine($"<div class='info'><strong>Date:</strong> {E(header.OrderDate)}<br>");
        sb.AppendLine($"<strong>Account:</strong> {E(header.SupplierAccNo)}<br>");
        // sb.AppendLine($"<strong>VAT No:</strong> {E(header.VatNo)}</div>");
        sb.AppendLine($"<strong>VAT No:</strong> 00</div>");
        sb.AppendLine("</div>");

        // ITEMS
        sb.AppendLine("<div class='section'>");
        sb.AppendLine("<div class='section-title'>Items</div>");
        sb.AppendLine("<table>");
        sb.AppendLine("<thead><tr>");
        sb.AppendLine("<th>Type</th><th>Your Ref</th><th>Our Ref</th><th>Description</th><th>Quantity</th><th>Unit Price</th><th>Total</th>");
        sb.AppendLine("</tr></thead><tbody>");

        decimal grandTotal = 0;

        foreach (var r in rows)
        {
            grandTotal += r.TotalCost;

            sb.AppendLine($@"
            <tr>
                <td>PO</td>
                <td>{E(r.YourPartNumber)}</td>
                <td>{E(r.OurPartNumber)}</td>
                <td>{E(r.Description)}</td>
                <td>{r.QuantityOrdered}</td>
                <td class='right'>{r.UnitCost:0.00}</td>
                <td class='right'>{r.TotalCost:0.00}</td>
            </tr>");
        }

        sb.AppendLine($@"
        <tr>
            <td colspan='6' class='right'><strong>Total</strong></td>
            <td class='right'><strong>{grandTotal:0.00}</strong></td>
        </tr>");

        sb.AppendLine("</tbody></table></div>");

        // NOTES
        sb.AppendLine("<div class='section'>");
        sb.AppendLine("<div class='section-title'>Notes</div>");
        sb.AppendLine($"<div class='info notes'>{E(header.FooterMessage)}</div>");
        sb.AppendLine("</div>");

        sb.AppendLine("<div class='footer'>Generated by POS System</div>");
        sb.AppendLine("</div></body></html>");

        return sb.ToString();
    }
